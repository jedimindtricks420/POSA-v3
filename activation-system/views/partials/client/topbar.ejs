<header class="fixed top-0 inset-x-0 z-40">
  <div class="px-4 pt-6">
    <div class="glass-panel flex items-center justify-between px-4 py-3">
      <div class="flex items-center gap-3">
        <div class="h-10 w-10 rounded-full bg-apple-blue/10 flex items-center justify-center">
          <span class="text-sm font-semibold text-apple-blue">NW</span>
        </div>
        <div>
          <p class="text-xs uppercase tracking-wider text-slate-500">Wallet</p>
          <p class="text-sm font-semibold text-slate-800 dark:text-slate-100"><%= phoneLabel || phone || '' %></p>
        </div>
      </div>
      <div class="flex items-center gap-3">
        <button id="walletThemeToggle" class="h-10 w-10 rounded-full bg-white/60 dark:bg-slate-900/60 flex items-center justify-center text-slate-600 dark:text-slate-200" aria-label="Toggle theme">
          <svg id="walletThemeToggleSun" xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 4.5v-2m0 19v-2m9-7h-2m-15 0H2m15.364 6.364-1.414-1.414M7.05 7.05 5.636 5.636m12.728 0-1.414 1.414M7.05 16.95 5.636 18.364M12 7.5A4.5 4.5 0 1 1 12 16.5 4.5 4.5 0 0 1 12 7.5Z" />
          </svg>
          <svg id="walletThemeToggleMoon" xmlns="http://www.w3.org/2000/svg" class="hidden h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M21 12.79A9 9 0 0 1 11.21 3 7.5 7.5 0 1 0 21 12.79Z" />
          </svg>
        </button>
        <a href="/client/profile" class="h-10 w-10 rounded-full bg-apple-blue text-white flex items-center justify-center font-semibold">P</a>
      </div>
    </div>
  </div>
</header>
