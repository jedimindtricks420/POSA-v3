<script>
  (function () {
    document.addEventListener('DOMContentLoaded', function () {
      // ========== DESKTOP DROPDOWNS (Hover-based) ==========
      const desktopDropdowns = document.querySelectorAll('.desktop-dropdown');
      let hideTimeout = null;

      desktopDropdowns.forEach(function (dropdown) {
        dropdown.addEventListener('mouseenter', function () {
          if (hideTimeout) {
            clearTimeout(hideTimeout);
            hideTimeout = null;
          }
          // Close all other menus first
          desktopDropdowns.forEach(function (other) {
            if (other !== dropdown) {
              const otherMenu = other.querySelector('.desktop-dropdown-menu');
              const otherArrow = other.querySelector('.dropdown-arrow');
              if (otherMenu) otherMenu.classList.add('hidden');
              if (otherArrow) otherArrow.classList.remove('rotate-180');
            }
          });
          // Show this menu
          const menu = dropdown.querySelector('.desktop-dropdown-menu');
          const arrow = dropdown.querySelector('.dropdown-arrow');
          if (menu) menu.classList.remove('hidden');
          if (arrow) arrow.classList.add('rotate-180');
        });

        dropdown.addEventListener('mouseleave', function () {
          const menu = dropdown.querySelector('.desktop-dropdown-menu');
          const arrow = dropdown.querySelector('.dropdown-arrow');
          hideTimeout = setTimeout(function () {
            if (menu) menu.classList.add('hidden');
            if (arrow) arrow.classList.remove('rotate-180');
          }, 150);
        });
      });

      // ========== MOBILE MENU ==========
      const mobileBtn = document.getElementById('adminMobileMenuBtn');
      const mobileMenu = document.getElementById('adminMobileMenu');

      if (mobileBtn && mobileMenu) {
        mobileBtn.addEventListener('click', function (e) {
          e.stopPropagation();
          mobileMenu.classList.toggle('hidden');
        });

        document.addEventListener('click', function (e) {
          if (!mobileBtn.contains(e.target) && !mobileMenu.contains(e.target)) {
            mobileMenu.classList.add('hidden');
          }
        });
      }

      // ========== MOBILE ACCORDIONS ==========
      document.querySelectorAll('.mobile-accordion-btn').forEach(function (button) {
        button.addEventListener('click', function (e) {
          e.preventDefault();
          e.stopPropagation();
          const accordion = this.closest('.mobile-accordion');
          const content = accordion.querySelector('.mobile-accordion-content');
          const icon = accordion.querySelector('.accordion-icon');
          if (content) content.classList.toggle('hidden');
          if (icon) icon.classList.toggle('rotate-180');
        });
      });
    });
  })();
</script>