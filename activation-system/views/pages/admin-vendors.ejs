<!DOCTYPE html>
<html lang="ru">

<head>
  <meta charset="UTF-8">
  <title>Вендоры | Admin Panel</title>
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <script src="https://cdn.tailwindcss.com"></script>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
  <link href="/css/admin.css" rel="stylesheet">
</head>

<body class="bg-slate-50 min-h-screen font-[Inter]">
  <%- include('../partials/admin-navbar', { user }) %>

    <% const statsData=stats || { totalVendors: 0, vendorOutstanding: 0, vendorPayoutAccrued: 0, vendorPayoutPaid: 0,
      platformRevenueShare: 0, totalTransactions: 0, totalSalesVolume: 0, averageTransactionValue: 0,
      averageVendorPayout: 0, averageVendorPayment: 0 }; %>
      <% const formatCurrency=(value)=> Number(value || 0).toLocaleString('ru-RU', { minimumFractionDigits: 2 }); %>

        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8 pt-20">
          <div class="md:flex md:items-center md:justify-between mb-8">
            <div>
              <h1 class="text-3xl font-bold tracking-tight text-slate-900">Вендоры и расчёты</h1>
              <p class="mt-2 text-sm text-slate-500">Следите за задолженностями платформы, выплатами и активностью
                вендоров</p>
            </div>
            <div>
              <a href="/admin/add-vendor"
                class="inline-flex items-center justify-center rounded-lg bg-indigo-600 px-4 py-2.5 text-sm font-semibold text-white shadow-sm transition hover:bg-indigo-500">
                <svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6v12m6-6H6" />
                </svg>
                Добавить вендора
              </a>
            </div>
          </div>

          <div class="grid grid-cols-1 gap-4 lg:grid-cols-4 mb-8">
            <div class="rounded-2xl bg-white p-5 shadow ring-1 ring-slate-100">
              <p class="text-sm font-medium text-slate-500">Задолженность перед вендорами</p>
              <p class="mt-2 text-3xl font-semibold text-emerald-600">
                <%= formatCurrency(statsData.vendorOutstanding) %>
              </p>
              <p class="text-xs uppercase tracking-widest text-slate-400">сум к выплате</p>
              <p class="mt-4 text-xs font-semibold text-slate-500">Всего вендоров: <span class="text-slate-900">
                  <%= statsData.totalVendors %>
                </span></p>
            </div>

            <div class="rounded-2xl bg-white p-5 shadow ring-1 ring-slate-100">
              <p class="text-sm font-medium text-slate-500">Начислено к выплате</p>
              <p class="mt-2 text-3xl font-semibold text-slate-900">
                <%= formatCurrency(statsData.vendorPayoutAccrued) %>
              </p>
              <p class="text-xs uppercase tracking-widest text-slate-400">сум</p>
              <p class="mt-4 text-sm text-slate-500">Средний на транзакцию: <span class="font-semibold text-slate-900">
                  <%= formatCurrency(statsData.averageVendorPayout) %>
                </span></p>
            </div>

            <div class="rounded-2xl bg-white p-5 shadow ring-1 ring-slate-100">
              <p class="text-sm font-medium text-slate-500">Выплачено вендорам</p>
              <p class="mt-2 text-3xl font-semibold text-indigo-600">
                <%= formatCurrency(statsData.vendorPayoutPaid) %>
              </p>
              <p class="text-xs uppercase tracking-widest text-slate-400">сум</p>
              <p class="mt-4 text-sm text-slate-500">Средний платеж: <span class="font-semibold text-slate-900">
                  <%= formatCurrency(statsData.averageVendorPayment) %>
                </span></p>
            </div>

            <div class="rounded-2xl bg-white p-5 shadow ring-1 ring-slate-100">
              <p class="text-sm font-medium text-slate-500">Доля платформы</p>
              <p class="mt-2 text-3xl font-semibold text-amber-600">
                <%= formatCurrency(statsData.platformRevenueShare) %>
              </p>
              <p class="text-xs uppercase tracking-widest text-slate-400">заработано сум</p>
              <p class="mt-4 text-sm text-slate-500">Транзакций: <span class="font-semibold text-slate-900">
                  <%= statsData.totalTransactions %>
                </span></p>
            </div>
          </div>

          <div class="grid grid-cols-1 gap-4 lg:grid-cols-3 mb-10">
            <div class="rounded-2xl bg-white p-4 shadow ring-1 ring-slate-100">
              <p class="text-xs uppercase tracking-wide text-slate-400">Оборот по продажам</p>
              <p class="mt-2 text-2xl font-semibold text-slate-900">
                <%= formatCurrency(statsData.totalSalesVolume) %> сум
              </p>
              <p class="text-sm text-slate-500">Средний чек: <span class="font-semibold text-slate-900">
                  <%= formatCurrency(statsData.averageTransactionValue) %>
                </span> сум</p>
            </div>
            <div class="rounded-2xl bg-white p-4 shadow ring-1 ring-slate-100">
              <p class="text-xs uppercase tracking-wide text-slate-400">Активные вендоры</p>
              <p class="mt-2 text-2xl font-semibold text-slate-900">
                <%= statsData.totalVendors %>
              </p>
              <p class="text-sm text-slate-500">Следите за задолженностями и статусами</p>
            </div>
            <div class="rounded-2xl bg-gradient-to-r from-indigo-500 to-blue-500 p-5 text-white shadow-lg">
              <p class="text-xs uppercase tracking-wide text-indigo-100">Контроль выплат</p>
              <p class="mt-3 text-2xl font-semibold">
                <%= formatCurrency(statsData.vendorOutstanding) %> сум
              </p>
              <p class="text-sm text-indigo-100">Планируйте выплаты и избегайте долгов</p>
            </div>
          </div>

          <div class="bg-white shadow ring-1 ring-slate-200 sm:rounded-2xl overflow-hidden">
            <% if (!vendors.length) { %>
              <div class="px-8 py-16 text-center">
                <svg class="mx-auto h-14 w-14 text-slate-300" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5"
                    d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16" />
                </svg>
                <h3 class="mt-4 text-base font-semibold text-slate-900">Вендоры отсутствуют</h3>
                <p class="mt-2 text-sm text-slate-500">Добавьте первого вендора, чтобы начать продажи.</p>
                <div class="mt-6">
                  <a href="/admin/add-vendor"
                    class="inline-flex items-center rounded-md bg-indigo-600 px-4 py-2 text-sm font-semibold text-white shadow-sm hover:bg-indigo-500">
                    <svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6v12m6-6H6" />
                    </svg>
                    Добавить вендора
                  </a>
                </div>
              </div>
              <% } else { %>
                <div class="px-6 py-4 border-b border-slate-200 flex items-center justify-between">
                  <div>
                    <h2 class="text-lg font-semibold text-slate-900">Список вендоров</h2>
                    <p class="text-sm text-slate-500">Баланс и типы продуктов для каждого партнёра</p>
                  </div>
                  <span class="rounded-full bg-slate-100 px-3 py-1 text-xs font-semibold text-slate-600">Всего: <%=
                      statsData.totalVendors %></span>
                </div>
                <div class="overflow-x-auto">
                  <table class="min-w-full divide-y divide-slate-200 text-sm">
                    <thead class="bg-slate-50 text-left text-xs font-semibold uppercase tracking-wide text-slate-500">
                      <tr>
                        <th class="py-3.5 pl-6 pr-3">ID</th>
                        <th class="px-3 py-3.5">Название</th>
                        <th class="px-3 py-3.5">Категория</th>
                        <th class="px-3 py-3.5">Тип товаров</th>
                        <th class="px-3 py-3.5">Описание</th>
                        <th class="px-3 py-3.5 text-right">К выплате</th>
                        <th class="py-3.5 pl-3 pr-6 text-right">Действия</th>
                      </tr>
                    </thead>
                    <tbody class="divide-y divide-slate-200 bg-white">
                      <% vendors.forEach(vendor=> { %>
                        <tr class="hover:bg-slate-50 transition">
                          <td class="whitespace-nowrap py-4 pl-6 pr-3 font-semibold text-slate-900">#<%= vendor.id %>
                          </td>
                          <td class="whitespace-nowrap px-3 py-4">
                            <div class="font-semibold text-slate-900">
                              <%= vendor.name %>
                            </div>
                            <div class="text-xs text-slate-500">Комиссия: <%= vendor.defaultCommissionPercent %>%</div>
                          </td>
                          <td class="whitespace-nowrap px-3 py-4">
                            <span
                              class="inline-flex items-center rounded-full bg-blue-50 px-3 py-1 text-xs font-medium text-blue-700 ring-1 ring-inset ring-blue-600/10">
                              <%= vendor.category %>
                            </span>
                          </td>
                          <td class="whitespace-nowrap px-3 py-4">
                            <% let productTypeLabel=vendor.productType; if (productTypeLabel==='ROKKY' )
                              productTypeLabel='Rokky (авто)' ; else if (productTypeLabel==='DRWEB' )
                              productTypeLabel='Dr.Web (авто)' ; else if (productTypeLabel==='MANASTORE' )
                              productTypeLabel='ManaStore (авто)' ; else if (productTypeLabel==='MANUAL' )
                              productTypeLabel='Manual' ; else if (productTypeLabel==='VOUCHER' )
                              productTypeLabel='Ваучеры' ; %>
                              <span
                                class="inline-flex items-center rounded-full bg-purple-50 px-3 py-1 text-xs font-medium text-purple-700 ring-1 ring-inset ring-purple-600/10">
                                <%= productTypeLabel %>
                              </span>
                          </td>
                          <td class="px-3 py-4 text-slate-600">
                            <%= vendor.description || '—' %>
                          </td>
                          <td class="whitespace-nowrap px-3 py-4 text-right">
                            <div
                              class="font-mono font-semibold <%= vendor.balance > 0 ? 'text-rose-600' : 'text-slate-600' %>">
                              <%= Number(vendor.balance || 0).toLocaleString('ru-RU') %>
                            </div>
                            <div class="text-xs text-slate-500">сум</div>
                          </td>
                          <td class="whitespace-nowrap py-4 pl-3 pr-6 text-right">
                            <div class="flex flex-wrap justify-end gap-2">
                              <a href="/admin/vendors/edit/<%= vendor.id %>"
                                class="inline-flex items-center rounded-md bg-slate-50 px-2.5 py-1 text-xs font-semibold text-slate-600 ring-1 ring-inset ring-slate-500/10 hover:bg-slate-100">Изменить</a>
                              <a href="/admin/vendor/<%= vendor.id %>/pay"
                                class="inline-flex items-center rounded-md bg-green-50 px-2.5 py-1 text-xs font-semibold text-green-700 ring-1 ring-inset ring-green-600/10 hover:bg-green-100">Оплатить</a>
                              <a href="/admin/vendor/<%= vendor.id %>/transactions"
                                class="inline-flex items-center rounded-md bg-indigo-50 px-2.5 py-1 text-xs font-semibold text-indigo-700 ring-1 ring-inset ring-indigo-600/10 hover:bg-indigo-100">История</a>
                            </div>
                          </td>
                        </tr>
                        <% }) %>
                    </tbody>
                  </table>
                </div>
                <% } %>
          </div>
        </div>
</body>

</html>