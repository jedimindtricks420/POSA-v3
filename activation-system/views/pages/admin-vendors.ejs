<!DOCTYPE html>
<html lang="ru">

<head>
  <meta charset="UTF-8">
  <title>Список вендоров</title>
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <script src="https://cdn.tailwindcss.com"></script>
  <link href="/css/admin.css" rel="stylesheet">
</head>

<body class="bg-slate-50 min-h-screen">
  <%- include('../partials/admin-navbar', { user }) %>

    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8 pt-20">
      <div class="md:flex md:items-center md:justify-between mb-6">
        <div class="min-w-0 flex-1">
          <h2 class="text-2xl font-bold leading-7 text-slate-900 sm:truncate sm:text-3xl sm:tracking-tight">
            Список вендоров
          </h2>
          <p class="mt-1 text-sm text-slate-500">
            Управление вендорами, их балансами и транзакциями
          </p>
        </div>
        <div class="mt-4 flex md:ml-4 md:mt-0">
          <a href="/admin/add-vendor"
            class="inline-flex items-center rounded-md bg-indigo-600 px-3 py-2 text-sm font-semibold text-white shadow-sm hover:bg-indigo-700 focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:ring-offset-2 transition-colors duration-200">
            <svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6v6m0 0v6m0-6h6m-6 0H6" />
            </svg>
            Добавить вендора
          </a>
        </div>
      </div>
      <div class="bg-white shadow-sm ring-1 ring-slate-200 sm:rounded-lg overflow-x-auto">
        <table class="min-w-full divide-y divide-slate-200">
          <thead>
            <tr>
              <th scope="col" class="py-3.5 pl-4 pr-3 text-left text-sm font-semibold text-slate-900 sm:pl-6">ID</th>
              <th scope="col" class="px-3 py-3.5 text-left text-sm font-semibold text-slate-900">Название</th>
              <th scope="col" class="px-3 py-3.5 text-left text-sm font-semibold text-slate-900">Категория</th>
              <th scope="col" class="px-3 py-3.5 text-left text-sm font-semibold text-slate-900">Тип товаров</th>
              <th scope="col" class="px-3 py-3.5 text-left text-sm font-semibold text-slate-900">Описание</th>
              <th scope="col" class="px-3 py-3.5 text-right text-sm font-semibold text-slate-900">Задолженность</th>
              <th scope="col" class="relative py-3.5 pl-3 pr-4 sm:pr-6">
                <span class="sr-only">Действия</span>
              </th>
            </tr>
          </thead>
          <tbody class="divide-y divide-slate-200 bg-white">
            <% vendors.forEach(vendor=> { %>
              <tr class="hover:bg-slate-50 transition-colors duration-150">
                <td class="whitespace-nowrap py-4 pl-4 pr-3 text-sm font-medium text-slate-900 sm:pl-6">
                  <%= vendor.id %>
                </td>
                <td class="whitespace-nowrap px-3 py-4 text-sm text-slate-900 font-medium">
                  <%= vendor.name %>
                </td>
                <td class="whitespace-nowrap px-3 py-4 text-sm text-slate-600">
                  <span
                    class="inline-flex items-center rounded-md bg-blue-50 px-2 py-1 text-xs font-medium text-blue-700 ring-1 ring-inset ring-blue-700/10">
                    <%= vendor.category %>
                  </span>
                </td>
                <td class="whitespace-nowrap px-3 py-4 text-sm text-slate-600">
                  <span
                    class="inline-flex items-center rounded-md bg-purple-50 px-2 py-1 text-xs font-medium text-purple-700 ring-1 ring-inset ring-purple-700/10">
                    <% let productTypeLabel=vendor.productType; if (vendor.productType==='ROKKY' )
                      productTypeLabel='Rokky (автоматическая)' ; else if (vendor.productType==='MANUAL' )
                      productTypeLabel='Manual (ручная)' ; else if (vendor.productType==='VOUCHER' )
                      productTypeLabel='Ваучеры' ; %>
                      <%= productTypeLabel %>
                  </span>
                </td>
                <td class="whitespace-nowrap px-3 py-4 text-sm text-slate-600">
                  <%= vendor.description || '—' %>
                </td>
                <td class="whitespace-nowrap px-3 py-4 text-sm text-right">
                  <span class="font-mono font-medium text-slate-900">
                    <%= Number(vendor.balance).toLocaleString('ru-RU') %>
                  </span>
                  <span class="ml-1 text-xs text-slate-500">сум</span>
                </td>
                <td class="relative whitespace-nowrap py-4 pl-3 pr-4 text-right text-sm font-medium sm:pr-6 space-x-2">
                  <a href="/admin/vendors/edit/<%= vendor.id %>"
                    class="inline-flex items-center rounded-md bg-slate-50 px-2 py-1 text-xs font-semibold text-slate-600 ring-1 ring-inset ring-slate-500/10 hover:bg-slate-100 hover:text-slate-700 transition-colors duration-150">
                    <svg class="w-3.5 h-3.5 mr-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                        d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z" />
                    </svg>
                    Изменить
                  </a>
                  <a href="/admin/vendor/<%= vendor.id %>/pay"
                    class="inline-flex items-center rounded-md bg-green-50 px-2 py-1 text-xs font-semibold text-green-700 ring-1 ring-inset ring-green-600/10 hover:bg-green-100 transition-colors duration-150">
                    <svg class="w-3.5 h-3.5 mr-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                        d="M12 6v6m0 0v6m0-6h6m-6 0H6" />
                    </svg>
                    Пополнить
                  </a>
                  <a href="/admin/vendor/<%= vendor.id %>/transactions"
                    class="inline-flex items-center rounded-md bg-indigo-50 px-2 py-1 text-xs font-semibold text-indigo-700 ring-1 ring-inset ring-indigo-700/10 hover:bg-indigo-100 transition-colors duration-150">
                    <svg class="w-3.5 h-3.5 mr-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                        d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2" />
                    </svg>
                    История
                  </a>
                </td>
              </tr>
              <% }) %>
          </tbody>
        </table>
        <% if (vendors.length===0) { %>
          <div class="text-center py-12">
            <svg class="mx-auto h-12 w-12 text-slate-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1"
                d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4" />
            </svg>
            <h3 class="mt-2 text-sm font-semibold text-slate-900">Нет вендоров</h3>
            <p class="mt-1 text-sm text-slate-500">Начните с добавления нового вендора.</p>
            <div class="mt-6">
              <a href="/admin/add-vendor"
                class="inline-flex items-center rounded-md bg-indigo-600 px-3 py-2 text-sm font-semibold text-white shadow-sm hover:bg-indigo-700 focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:ring-offset-2">
                <svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                    d="M12 6v6m0 0v6m0-6h6m-6 0H6" />
                </svg>
                Добавить вендора
              </a>
            </div>
          </div>
          <% } %>
      </div>
    </div>
</body>

</html>