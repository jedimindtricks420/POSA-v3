<!DOCTYPE html>
<html lang="ru">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <meta name="theme-color" content="#007AFF">
    <title>Профиль</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="manifest" href="/manifest.json">
    <script>
        tailwind.config = {
            theme: {
                extend: {
                    colors: {
                        'apple-blue': '#007AFF',
                    },
                    fontFamily: {
                        sans: ['-apple-system', 'BlinkMacSystemFont', 'Segoe UI', 'Roboto', 'Helvetica Neue', 'Arial', 'sans-serif'],
                    },
                }
            }
        }
    </script>
</head>
<body class="bg-gray-100 min-h-screen font-sans antialiased pb-20">
    <div class="max-w-md mx-auto px-4 py-8">
        <!-- Header -->
        <div class="text-center mb-8">
            <div class="w-20 h-20 bg-apple-blue rounded-full flex items-center justify-center mx-auto mb-4">
                <span class="text-3xl text-white">👤</span>
            </div>
            <h2 class="text-2xl font-semibold text-gray-900">Профиль</h2>
            <p class="text-gray-600 mt-2"><%= phone %></p>
        </div>

        <!-- Profile Actions -->
        <div class="space-y-4">
            <!-- Account Info -->
            <div class="bg-white rounded-2xl shadow-md">
                <div class="p-4 border-b border-gray-100">
                    <h3 class="text-lg font-semibold text-gray-900">Аккаунт</h3>
                </div>
                <div class="p-4 space-y-3">
                    <div class="flex items-center justify-between py-2">
                        <div class="flex items-center">
                            <span class="text-xl mr-3">📱</span>
                            <span class="text-gray-700">Телефон</span>
                        </div>
                        <span class="text-gray-500"><%= phone %></span>
                    </div>
                    <div class="flex items-center justify-between py-2">
                        <div class="flex items-center">
                            <span class="text-xl mr-3">💳</span>
                            <span class="text-gray-700">Ваучеры</span>
                        </div>
                        <span class="text-gray-500">Активные</span>
                    </div>
                </div>
            </div>

            <!-- Settings -->
            <div class="bg-white rounded-2xl shadow-md">
                <div class="p-4 border-b border-gray-100">
                    <h3 class="text-lg font-semibold text-gray-900">Настройки</h3>
                </div>
                <div class="p-4 space-y-3">
                    <button class="flex items-center justify-between w-full py-2 text-left">
                        <div class="flex items-center">
                            <span class="text-xl mr-3">🔔</span>
                            <span class="text-gray-700">Уведомления</span>
                        </div>
                        <span class="text-gray-400">›</span>
                    </button>
                    <button class="flex items-center justify-between w-full py-2 text-left">
                        <div class="flex items-center">
                            <span class="text-xl mr-3">🌙</span>
                            <span class="text-gray-700">Тёмная тема</span>
                        </div>
                        <span class="text-gray-400">›</span>
                    </button>
                    <button class="flex items-center justify-between w-full py-2 text-left">
                        <div class="flex items-center">
                            <span class="text-xl mr-3">🔒</span>
                            <span class="text-gray-700">Безопасность</span>
                        </div>
                        <span class="text-gray-400">›</span>
                    </button>
                </div>
            </div>

            <!-- Support -->
            <div class="bg-white rounded-2xl shadow-md">
                <div class="p-4 border-b border-gray-100">
                    <h3 class="text-lg font-semibold text-gray-900">Поддержка</h3>
                </div>
                <div class="p-4 space-y-3">
                    <button class="flex items-center justify-between w-full py-2 text-left">
                        <div class="flex items-center">
                            <span class="text-xl mr-3">❓</span>
                            <span class="text-gray-700">Помощь</span>
                        </div>
                        <span class="text-gray-400">›</span>
                    </button>
                    <button class="flex items-center justify-between w-full py-2 text-left">
                        <div class="flex items-center">
                            <span class="text-xl mr-3">📞</span>
                            <span class="text-gray-700">Связаться с нами</span>
                        </div>
                        <span class="text-gray-400">›</span>
                    </button>
                </div>
            </div>

            <!-- Logout -->
            <a href="/client/logout" 
               class="block w-full mt-8 bg-red-500 hover:bg-red-600 text-white font-semibold py-3 px-6 rounded-lg transition-colors duration-200 shadow-md hover:shadow-lg text-center">
                Выйти из аккаунта
            </a>
        </div>
    </div>

    <!-- Bottom Navigation -->
    <div class="fixed bottom-0 left-0 right-0 bg-white border-t border-gray-200 shadow-lg">
        <div class="max-w-md mx-auto px-4">
            <div class="flex justify-around py-2">
                <!-- Wallet Button -->
                <a href="/client/dashboard" class="flex flex-col items-center py-2 px-4 text-gray-400 hover:text-apple-blue transition-colors">
                    <svg class="w-6 h-6 mb-1" fill="currentColor" viewBox="0 0 24 24">
                        <path d="M21 18v1c0 1.1-.9 2-2 2H5c-1.11 0-2-.9-2-2V5c0-1.1.89-2 2-2h14c1.1 0 2 .9 2 2v1h-9c-1.11 0-2 .9-2 2v8c0 1.1.89 2 2 2h9zm-9-2h10V8H12v8zm4-2.5c-.83 0-1.5-.67-1.5-1.5s.67-1.5 1.5-1.5 1.5.67 1.5 1.5-.67 1.5-1.5 1.5z"/>
                    </svg>
                    <span class="text-xs">Кошелёк</span>
                </a>

                <!-- QR Scanner Button -->
                <a href="/client/qr-scanner" class="flex flex-col items-center py-2 px-4 text-gray-400 hover:text-apple-blue transition-colors">
                    <div class="w-12 h-12 bg-apple-blue rounded-full flex items-center justify-center mb-1 shadow-lg">
                        <svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"/>
                        </svg>
                    </div>
                    <span class="text-xs">Сканер</span>
                </a>

                <!-- Profile Button -->
                <a href="/client/profile" class="flex flex-col items-center py-2 px-4 text-apple-blue transition-colors">
                    <svg class="w-6 h-6 mb-1" fill="currentColor" viewBox="0 0 24 24">
                        <path d="M12 12c2.21 0 4-1.79 4-4s-1.79-4-4-4-4 1.79-4 4 1.79 4 4 4zm0 2c-2.67 0-8 1.34-8 4v2h16v-2c0-2.66-5.33-4-8-4z"/>
                    </svg>
                    <span class="text-xs">Профиль</span>
                </a>
            </div>
        </div>
    </div>

    <script>
        // PWA Service Worker Registration
        if ('serviceWorker' in navigator) {
            navigator.serviceWorker.register('/sw.js')
                .then(registration => console.log('ServiceWorker registered'))
                .catch(err => console.log('ServiceWorker registration failed: ', err));
        }
    </script>
</body>
</html>
