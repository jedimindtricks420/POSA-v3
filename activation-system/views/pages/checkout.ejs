<!DOCTYPE html>
<html lang="ru">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Чек продажи</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="/css/admin.css" rel="stylesheet">
</head>
<body class="bg-slate-50 min-h-screen">
    <%- include('../partials/merchant-navbar', { user }) %>

    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-8 pt-20">
        <div class="mb-6">
            <h2 class="text-3xl font-bold text-slate-900 mb-2">🧾 Чек продажи</h2>
            <p class="text-slate-600">Проверьте детали заказа и выберите тип продажи</p>
        </div>

        <% if (items.length === 0) { %>
            <div class="bg-amber-50 border border-amber-200 rounded-lg p-6 text-center">
                <div class="text-amber-800 mb-4">
                    <svg class="h-12 w-12 mx-auto mb-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-2.5L13.732 4c-.77-.833-1.732-.833-2.5 0L4.314 15.5c-.77.833.192 2.5 1.732 2.5z"/>
                    </svg>
                    <h3 class="text-lg font-medium">Корзина пуста</h3>
                    <p class="text-sm mt-1">Добавьте товары в корзину перед оформлением заказа</p>
                </div>
                <a href="/merchant/sell" class="inline-flex items-center px-4 py-2 bg-blue-600 text-white rounded-lg hover:bg-blue-700 transition-colors">
                    <svg class="h-4 w-4 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18"/>
                    </svg>
                    Вернуться к товарам
                </a>
            </div>
        <% } else { %>
            <form method="POST" action="/merchant/checkout/confirm" class="space-y-6">
                <!-- Тип продажи -->
                <div class="bg-white rounded-lg shadow-sm border border-slate-200 p-6">
                    <h3 class="text-lg font-semibold text-slate-900 mb-4">Тип продажи</h3>
                    <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
                        <!-- Оффлайн продажа -->
                        <label class="relative cursor-pointer">
                            <input type="radio" name="saleType" value="OFFLINE" class="sr-only peer" checked>
                            <div class="bg-white border-2 border-slate-200 rounded-lg p-4 peer-checked:border-blue-500 peer-checked:ring-2 peer-checked:ring-blue-100 transition-all hover:border-slate-300">
                                <div class="flex items-center">
                                    <div class="flex-shrink-0 bg-slate-100 rounded-full p-2 peer-checked:bg-blue-100">
                                        <svg class="h-5 w-5 text-slate-600 peer-checked:text-blue-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4"/>
                                        </svg>
                                    </div>
                                    <div class="ml-3">
                                        <h4 class="font-medium text-slate-900">Оффлайн продажа</h4>
                                        <p class="text-sm text-slate-500">Печать физического ваучера</p>
                                    </div>
                                </div>
                            </div>
                        </label>

                        <!-- Онлайн продажа -->
                        <label class="relative cursor-pointer">
                            <input type="radio" name="saleType" value="ONLINE" class="sr-only peer">
                            <div class="bg-white border-2 border-slate-200 rounded-lg p-4 peer-checked:border-green-500 peer-checked:ring-2 peer-checked:ring-green-100 transition-all hover:border-slate-300">
                                <div class="flex items-center">
                                    <div class="flex-shrink-0 bg-slate-100 rounded-full p-2 peer-checked:bg-green-100">
                                        <svg class="h-5 w-5 text-slate-600 peer-checked:text-green-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 18h.01M8 21h8a2 2 0 002-2V5a2 2 0 00-2-2H8a2 2 0 00-2 2v14a2 2 0 002 2z"/>
                                        </svg>
                                    </div>
                                    <div class="ml-3">
                                        <h4 class="font-medium text-slate-900">Онлайн продажа</h4>
                                        <p class="text-sm text-slate-500">Отправка SMS с ваучером</p>
                                    </div>
                                </div>
                            </div>
                        </label>
                    </div>
                </div>

                <!-- Номер телефона (показывается только для онлайн) -->
                <div id="phoneSection" class="bg-white rounded-lg shadow-sm border border-slate-200 p-6 hidden">
                    <h3 class="text-lg font-semibold text-slate-900 mb-4">Номер телефона клиента</h3>
                    <div class="max-w-md">
                        <label for="customerPhone" class="block text-sm font-medium text-slate-700 mb-2">
                            Введите номер телефона
                        </label>
                        <div class="relative">
                            <div class="absolute inset-y-0 left-0 pl-3 flex items-center pointer-events-none">
                                <svg class="h-5 w-5 text-slate-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/>
                                </svg>
                            </div>
                            <input 
                                type="tel" 
                                name="customerPhone" 
                                id="customerPhone"
                                class="block w-full pl-10 pr-3 py-2 border border-slate-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-blue-500 sm:text-sm"
                                placeholder="+998901234567"
                                pattern="^\+998[0-9]{9}$"
                            >
                        </div>
                        <p class="mt-2 text-sm text-slate-500">
                            Формат: +998XXXXXXXXX (например, +998901234567)
                        </p>
                    </div>
                </div>

                <!-- Товары в корзине -->
                <div class="bg-white rounded-lg shadow-sm border border-slate-200 overflow-hidden">
                    <div class="px-6 py-4 border-b border-slate-200">
                        <h3 class="text-lg font-semibold text-slate-900">Товары в заказе</h3>
                    </div>
                    <div class="overflow-x-auto">
                        <table class="min-w-full divide-y divide-slate-200">
                            <thead class="bg-slate-50">
                                <tr>
                                    <th class="px-6 py-3 text-left text-xs font-medium text-slate-500 uppercase tracking-wider">Товар</th>
                                    <th class="px-6 py-3 text-left text-xs font-medium text-slate-500 uppercase tracking-wider">Цена</th>
                                    <th class="px-6 py-3 text-left text-xs font-medium text-slate-500 uppercase tracking-wider">Количество</th>
                                    <th class="px-6 py-3 text-left text-xs font-medium text-slate-500 uppercase tracking-wider">Сумма</th>
                                    <th class="px-6 py-3 text-left text-xs font-medium text-slate-500 uppercase tracking-wider">Действие</th>
                                </tr>
                            </thead>
                            <tbody class="bg-white divide-y divide-slate-200">
                                <% items.forEach(item => { %>
                                    <tr class="hover:bg-slate-50">
                                        <td class="px-6 py-4 whitespace-nowrap">
                                            <div class="text-sm font-medium text-slate-900"><%= item.name %></div>
                                        </td>
                                        <td class="px-6 py-4 whitespace-nowrap">
                                            <div class="text-sm text-slate-900"><%= item.price.toLocaleString('ru-RU') %> сум</div>
                                        </td>
                                        <td class="px-6 py-4 whitespace-nowrap">
                                            <input 
                                                type="number" 
                                                name="quantities[<%= item.id %>]" 
                                                value="<%= item.quantity %>" 
                                                min="1" 
                                                class="w-20 px-2 py-1 border border-slate-300 rounded focus:ring-2 focus:ring-blue-500 focus:border-blue-500 text-sm"
                                            >
                                        </td>
                                        <td class="px-6 py-4 whitespace-nowrap">
                                            <div class="text-sm font-medium text-slate-900"><%= (item.price * item.quantity).toLocaleString('ru-RU') %> сум</div>
                                        </td>
                                        <td class="px-6 py-4 whitespace-nowrap">
                                            <a href="/merchant/cart/remove/<%= item.id %>" class="inline-flex items-center px-3 py-1 bg-red-100 text-red-700 text-sm rounded-full hover:bg-red-200 transition-colors">
                                                <svg class="h-4 w-4 mr-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"/>
                                                </svg>
                                                Удалить
                                            </a>
                                        </td>
                                    </tr>
                                <% }) %>
                            </tbody>
                        </table>
                    </div>
                </div>

                <!-- Итого -->
                <div class="bg-white rounded-lg shadow-sm border border-slate-200 p-6">
                    <div class="flex justify-between items-center text-xl font-bold text-slate-900">
                        <span>Итого к оплате:</span>
                        <span><%= totalPrice.toLocaleString('ru-RU') %> сум</span>
                    </div>
                </div>

                <!-- Кнопки действий -->
                <div class="flex flex-col sm:flex-row gap-4 justify-end">
                    <a href="/merchant/sell" class="inline-flex items-center justify-center px-6 py-3 border border-slate-300 text-base font-medium rounded-lg text-slate-700 bg-white hover:bg-slate-50 transition-colors">
                        <svg class="h-5 w-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18"/>
                        </svg>
                        Добавить товары
                    </a>
                    <button type="submit" class="inline-flex items-center justify-center px-6 py-3 border border-transparent text-base font-medium rounded-lg text-white bg-green-600 hover:bg-green-700 focus:ring-2 focus:ring-green-500 focus:ring-offset-2 transition-colors">
                        <svg class="h-5 w-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/>
                        </svg>
                        Подтвердить продажу
                    </button>
                </div>
            </form>
        <% } %>
    </div>

    <script>
        // Показ/скрытие поля телефона в зависимости от типа продажи
        const saleTypeRadios = document.querySelectorAll('input[name="saleType"]');
        const phoneSection = document.getElementById('phoneSection');
        const phoneInput = document.getElementById('customerPhone');

        function togglePhoneSection() {
            const selectedType = document.querySelector('input[name="saleType"]:checked').value;
            if (selectedType === 'ONLINE') {
                phoneSection.classList.remove('hidden');
                phoneInput.setAttribute('required', '');
            } else {
                phoneSection.classList.add('hidden');
                phoneInput.removeAttribute('required');
                phoneInput.value = '';
            }
        }

        saleTypeRadios.forEach(radio => {
            radio.addEventListener('change', togglePhoneSection);
        });

        // Инициализация
        togglePhoneSection();

        // Валидация формы
        document.querySelector('form').addEventListener('submit', function(e) {
            const selectedType = document.querySelector('input[name="saleType"]:checked').value;
            if (selectedType === 'ONLINE') {
                const phone = phoneInput.value.trim();
                if (!phone.match(/^\+998[0-9]{9}$/)) {
                    e.preventDefault();
                    alert('Пожалуйста, введите корректный номер телефона в формате +998XXXXXXXXX');
                    phoneInput.focus();
                    return false;
                }
            }
        });
    </script>
</body>
</html>
