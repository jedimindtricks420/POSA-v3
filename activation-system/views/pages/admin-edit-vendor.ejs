<!DOCTYPE html>
<html lang="ru">
<head>
  <meta charset="UTF-8">
  <title>Редактирование вендора - <%= vendor.name %></title>
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <script src="https://cdn.tailwindcss.com"></script>
  <link href="/css/admin.css" rel="stylesheet">
</head>
<body class="bg-slate-50 min-h-screen">
  <%- include('../partials/admin-navbar') %>
  
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8 pt-20">
    <div class="md:flex md:items-center md:justify-between mb-6">
      <div class="min-w-0 flex-1">
        <h2 class="text-2xl font-bold leading-7 text-slate-900 sm:truncate sm:text-3xl sm:tracking-tight">
          Редактирование вендора
        </h2>
        <p class="mt-1 text-sm text-slate-500">
          <%= vendor.name %>
        </p>
      </div>
      <div class="mt-4 flex md:ml-4 md:mt-0">
        <a href="/admin/vendors" 
          class="inline-flex items-center rounded-md bg-white px-3 py-2 text-sm font-semibold text-slate-900 shadow-sm ring-1 ring-inset ring-slate-300 hover:bg-slate-50 transition-colors duration-200">
          <svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 17l-5-5m0 0l5-5m-5 5h12"/>
          </svg>
          К списку вендоров
        </a>
      </div>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-2 gap-6">
      <!-- Левая часть: форма -->
      <div>
        <form method="POST" action="/admin/vendors/edit/<%= vendor.id %>" class="bg-white shadow-sm ring-1 ring-slate-200 rounded-lg p-6">
          <div class="space-y-6">
            <div>
              <label class="block text-sm font-medium text-slate-700">Название</label>
              <div class="mt-1">
                <input type="text" name="name" value="<%= vendor.name %>" required
                  class="block w-full rounded-md border-slate-300 shadow-sm focus:border-indigo-500 focus:ring-indigo-500 sm:text-sm" />
              </div>
            </div>

            <div>
              <label class="block text-sm font-medium text-slate-700">Категория</label>
              <div class="mt-1">
                <input type="text" name="category" value="<%= vendor.category %>" required
                  class="block w-full rounded-md border-slate-300 shadow-sm focus:border-indigo-500 focus:ring-indigo-500 sm:text-sm" />
              </div>
            </div>

            <div>
              <label class="block text-sm font-medium text-slate-700">Тип товаров</label>
              <div class="mt-1">
                <input type="text" name="productType" value="<%= vendor.productType %>" required
                  class="block w-full rounded-md border-slate-300 shadow-sm focus:border-indigo-500 focus:ring-indigo-500 sm:text-sm" />
              </div>
            </div>

            <div>
              <label class="block text-sm font-medium text-slate-700">Описание</label>
              <div class="mt-1">
                <textarea name="description" rows="3"
                  class="block w-full rounded-md border-slate-300 shadow-sm focus:border-indigo-500 focus:ring-indigo-500 sm:text-sm"><%= vendor.description %></textarea>
              </div>
            </div>

            <div>
              <label class="block text-sm font-medium text-slate-700">Комиссия вендора (%)</label>
              <div class="mt-1">
                <input type="number" step="0.1" min="0" max="100" name="defaultCommissionPercent" 
                  value="<%= vendor.defaultCommissionPercent %>" required
                  class="block w-full rounded-md border-slate-300 shadow-sm focus:border-indigo-500 focus:ring-indigo-500 sm:text-sm" />
              </div>
            </div>

            <div>
              <label class="block text-sm font-medium text-slate-700">Шаблон чека (HTML)</label>
              <div class="mt-1">
                <textarea id="receiptTemplate" name="receiptTemplate" rows="12"
                  class="font-mono block w-full rounded-md border-slate-300 shadow-sm focus:border-indigo-500 focus:ring-indigo-500 sm:text-sm"><%= vendor.receiptTemplate || `ВАУЧЕР: {{voucher}}
ТОВАР: {{product}}
ДАТА: {{date}}
ПРОДАВЕЦ: {{merchant}}
ЦЕНА: {{price}} сум

Спасибо за покупку!` %></textarea>
              </div>
            </div>

            <div class="pt-4">
              <button type="submit"
                class="w-full inline-flex justify-center items-center rounded-md bg-indigo-600 px-4 py-2.5 text-sm font-semibold text-white shadow-sm hover:bg-indigo-500 focus:outline-none focus:ring-2 focus:ring-indigo-600 focus:ring-offset-2">
                <svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
                </svg>
                Сохранить изменения
              </button>
            </div>
          </div>
        </form>
      </div>

      <!-- Правая часть: превью -->
      <div>
        <div class="bg-white shadow-sm ring-1 ring-slate-200 rounded-lg p-6">
          <h3 class="text-lg font-medium leading-6 text-slate-900 mb-4">Предпросмотр чека</h3>
          <div id="preview" class="font-mono bg-slate-50 border border-slate-200 rounded-md p-4 mb-4" style="min-height: 350px;"></div>
          <div class="rounded-md bg-blue-50 p-4">
            <div class="flex">
              <div class="flex-shrink-0">
                <svg class="h-5 w-5 text-blue-400" viewBox="0 0 20 20" fill="currentColor">
                  <path fill-rule="evenodd" d="M18 10a8 8 0 11-16 0 8 8 0 0116 0zm-7-4a1 1 0 11-2 0 1 1 0 012 0zM9 9a1 1 0 000 2v3a1 1 0 001 1h1a1 1 0 100-2v-3a1 1 0 00-1-1H9z" clip-rule="evenodd" />
                </svg>
              </div>
              <div class="ml-3">
                <h3 class="text-sm font-medium text-blue-800">Доступные переменные</h3>
                <div class="mt-2 text-sm text-blue-700">
                  <code class="font-mono">{{voucher}}</code>, <code class="font-mono">{{product}}</code>, 
                  <code class="font-mono">{{date}}</code>, <code class="font-mono">{{merchant}}</code>, 
                  <code class="font-mono">{{price}}</code>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>

  <script>
    const textarea = document.getElementById('receiptTemplate');
    const preview = document.getElementById('preview');

    const placeholderData = {
      "{{voucher}}": "TEST-CODE-123",
      "{{date}}": new Date().toLocaleString(),
      "{{product}}": "Пример товара",
      "{{merchant}}": "merchant_username",
      "{{price}}": "10000",
    };

    function applyTemplate(template, data) {
      return template.replace(/{{(.*?)}}/g, (_, key) => {
        return data[`{{${key.trim()}}}`] || '';
      });
    }

    function updatePreview() {
      const html = textarea.value;
      preview.innerHTML = applyTemplate(html, placeholderData);
    }

    textarea.addEventListener('input', updatePreview);
    window.addEventListener('DOMContentLoaded', updatePreview);
  </script>
</body>
</html>
