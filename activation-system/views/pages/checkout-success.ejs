<!DOCTYPE html>
<html lang="ru">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Продажа завершена</title>
  <script src="https://cdn.tailwindcss.com"></script>
  <link rel="stylesheet" href="/css/admin.css" />
</head>
<body class="bg-slate-100 min-h-screen text-slate-800">
  <%- include('../partials/merchant-navbar', { user }) %>

  <% const hasItems = Array.isArray(items) && items.length > 0; %>
  <% const totalSum = hasItems ? items.reduce((sum, item) => sum + (item.price || 0), 0) : 0; %>

  <main class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 pt-24 pb-16 space-y-8">
    <section class="rounded-2xl border border-slate-200 bg-white shadow-sm">
      <div class="px-6 py-8 text-center">
        <div class="mx-auto flex h-16 w-16 items-center justify-center rounded-full bg-green-100 text-green-600">
          <svg class="h-8 w-8" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
          </svg>
        </div>
        <h1 class="mt-6 text-2xl font-bold text-slate-900">Продажа успешно завершена</h1>
        <p class="mt-2 text-sm text-slate-500">Сохраните чек, передайте его клиенту и переходите к следующим продажам.</p>
      </div>

      <% if (!hasItems) { %>
        <div class="border-t border-slate-200 px-6 py-8 text-center text-sm text-slate-500">
          Нет проданных позиций. Вы можете начать новую продажу.
        </div>
      <% } else { %>
        <div class="border-t border-slate-200">
          <div class="overflow-x-auto">
            <table class="min-w-full divide-y divide-slate-200 text-sm">
              <thead class="bg-slate-50 text-left font-semibold uppercase tracking-wide text-xs text-slate-500">
                <tr>
                  <th class="px-6 py-3">#</th>
                  <th class="px-6 py-3">Товар</th>
                  <th class="px-6 py-3">Ваучер</th>
                  <th class="px-6 py-3 text-right">Сумма</th>
                </tr>
              </thead>
              <tbody class="divide-y divide-slate-100 bg-white">
                <% items.forEach((item, index) => { %>
                  <tr>
                    <td class="px-6 py-4 text-slate-500"><%= index + 1 %></td>
                    <td class="px-6 py-4">
                      <p class="font-semibold text-slate-900"><%= item.product?.name || 'Продукт' %></p>
                      <p class="text-xs text-slate-400 mt-1">ID: <span class="font-mono">#<%= item.product?.id || '—' %></span></p>
                    </td>
                    <td class="px-6 py-4">
                      <code class="rounded-md bg-slate-100 px-2 py-1 text-xs font-mono text-slate-700"><%= item.voucher %></code>
                    </td>
                    <td class="px-6 py-4 text-right font-semibold text-slate-900">
                      <%= (item.price || 0).toLocaleString('ru-RU') %> сум
                    </td>
                  </tr>
                <% }) %>
              </tbody>
            </table>
          </div>
          <div class="flex justify-between items-center px-6 py-5 border-t border-slate-200 bg-slate-50">
            <p class="text-sm font-medium text-slate-500">Итого</p>
            <p class="text-xl font-semibold text-slate-900"><%= totalSum.toLocaleString('ru-RU') %> сум</p>
          </div>
        </div>
      <% } %>

      <div class="flex flex-col sm:flex-row gap-3 px-6 py-6 border-t border-slate-200 bg-white">
        <button type="button" class="inline-flex items-center justify-center gap-2 rounded-lg bg-slate-900 px-5 py-2.5 text-sm font-semibold text-white shadow-sm transition hover:bg-slate-700" onclick="window.print()">
          <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 9V4h12v5M6 18h12v-6H6v6zm0 0v2h12v-2M6 12h.01M18 12h.01" />
          </svg>
          Распечатать чек
        </button>
        <div class="flex flex-1 flex-col gap-3 sm:flex-row sm:justify-end">
          <a href="/merchant/sell" class="inline-flex items-center justify-center gap-2 rounded-lg border border-slate-200 bg-white px-5 py-2.5 text-sm font-semibold text-slate-700 shadow-sm transition hover:border-indigo-300 hover:text-indigo-600">
            <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18" />
            </svg>
            К каталогу
          </a>
          <a href="/merchant/sales" class="inline-flex items-center justify-center gap-2 rounded-lg bg-indigo-600 px-5 py-2.5 text-sm font-semibold text-white shadow-sm transition hover:bg-indigo-500">
            <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 17v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm6 0v-6a2 2 0 00-2-2h-2a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm6 0v-6a2 2 0 00-2-2h-2a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2z" />
            </svg>
            История продаж
          </a>
        </div>
      </div>
    </section>
  </main>
</body>
</html>
