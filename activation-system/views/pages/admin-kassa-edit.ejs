<!DOCTYPE html>
<html lang="ru">

<head>
    <meta charset="UTF-8">
    <title>Редактирование кассы — POSA Admin</title>
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="/css/admin.css" rel="stylesheet">
</head>

<body class="bg-slate-50 min-h-screen">
    <%- include('../partials/admin-navbar', { user }) %>

        <div class="max-w-2xl mx-auto px-4 sm:px-6 lg:px-8 py-8 pt-20">
            <h2 class="text-2xl font-bold text-slate-900 mb-6">Редактирование — <%= kassa.name %>
            </h2>

            <% if (error) { %>
                <div class="rounded-md bg-red-50 p-4 mb-6">
                    <div class="text-sm text-red-700">
                        <%= error %>
                    </div>
                </div>
                <% } %>

                    <form method="POST" action="/admin/kassas/<%= kassa.id %>/edit"
                        class="bg-white shadow-sm ring-1 ring-slate-200 rounded-lg p-6 space-y-6">
                        <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
                            <div>
                                <label class="block text-sm font-medium text-slate-700">Название</label>
                                <input type="text" name="name" value="<%= kassa.name %>" required
                                    class="mt-1 block w-full rounded-md border-slate-300 shadow-sm text-sm">
                            </div>
                            <div>
                                <label class="block text-sm font-medium text-slate-700">Юр. лицо</label>
                                <input type="text" name="legalName" value="<%= kassa.legalName || '' %>"
                                    class="mt-1 block w-full rounded-md border-slate-300 shadow-sm text-sm">
                            </div>
                            <div>
                                <label class="block text-sm font-medium text-slate-700">ИНН</label>
                                <input type="text" name="inn" value="<%= kassa.inn || '' %>"
                                    class="mt-1 block w-full rounded-md border-slate-300 shadow-sm text-sm">
                            </div>
                            <div class="flex items-center pt-6">
                                <label class="flex items-center gap-2">
                                    <input type="checkbox" name="isActive" <%=kassa.isActive ? 'checked' : '' %>
                                    class="rounded border-slate-300 text-indigo-600">
                                    <span class="text-sm text-slate-700">Активна</span>
                                </label>
                            </div>
                        </div>

                        <hr class="border-slate-200">
                        <h3 class="text-lg font-medium text-slate-900">Реквизиты Click</h3>
                        <div class="grid grid-cols-1 sm:grid-cols-3 gap-4">
                            <div>
                                <label class="block text-sm font-medium text-slate-700">Merchant ID</label>
                                <input type="text" name="clickMerchantId" value="<%= kassa.clickMerchantId || '' %>"
                                    class="mt-1 block w-full rounded-md border-slate-300 shadow-sm text-sm">
                            </div>
                            <div>
                                <label class="block text-sm font-medium text-slate-700">Service ID</label>
                                <input type="text" name="clickServiceId" value="<%= kassa.clickServiceId || '' %>"
                                    class="mt-1 block w-full rounded-md border-slate-300 shadow-sm text-sm">
                            </div>
                            <div>
                                <label class="block text-sm font-medium text-slate-700">Secret Key</label>
                                <input type="password" name="clickSecretKey" value="<%= kassa.clickSecretKey || '' %>"
                                    class="mt-1 block w-full rounded-md border-slate-300 shadow-sm text-sm">
                            </div>
                        </div>

                        <hr class="border-slate-200">
                        <h3 class="text-lg font-medium text-slate-900">Реквизиты Payme</h3>
                        <div class="grid grid-cols-1 sm:grid-cols-3 gap-4">
                            <div>
                                <label class="block text-sm font-medium text-slate-700">Merchant ID</label>
                                <input type="text" name="paymeMerchantId" value="<%= kassa.paymeMerchantId || '' %>"
                                    class="mt-1 block w-full rounded-md border-slate-300 shadow-sm text-sm">
                            </div>
                            <div>
                                <label class="block text-sm font-medium text-slate-700">Key (prod)</label>
                                <input type="password" name="paymeKey" value="<%= kassa.paymeKey || '' %>"
                                    class="mt-1 block w-full rounded-md border-slate-300 shadow-sm text-sm">
                            </div>
                            <div>
                                <label class="block text-sm font-medium text-slate-700">Test Key</label>
                                <input type="password" name="paymeTestKey" value="<%= kassa.paymeTestKey || '' %>"
                                    class="mt-1 block w-full rounded-md border-slate-300 shadow-sm text-sm">
                            </div>
                        </div>

                        <hr class="border-slate-200">
                        <h3 class="text-lg font-medium text-slate-900">Контакты</h3>
                        <div class="grid grid-cols-1 sm:grid-cols-3 gap-4">
                            <div>
                                <label class="block text-sm font-medium text-slate-700">Контактное лицо</label>
                                <input type="text" name="contactPerson" value="<%= kassa.contactPerson || '' %>"
                                    class="mt-1 block w-full rounded-md border-slate-300 shadow-sm text-sm">
                            </div>
                            <div>
                                <label class="block text-sm font-medium text-slate-700">Телефон</label>
                                <input type="text" name="contactPhone" value="<%= kassa.contactPhone || '' %>"
                                    class="mt-1 block w-full rounded-md border-slate-300 shadow-sm text-sm">
                            </div>
                            <div>
                                <label class="block text-sm font-medium text-slate-700">Email</label>
                                <input type="email" name="contactEmail" value="<%= kassa.contactEmail || '' %>"
                                    class="mt-1 block w-full rounded-md border-slate-300 shadow-sm text-sm">
                            </div>
                        </div>

                        <!-- Callback URLs -->
                        <div class="bg-indigo-50 rounded-md p-4">
                            <h4 class="text-sm font-medium text-indigo-900 mb-2">Callback URLs для Click/Payme</h4>
                            <div class="space-y-1 text-sm">
                                <div><span class="text-indigo-600">Click Prepare:</span> <code
                                        class="text-slate-700">https://wallet.namo.uz/api/payments/click/<%= kassa.id %>/prepare</code>
                                </div>
                                <div><span class="text-indigo-600">Click Complete:</span> <code
                                        class="text-slate-700">https://wallet.namo.uz/api/payments/click/<%= kassa.id %>/complete</code>
                                </div>
                                <div><span class="text-indigo-600">Payme:</span> <code
                                        class="text-slate-700">https://wallet.namo.uz/api/payments/payme/<%= kassa.id %></code>
                                </div>
                            </div>
                        </div>

                        <hr class="border-slate-200">
                        <h3 class="text-lg font-medium text-slate-900">Привязка вендоров</h3>
                        <div class="space-y-2">
                            <% availableVendors.forEach(v=> { %>
                                <label class="flex items-center gap-2">
                                    <input type="checkbox" name="vendorIds" value="<%= v.id %>" <%=v.kassaId===kassa.id
                                        ? 'checked' : '' %> class="rounded border-slate-300 text-indigo-600">
                                    <span class="text-sm text-slate-700">
                                        <%= v.name %>
                                    </span>
                                </label>
                                <% }) %>
                        </div>

                        <button type="submit"
                            class="w-full rounded-md bg-indigo-600 px-4 py-2.5 text-sm font-semibold text-white hover:bg-indigo-500">
                            Сохранить
                        </button>
                    </form>
        </div>
</body>

</html>