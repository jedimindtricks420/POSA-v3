<!DOCTYPE html>
<html lang="ru">

<head>
    <meta charset="UTF-8">
    <title>ManaStore - История активаций</title>
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="/css/admin.css" rel="stylesheet">
</head>

<body class="bg-slate-50 min-h-screen">
    <%- include('../partials/admin-navbar', { user }) %>

        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8 pt-20">
            <div class="md:flex md:items-center md:justify-between mb-6">
                <div class="min-w-0 flex-1">
                    <h2 class="text-2xl font-bold leading-7 text-slate-900 sm:truncate sm:text-3xl sm:tracking-tight">
                        История активаций ManaStore
                    </h2>
                    <p class="mt-1 text-sm text-slate-500">
                        Просмотр всех активаций ваучеров через магазины ManaStore
                    </p>
                </div>
                <div class="mt-4 flex md:ml-4 md:mt-0">
                    <a href="/admin/manastore"
                        class="inline-flex items-center rounded-md bg-white px-3 py-2 text-sm font-semibold text-slate-900 shadow-sm ring-1 ring-inset ring-slate-300 hover:bg-slate-50">
                        <svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                                d="M11 17l-5-5m0 0l5-5m-5 5h12" />
                        </svg>
                        Назад
                    </a>
                </div>
            </div>

            <!-- Фильтры -->
            <form method="GET" action="/admin/manastore/activations"
                class="bg-white shadow-sm ring-1 ring-slate-200 sm:rounded-lg p-4 mb-6">
                <div class="grid grid-cols-1 gap-4 sm:grid-cols-3 lg:grid-cols-6">
                    <div>
                        <label for="startDate" class="block text-xs font-medium text-slate-700">Дата от</label>
                        <input type="date" name="startDate" id="startDate" value="<%= filters.startDate || '' %>"
                            class="mt-1 block w-full rounded-md border-slate-300 shadow-sm focus:border-indigo-500 focus:ring-indigo-500 text-sm">
                    </div>
                    <div>
                        <label for="endDate" class="block text-xs font-medium text-slate-700">Дата до</label>
                        <input type="date" name="endDate" id="endDate" value="<%= filters.endDate || '' %>"
                            class="mt-1 block w-full rounded-md border-slate-300 shadow-sm focus:border-indigo-500 focus:ring-indigo-500 text-sm">
                    </div>
                    <div>
                        <label for="productId" class="block text-xs font-medium text-slate-700">Товар</label>
                        <select name="productId" id="productId"
                            class="mt-1 block w-full rounded-md border-slate-300 shadow-sm focus:border-indigo-500 focus:ring-indigo-500 text-sm">
                            <option value="">Все товары</option>
                            <% products.forEach(product=> { %>
                                <option value="<%= product.id %>" <%=filters.productId==product.id ? 'selected' : '' %>>
                                    <%= product.name %>
                                </option>
                                <% }) %>
                        </select>
                    </div>
                    <div>
                        <label for="phone" class="block text-xs font-medium text-slate-700">Телефон</label>
                        <input type="text" name="phone" id="phone" value="<%= filters.phone || '' %>"
                            class="mt-1 block w-full rounded-md border-slate-300 shadow-sm focus:border-indigo-500 focus:ring-indigo-500 text-sm"
                            placeholder="+998">
                    </div>
                    <div>
                        <label for="storeSlug" class="block text-xs font-medium text-slate-700">Магазин</label>
                        <select name="storeSlug" id="storeSlug"
                            class="mt-1 block w-full rounded-md border-slate-300 shadow-sm focus:border-indigo-500 focus:ring-indigo-500 text-sm">
                            <option value="">Все магазины</option>
                            <% stores.forEach(store=> { %>
                                <option value="<%= store.slug %>" <%=filters.storeSlug===store.slug ? 'selected' : ''
                                    %>>
                                    /<%= store.slug %>
                                </option>
                                <% }) %>
                        </select>
                    </div>
                    <div>
                        <label for="status" class="block text-xs font-medium text-slate-700">Статус ManaStore</label>
                        <select name="status" id="status"
                            class="mt-1 block w-full rounded-md border-slate-300 shadow-sm focus:border-indigo-500 focus:ring-indigo-500 text-sm">
                            <option value="">Все статусы</option>
                            <option value="COMPLETED" <%=filters.status==='COMPLETED' ? 'selected' : '' %>>COMPLETED
                            </option>
                            <option value="PENDING" <%=filters.status==='PENDING' ? 'selected' : '' %>>PENDING</option>
                            <option value="FAILED" <%=filters.status==='FAILED' ? 'selected' : '' %>>FAILED</option>
                            <option value="REFUNDED" <%=filters.status==='REFUNDED' ? 'selected' : '' %>>REFUNDED
                            </option>
                        </select>
                    </div>
                </div>
                <div class="mt-4 flex justify-end">
                    <button type="submit"
                        class="inline-flex items-center rounded-md bg-indigo-600 px-3 py-2 text-sm font-semibold text-white shadow-sm hover:bg-indigo-700">
                        Применить фильтры
                    </button>
                </div>
            </form>

            <!-- Таблица активаций -->
            <div class="bg-white shadow-sm ring-1 ring-slate-200 sm:rounded-lg overflow-x-auto">
                <table class="min-w-full divide-y divide-slate-200">
                    <thead>
                        <tr>
                            <th scope="col"
                                class="py-3.5 pl-4 pr-3 text-left text-sm font-semibold text-slate-900 sm:pl-6">
                                Дата/Время</th>
                            <th scope="col" class="px-3 py-3.5 text-left text-sm font-semibold text-slate-900">Ваучер
                            </th>
                            <th scope="col" class="px-3 py-3.5 text-left text-sm font-semibold text-slate-900">Клиент
                            </th>
                            <th scope="col" class="px-3 py-3.5 text-left text-sm font-semibold text-slate-900">Товар
                            </th>
                            <th scope="col" class="px-3 py-3.5 text-left text-sm font-semibold text-slate-900">Магазин
                            </th>
                            <th scope="col" class="px-3 py-3.5 text-left text-sm font-semibold text-slate-900">Статус
                                ManaStore</th>
                            <th scope="col" class="px-3 py-3.5 text-left text-sm font-semibold text-slate-900">Контур
                            </th>
                            <th scope="col" class="px-3 py-3.5 text-left text-sm font-semibold text-slate-900">Ключ</th>
                        </tr>
                    </thead>
                    <tbody class="divide-y divide-slate-200 bg-white">
                        <% activations.forEach(activation=> { %>
                            <tr class="hover:bg-slate-50 transition-colors duration-150">
                                <td class="whitespace-nowrap py-4 pl-4 pr-3 text-sm text-slate-900 sm:pl-6">
                                    <%= new Date(activation.activatedAt).toLocaleString('ru-RU') %>
                                </td>
                                <td class="whitespace-nowrap px-3 py-4 text-sm font-mono text-slate-900">
                                    <%= activation.voucher.value %>
                                </td>
                                <td class="whitespace-nowrap px-3 py-4 text-sm text-slate-600">
                                    <% if (activation.client) { %>
                                        <%= activation.client.phoneNumber || activation.client.name || '—' %>
                                            <% } else { %>
                                                <span class="text-slate-400">—</span>
                                                <% } %>
                                </td>
                                <td class="whitespace-nowrap px-3 py-4 text-sm text-slate-900">
                                    <%= activation.voucher.product.name %>
                                </td>
                                <td class="whitespace-nowrap px-3 py-4 text-sm text-slate-600">
                                    <% if (activation.voucher.product.store) { %>
                                        <span
                                            class="inline-flex items-center rounded-md bg-blue-50 px-2 py-1 text-xs font-medium text-blue-700 ring-1 ring-inset ring-blue-700/10 font-mono">
                                            /<%= activation.voucher.product.store.slug %>
                                        </span>
                                        <% } else { %>
                                            <span class="text-slate-400">—</span>
                                            <% } %>
                                </td>
                                <td class="whitespace-nowrap px-3 py-4 text-sm">
                                    <% if (activation.voucher.manastoreOrder) { %>
                                        <% if (activation.voucher.manastoreOrder.status==='COMPLETED' ) { %>
                                            <span
                                                class="inline-flex items-center rounded-md bg-green-50 px-2 py-1 text-xs font-medium text-green-700 ring-1 ring-inset ring-green-600/20">
                                                COMPLETED
                                            </span>
                                            <% } else if (activation.voucher.manastoreOrder.status==='PENDING' ) { %>
                                                <span
                                                    class="inline-flex items-center rounded-md bg-yellow-50 px-2 py-1 text-xs font-medium text-yellow-800 ring-1 ring-inset ring-yellow-600/20">
                                                    PENDING
                                                </span>
                                                <% } else if
                                                    (activation.voucher.manastoreOrder.status==='REFUNDED' ) { %>
                                                    <span
                                                        class="inline-flex items-center rounded-md bg-orange-50 px-2 py-1 text-xs font-medium text-orange-700 ring-1 ring-inset ring-orange-600/20">
                                                        REFUNDED
                                                    </span>
                                                    <% } else { %>
                                                        <span
                                                            class="inline-flex items-center rounded-md bg-red-50 px-2 py-1 text-xs font-medium text-red-700 ring-1 ring-inset ring-red-600/10">
                                                            FAILED
                                                        </span>
                                                        <% } %>
                                                            <% } else { %>
                                                                <span class="text-slate-400">—</span>
                                                                <% } %>
                                </td>
                                <td class="whitespace-nowrap px-3 py-4 text-sm font-mono text-slate-600">
                                    <%= activation.voucher.manastoreOrder?.environment || '—' %>
                                </td>
                                <td class="whitespace-nowrap px-3 py-4 text-sm font-mono text-slate-600">
                                    <% if (activation.voucher.manastoreOrder && activation.voucher.manastoreOrder.key)
                                        { %>
                                        <% const key=activation.voucher.manastoreOrder.key; %>
                                            <% const masked=key.length> 8 ? key.substring(0, 4) + '-****-' +
                                                key.substring(key.length - 4) : '****'; %>
                                                <%= masked %>
                                                    <% } else { %>
                                                        <span class="text-slate-400">—</span>
                                                        <% } %>
                                </td>
                            </tr>
                            <% }) %>
                    </tbody>
                </table>

                <% if (activations.length===0) { %>
                    <div class="text-center py-12">
                        <svg class="mx-auto h-12 w-12 text-slate-400" fill="none" stroke="currentColor"
                            viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1"
                                d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2" />
                        </svg>
                        <h3 class="mt-2 text-sm font-semibold text-slate-900">Нет активаций</h3>
                        <p class="mt-1 text-sm text-slate-500">Активации появятся после того, как клиенты начнут
                            активировать ваучеры через магазины.</p>
                    </div>
                    <% } %>
            </div>
        </div>
</body>

</html>
