<!DOCTYPE html>
<html lang="ru" class="h-full">
<%- include('../partials/client/head', { title: 'Подтверждение кода' }) %>
<body class="flex min-h-screen items-center justify-center bg-wallet-bg px-4 text-slate-900 dark:bg-wallet-dark dark:text-slate-100 safe-area-y">
  <div class="w-full max-w-md space-y-8">
    <div class="text-center space-y-3">
      <div class="mx-auto flex h-16 w-16 items-center justify-center rounded-2xl bg-apple-blue text-2xl font-semibold text-white">NW</div>
      <h1 class="text-2xl font-semibold">Подтвердите код</h1>
      <p class="text-sm text-slate-500">Мы отправили SMS на номер <span class="font-semibold"><%= phone %></span></p>
    </div>
    <div class="glass-panel space-y-6 p-8">
      <% if (error) { %>
        <div class="rounded-2xl border border-red-200 bg-red-50 px-4 py-3 text-sm text-red-600"><%= error %></div>
      <% } %>
      <form method="POST" action="/client-verify" class="space-y-4" id="walletOtpForm">
        <label class="space-y-2">
          <span class="text-sm font-medium text-slate-600">Код из SMS</span>
          <input type="text" name="otp" inputmode="numeric" autocomplete="one-time-code" maxlength="6" class="w-full rounded-2xl border border-slate-200 bg-white px-4 py-3 text-center text-lg tracking-[0.5em] outline-none transition focus:border-apple-blue focus:ring-2 focus:ring-apple-blue/20 dark:border-slate-700 dark:bg-slate-900" required />
        </label>
        <button type="submit" class="w-full rounded-2xl bg-apple-blue px-4 py-3 text-sm font-semibold text-white transition hover:bg-blue-600">Подтвердить</button>
      </form>
      <div class="text-center text-sm text-slate-500">
        Не пришло SMS? <button id="walletOtpResend" class="font-semibold text-apple-blue hover:text-blue-600" type="button">Отправить снова</button>
      </div>
    </div>
  </div>
  <script>
    window.__WALLET_VERIFY__ = {
      phone: <%- JSON.stringify(phone || null) %>
    };
  </script>
  <script type="module" src="/js/client-session.js"></script>
  <script type="module" src="/js/client-auth.js"></script>
</body>
</html>
