<!DOCTYPE html>
<html lang="ru">
<head>
  <meta charset="UTF-8">
  <title>Редактирование мерчанта</title>
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <script src="https://cdn.tailwindcss.com"></script>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
  <link href="/css/admin.css" rel="stylesheet">
</head>
<body class="bg-slate-50 min-h-screen font-[Inter]">
  <%- include('../partials/admin-navbar', { user }) %>

  <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 py-8 pt-20">
    <div class="md:flex md:items-center md:justify-between mb-6">
      <div class="min-w-0 flex-1">
        <h1 class="text-3xl font-bold tracking-tight text-slate-900">Редактирование мерчанта</h1>
        <p class="mt-2 text-sm text-slate-500">Настройте аккаунт <span class="font-semibold text-slate-900"><%= merchant.username %></span> и обновите юридические данные</p>
      </div>
      <div class="mt-4 md:ml-4 md:mt-0">
        <a href="/admin/merchants"
           class="inline-flex items-center rounded-md border border-slate-300 bg-white px-4 py-2 text-sm font-medium text-slate-700 shadow-sm hover:bg-slate-50">
          Назад к списку
        </a>
      </div>
    </div>

    <% if (error) { %>
      <div class="mb-6 rounded-md bg-red-50 p-4">
        <div class="flex">
          <div class="flex-shrink-0">
            <svg class="h-5 w-5 text-red-400" viewBox="0 0 20 20" fill="currentColor">
              <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm0-11a.75.75 0 01.75.75v3.5a.75.75 0 01-1.5 0v-3.5A.75.75 0 0110 7zm0 6a.75.75 0 100 1.5.75.75 0 000-1.5z" clip-rule="evenodd" />
            </svg>
          </div>
          <div class="ml-3">
            <h3 class="text-sm font-medium text-red-800">Ошибка</h3>
            <div class="mt-2 text-sm text-red-700"><%= error %></div>
          </div>
        </div>
      </div>
    <% } %>

    <% const actualDebt = Math.max(Number(merchant.balance || 0), 0); %>
    <div class="grid grid-cols-1 gap-6 lg:grid-cols-3">
      <section class="rounded-2xl bg-white p-5 shadow ring-1 ring-slate-200">
        <h2 class="text-lg font-semibold text-slate-900">Карточка мерчанта</h2>
        <dl class="mt-4 space-y-4 text-sm">
          <div class="flex items-start justify-between">
            <dt class="text-slate-500">ID</dt>
            <dd class="font-semibold text-slate-900">#<%= merchant.id %></dd>
          </div>
          <div class="flex items-start justify-between">
            <dt class="text-slate-500">Баланс</dt>
            <dd class="font-mono text-base font-semibold text-slate-900"><%= Number(merchant.balance || 0).toLocaleString('ru-RU', { minimumFractionDigits: 2 }) %> сум</dd>
          </div>
          <div class="flex items-start justify-between">
            <dt class="text-slate-500">Текущий долг</dt>
            <dd class="font-mono text-base font-semibold <%= actualDebt > 0 ? 'text-rose-600' : 'text-emerald-600' %>"><%= actualDebt.toLocaleString('ru-RU', { minimumFractionDigits: 2 }) %> сум</dd>
          </div>
          <div class="flex items-start justify-between">
            <dt class="text-slate-500">Статус</dt>
            <dd class="font-semibold text-slate-900"><%= merchant.status === 'off' ? 'Выключен' : 'Активен' %></dd>
          </div>
        </dl>
        <p class="mt-4 text-xs text-slate-400">Изменение логина синхронизирует также учётную запись пользователя (роль «merchant»).</p>
      </section>

      <form method="POST" action="/admin/merchants/edit/<%= merchant.id %>" class="lg:col-span-2 rounded-2xl bg-white p-6 shadow ring-1 ring-slate-200">
        <div class="space-y-6">
          <div>
            <label class="block text-sm font-medium text-slate-700">Логин</label>
            <div class="mt-1">
              <input type="text" name="username" required
                     value="<%= merchant.username %>"
                     class="block w-full rounded-md border-slate-300 shadow-sm focus:border-indigo-500 focus:ring-indigo-500 sm:text-sm" />
            </div>
          </div>

          <div>
            <label class="block text-sm font-medium text-slate-700">Статус</label>
            <div class="mt-1">
              <select name="status"
                      class="block w-full rounded-md border-slate-300 shadow-sm focus:border-indigo-500 focus:ring-indigo-500 sm:text-sm">
                <option value="active" <%= merchant.status === 'active' ? 'selected' : '' %>>Активен</option>
                <option value="off" <%= merchant.status === 'off' ? 'selected' : '' %>>Выключен</option>
              </select>
            </div>
          </div>

          <div>
            <label class="block text-sm font-medium text-slate-700">Юридическая информация</label>
            <div class="mt-1">
              <textarea name="legalInfo" rows="4" required
                        class="block w-full rounded-md border-slate-300 shadow-sm focus:border-indigo-500 focus:ring-indigo-500 sm:text-sm"><%= merchant.legalInfo %></textarea>
            </div>
          </div>

          <div>
            <label class="block text-sm font-medium text-slate-700">Новый пароль <span class="text-slate-400">(необязательно)</span></label>
            <div class="mt-1">
              <input type="password" name="password" minlength="6"
                     class="block w-full rounded-md border-slate-300 shadow-sm focus:border-indigo-500 focus:ring-indigo-500 sm:text-sm"
                     placeholder="Оставьте пустым, чтобы не менять" />
            </div>
            <p class="mt-1 text-xs text-slate-500">Если заполнить поле, пароль будет обновлён и отправлен мерчанту вручную.</p>
          </div>
        </div>

        <div class="mt-8 flex flex-col gap-3 sm:flex-row sm:justify-end">
          <a href="/admin/merchants"
             class="inline-flex items-center justify-center rounded-md border border-slate-300 bg-white px-4 py-2 text-sm font-medium text-slate-700 shadow-sm hover:bg-slate-50">Отмена</a>
          <button type="submit"
                  class="inline-flex items-center justify-center rounded-md bg-indigo-600 px-4 py-2 text-sm font-semibold text-white shadow-sm hover:bg-indigo-500">Сохранить изменения</button>
        </div>
      </form>
    </div>
  </div>
</body>
</html>
