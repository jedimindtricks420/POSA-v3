<!DOCTYPE html>
<html lang="ru">
<head>
  <meta charset="UTF-8">
  <title>История платежей - <%= merchant.legalInfo %></title>
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <script src="https://cdn.tailwindcss.com"></script>
  <link href="/css/admin.css" rel="stylesheet">
</head>
<body class="bg-slate-50 min-h-screen">
  <%- include('../partials/admin-navbar', { user }) %>
  
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8 pt-20">
    <div class="md:flex md:items-center md:justify-between mb-6">
      <div class="min-w-0 flex-1">
        <h2 class="text-2xl font-bold leading-7 text-slate-900 sm:truncate sm:text-3xl sm:tracking-tight">
          История платежей
        </h2>
        <p class="mt-1 text-sm text-slate-500">
          Мерчант: <%= merchant.legalInfo %>
        </p>
      </div>
      <div class="mt-4 flex md:ml-4 md:mt-0">
        <a href="/admin/merchants" 
          class="inline-flex items-center rounded-md bg-white px-3 py-2 text-sm font-semibold text-slate-900 shadow-sm ring-1 ring-inset ring-slate-300 hover:bg-slate-50 transition-colors duration-200">
          <svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 17l-5-5m0 0l5-5m-5 5h12"/>
          </svg>
          К списку мерчантов
        </a>
      </div>
    </div>

    <% if (payments.length === 0) { %>
      <div class="rounded-md bg-yellow-50 p-4">
        <div class="flex">
          <div class="flex-shrink-0">
            <svg class="h-5 w-5 text-yellow-400" viewBox="0 0 20 20" fill="currentColor">
              <path fill-rule="evenodd" d="M8.485 2.495c.673-1.167 2.357-1.167 3.03 0l6.28 10.875c.673 1.167-.17 2.625-1.516 2.625H3.72c-1.347 0-2.189-1.458-1.515-2.625L8.485 2.495zM10 5a.75.75 0 01.75.75v3.5a.75.75 0 01-1.5 0v-3.5A.75.75 0 0110 5zm0 9a1 1 0 100-2 1 1 0 000 2z" clip-rule="evenodd" />
            </svg>
          </div>
          <div class="ml-3">
            <h3 class="text-sm font-medium text-yellow-800">Нет данных</h3>
            <div class="mt-2 text-sm text-yellow-700">
              Платежей пока нет.
            </div>
          </div>
        </div>
      </div>
    <% } else { %>
      <div class="mt-8 flow-root">
        <div class="-mx-4 -my-2 overflow-x-auto sm:-mx-6 lg:-mx-8">
          <div class="inline-block min-w-full py-2 align-middle sm:px-6 lg:px-8">
            <div class="overflow-hidden shadow ring-1 ring-black ring-opacity-5 sm:rounded-lg">
              <table class="min-w-full divide-y divide-slate-300">
                <thead class="bg-slate-50">
                  <tr>
                    <th scope="col" class="py-3.5 pl-4 pr-3 text-left text-sm font-semibold text-slate-900 sm:pl-6">ID</th>
                    <th scope="col" class="px-3 py-3.5 text-left text-sm font-semibold text-slate-900">Сумма</th>
                    <th scope="col" class="px-3 py-3.5 text-left text-sm font-semibold text-slate-900">Комментарий</th>
                    <th scope="col" class="px-3 py-3.5 text-left text-sm font-semibold text-slate-900">До оплаты</th>
                    <th scope="col" class="px-3 py-3.5 text-left text-sm font-semibold text-slate-900">После оплаты</th>
                    <th scope="col" class="px-3 py-3.5 text-left text-sm font-semibold text-slate-900">Дата</th>
                  </tr>
                </thead>
                <tbody class="divide-y divide-slate-200 bg-white">
                  <% payments.forEach(payment => { %>
                    <tr>
                      <td class="whitespace-nowrap py-4 pl-4 pr-3 text-sm font-medium text-slate-900 sm:pl-6"><%= payment.id %></td>
                      <td class="whitespace-nowrap px-3 py-4 text-sm text-slate-500"><%= payment.amount.toFixed(2) %> сум</td>
                      <td class="whitespace-nowrap px-3 py-4 text-sm text-slate-500"><%= payment.comment || '—' %></td>
                      <td class="whitespace-nowrap px-3 py-4 text-sm text-slate-500"><%= payment.balanceBefore.toFixed(2) %></td>
                      <td class="whitespace-nowrap px-3 py-4 text-sm text-slate-500"><%= payment.balanceAfter.toFixed(2) %></td>
                      <td class="whitespace-nowrap px-3 py-4 text-sm text-slate-500"><%= new Date(payment.createdAt).toLocaleString() %></td>
                    </tr>
                  <% }) %>
                </tbody>
              </table>
            </div>
          </div>
        </div>
      </div>
    <% } %>
  </div>
</body>
</html>