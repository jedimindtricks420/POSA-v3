<!DOCTYPE html>
<html lang="ru">
<head>
  <meta charset="UTF-8">
  <title>Мерчанты | Admin Panel</title>
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <script src="https://cdn.tailwindcss.com"></script>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
  <link href="/css/admin.css" rel="stylesheet">
</head>
<body class="bg-slate-50 min-h-screen font-[Inter]">
  <%- include('../partials/admin-navbar', { user }) %>

  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8 pt-20">
    <div class="md:flex md:items-center md:justify-between mb-8">
      <div class="min-w-0 flex-1">
        <h1 class="text-3xl font-bold tracking-tight text-slate-900">Мерчанты и задолженности</h1>
        <p class="mt-2 text-sm text-slate-500">Следите за балансами, статусами и платежами мерчантов платформы</p>
      </div>
      <div class="mt-4 flex flex-col gap-3 md:ml-4 md:mt-0">
        <a href="/admin/add-merchant"
           class="inline-flex items-center justify-center rounded-lg bg-indigo-600 px-4 py-2.5 text-sm font-semibold text-white shadow-sm transition hover:bg-indigo-500 focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-indigo-600">
          <svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6v12m6-6H6" />
          </svg>
          Добавить мерчанта
        </a>
      </div>
    </div>

    <% const statsData = stats || { total: 0, active: 0, suspended: 0, totalDebt: 0 }; %>
    <div class="grid grid-cols-1 gap-4 sm:grid-cols-2 lg:grid-cols-4 mb-8">
      <div class="rounded-2xl bg-white p-5 shadow ring-1 ring-slate-100">
        <p class="text-sm font-medium text-slate-500">Всего мерчантов</p>
        <p class="mt-2 text-3xl font-semibold text-slate-900"><%= statsData.total %></p>
      </div>
      <div class="rounded-2xl bg-white p-5 shadow ring-1 ring-slate-100">
        <p class="text-sm font-medium text-slate-500">Активны</p>
        <p class="mt-2 text-3xl font-semibold text-emerald-600"><%= statsData.active %></p>
      </div>
      <div class="rounded-2xl bg-white p-5 shadow ring-1 ring-slate-100">
        <p class="text-sm font-medium text-slate-500">Выключены</p>
        <p class="mt-2 text-3xl font-semibold text-slate-900"><%= statsData.suspended %></p>
      </div>
      <div class="rounded-2xl bg-white p-5 shadow ring-1 ring-slate-100">
        <p class="text-sm font-medium text-slate-500">Суммарный долг</p>
        <p class="mt-2 text-3xl font-semibold text-rose-600"><%= Number(statsData.totalDebt || 0).toLocaleString('ru-RU', { minimumFractionDigits: 2 }) %></p>
        <p class="text-xs uppercase tracking-widest text-slate-400">сум</p>
      </div>
    </div>

    <div class="bg-white shadow-sm ring-1 ring-slate-200 sm:rounded-lg overflow-x-auto">
      <table class="min-w-full divide-y divide-slate-200">
        <thead class="bg-slate-50">
          <tr>
            <th class="py-3.5 pl-4 pr-3 text-left text-xs font-semibold uppercase tracking-wide text-slate-500 sm:pl-6">ID</th>
            <th class="px-3 py-3.5 text-left text-xs font-semibold uppercase tracking-wide text-slate-500">Логин</th>
            <th class="px-3 py-3.5 text-left text-xs font-semibold uppercase tracking-wide text-slate-500">Компания</th>
            <th class="px-3 py-3.5 text-left text-xs font-semibold uppercase tracking-wide text-slate-500">Статус</th>
            <th class="px-3 py-3.5 text-right text-xs font-semibold uppercase tracking-wide text-slate-500">Баланс</th>
            <th class="px-3 py-3.5 text-right text-xs font-semibold uppercase tracking-wide text-slate-500">Текущий долг</th>
            <th class="relative py-3.5 pl-3 pr-4 text-right text-xs font-semibold uppercase tracking-wide text-slate-500 sm:pr-6">Действия</th>
          </tr>
        </thead>
        <tbody class="divide-y divide-slate-200 bg-white">
          <% if (merchants.length > 0) { %>
            <% merchants.forEach(m => { %>
              <% const statusLabel = m.status === 'active' ? 'Активен' : 'Выключен'; %>
              <tr class="hover:bg-slate-50 transition duration-150 ease-in-out">
                <td class="whitespace-nowrap py-4 pl-4 pr-3 text-sm font-semibold text-slate-900 sm:pl-6">#<%= m.id %></td>
                <td class="whitespace-nowrap px-3 py-4 text-sm">
                  <div class="font-semibold text-slate-900"><%= m.username %></div>
                  <div class="text-xs text-slate-500">Логин мерчанта</div>
                </td>
                <td class="px-3 py-4 text-sm text-slate-700 min-w-[220px]">
                  <%= m.legalInfo || '—' %>
                </td>
                <td class="whitespace-nowrap px-3 py-4 text-sm">
                  <span class="inline-flex items-center rounded-full px-3 py-1 text-xs font-semibold <%= m.status === 'active' ? 'bg-emerald-50 text-emerald-700 ring-1 ring-emerald-600/20' : 'bg-slate-100 text-slate-600 ring-1 ring-slate-500/20' %>">
                    <%= statusLabel %>
                  </span>
                </td>
                <td class="whitespace-nowrap px-3 py-4 text-sm text-right">
                  <div class="font-mono font-semibold text-slate-900">
                    <%= Number(m.balance || 0).toLocaleString('ru-RU', { minimumFractionDigits: 2 }) %>
                  </div>
                  <div class="text-xs text-slate-500">сум</div>
                </td>
                <td class="whitespace-nowrap px-3 py-4 text-sm text-right">
                  <div class="font-mono font-semibold <%= m.actualDebt > 0 ? 'text-rose-600' : 'text-slate-500' %>">
                    <%= Number(m.actualDebt || 0).toLocaleString('ru-RU', { minimumFractionDigits: 2 }) %>
                  </div>
                  <div class="text-xs text-slate-500">сум</div>
                </td>
                <td class="whitespace-nowrap py-4 pl-3 pr-4 text-right text-sm font-medium sm:pr-6">
                  <div class="flex flex-wrap items-center justify-end gap-2">
                    <a href="/admin/merchants/edit/<%= m.id %>" class="inline-flex items-center rounded-md bg-slate-50 px-2 py-1 text-xs font-semibold text-slate-600 ring-1 ring-inset ring-slate-500/10 hover:bg-slate-100">Изменить</a>
                    <a href="/admin/merchant/<%= m.id %>/pay" class="inline-flex items-center rounded-md bg-green-50 px-2 py-1 text-xs font-semibold text-green-700 ring-1 ring-inset ring-green-600/10 hover:bg-green-100">Оплатить</a>
                    <a href="/admin/merchant/<%= m.id %>/transactions" class="inline-flex items-center rounded-md bg-indigo-50 px-2 py-1 text-xs font-semibold text-indigo-700 ring-1 ring-inset ring-indigo-600/10 hover:bg-indigo-100">Продажи</a>
                    <a href="/admin/merchant/<%= m.id %>/payments" class="inline-flex items-center rounded-md bg-amber-50 px-2 py-1 text-xs font-semibold text-amber-700 ring-1 ring-inset ring-amber-500/10 hover:bg-amber-100">Платежи</a>
                  </div>
                </td>
              </tr>
            <% }) %>
          <% } else { %>
            <tr>
              <td colspan="7" class="py-16">
                <div class="text-center">
                  <svg class="mx-auto h-14 w-14 text-slate-300" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 6v12m6-6H6" />
                  </svg>
                  <h3 class="mt-4 text-base font-semibold text-slate-900">Мерчанты отсутствуют</h3>
                  <p class="mt-2 text-sm text-slate-500">Создайте первого мерчанта, чтобы начать продажи.</p>
                  <div class="mt-6">
                    <a href="/admin/add-merchant" class="inline-flex items-center rounded-md bg-indigo-600 px-4 py-2 text-sm font-semibold text-white shadow-sm hover:bg-indigo-500">
                      Добавить мерчанта
                    </a>
                  </div>
                </div>
              </td>
            </tr>
          <% } %>
        </tbody>
      </table>
    </div>
  </div>
</body>
</html>
