<!DOCTYPE html>
<html lang="ru">

<head>
    <meta charset="UTF-8">
    <title>Кассы — POSA Admin</title>
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="/css/admin.css" rel="stylesheet">
</head>

<body class="bg-slate-50 min-h-screen">
    <%- include('../partials/admin-navbar', { user }) %>

        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8 pt-20">
            <div class="md:flex md:items-center md:justify-between mb-6">
                <h2 class="text-2xl font-bold text-slate-900">Кассы</h2>
                <% if (user.role==='admin' ) { %>
                    <a href="/admin/kassas/add"
                        class="inline-flex items-center rounded-md bg-indigo-600 px-4 py-2 text-sm font-semibold text-white hover:bg-indigo-500">
                        + Добавить кассу
                    </a>
                    <% } %>
            </div>

            <div class="bg-white rounded-lg shadow-sm ring-1 ring-slate-200 overflow-hidden">
                <table class="min-w-full divide-y divide-slate-200">
                    <thead class="bg-slate-50">
                        <tr>
                            <th class="px-6 py-3 text-left text-xs font-medium text-slate-500 uppercase">ID</th>
                            <th class="px-6 py-3 text-left text-xs font-medium text-slate-500 uppercase">Название</th>
                            <th class="px-6 py-3 text-left text-xs font-medium text-slate-500 uppercase">Юр. лицо</th>
                            <th class="px-6 py-3 text-left text-xs font-medium text-slate-500 uppercase">Вендоры</th>
                            <th class="px-6 py-3 text-left text-xs font-medium text-slate-500 uppercase">Транзакции</th>
                            <th class="px-6 py-3 text-left text-xs font-medium text-slate-500 uppercase">Баланс</th>
                            <th class="px-6 py-3 text-left text-xs font-medium text-slate-500 uppercase">Статус</th>
                            <th class="px-6 py-3"></th>
                        </tr>
                    </thead>
                    <tbody class="divide-y divide-slate-200">
                        <% kassas.forEach(k=> { %>
                            <tr>
                                <td class="px-6 py-4 text-sm text-slate-900">
                                    <%= k.id %>
                                </td>
                                <td class="px-6 py-4 text-sm font-medium text-slate-900">
                                    <%= k.name %>
                                </td>
                                <td class="px-6 py-4 text-sm text-slate-600">
                                    <%= k.legalName || '—' %>
                                </td>
                                <td class="px-6 py-4 text-sm text-slate-600">
                                    <%= k.vendors.map(v=> v.name).join(', ') || '—' %>
                                </td>
                                <td class="px-6 py-4 text-sm text-slate-600">
                                    <%= k._count.transactions %>
                                </td>
                                <td class="px-6 py-4 text-sm font-medium text-indigo-600">
                                    <%= k.balance.toLocaleString('ru-RU') %>
                                </td>
                                <td class="px-6 py-4 text-sm">
                                    <span class="inline-flex items-center rounded-full px-2 py-0.5 text-xs font-medium
                <%= k.isActive ? 'bg-emerald-100 text-emerald-700' : 'bg-red-100 text-red-700' %>">
                                        <%= k.isActive ? 'Активна' : 'Неактивна' %>
                                    </span>
                                </td>
                                <td class="px-6 py-4 text-sm text-right">
                                    <% if (user.role==='admin' ) { %>
                                        <a href="/admin/kassas/<%= k.id %>/edit"
                                            class="text-indigo-600 hover:text-indigo-500">Редактировать</a>
                                        <% } %>
                                </td>
                            </tr>
                            <% }) %>
                                <% if (kassas.length===0) { %>
                                    <tr>
                                        <td colspan="8" class="px-6 py-8 text-center text-sm text-slate-400">Нет касс
                                        </td>
                                    </tr>
                                    <% } %>
                    </tbody>
                </table>
            </div>
        </div>
</body>

</html>