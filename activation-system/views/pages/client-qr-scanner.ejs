<!DOCTYPE html>
<html lang="ru" class="h-full">
<%- include('../partials/client/head', { title: 'Сканировать ваучер' }) %>
<body class="relative min-h-screen bg-wallet-bg px-4 text-slate-900 transition-colors dark:bg-wallet-dark dark:text-slate-100 safe-area-bottom">
  <main class="mx-auto flex w-full max-w-md flex-col gap-6 pb-24 pt-[calc(env(safe-area-inset-top,0px)+2rem)]">
    <div id="qrOfflineNotice" class="hidden rounded-2xl border border-amber-400 bg-amber-50 px-4 py-3 text-sm text-amber-700">
      Требуется подключение к интернету для проверки и добавления ваучера.
    </div>
    <section class="glass-panel space-y-6 p-6">
      <div class="space-y-2 text-center">
        <h2 class="text-lg font-semibold">Сканирование</h2>
        <p class="text-sm text-slate-500 dark:text-slate-400">Наведите камеру на QR код ваучера или введите код вручную.</p>
      </div>
      <div class="relative overflow-hidden rounded-3xl bg-black">
        <video id="qrPreview" class="h-64 w-full object-cover" autoplay playsinline muted></video>
        <div class="pointer-events-none absolute inset-0 flex items-center justify-center">
          <div class="h-40 w-40 rounded-2xl border-2 border-white/80"></div>
        </div>
        <div class="absolute left-1/2 top-1/2 flex w-full -translate-x-1/2 translate-y-[calc(80px+50px)] flex-col items-center gap-3 px-4">
          <button id="qrSwitchCamera" class="rounded-full bg-white/80 px-4 py-2 text-sm font-medium text-slate-800 shadow-sm backdrop-blur">Сменить камеру</button>
          <button id="qrToggleTorch" class="rounded-full bg-white/80 px-4 py-2 text-sm font-medium text-slate-800 shadow-sm backdrop-blur">Фонарик</button>
        </div>
      </div>
      <div class="space-y-2">
        <label for="qrManualCode" class="text-sm font-medium text-slate-600 dark:text-slate-300">Ввести код вручную</label>
        <div class="grid grid-cols-1 sm:[grid-template-columns:1fr_auto] gap-2 items-stretch">
          <input id="qrManualCode" type="text" placeholder="Введите код" class="w-full h-12 rounded-2xl border border-slate-200 bg-white px-4 text-sm outline-none transition focus:border-apple-blue focus:ring-2 focus:ring-apple-blue/20 dark:border-slate-700 dark:bg-slate-900" />
          <button id="qrManualSubmit" class="w-full sm:w-32 h-12 rounded-2xl btn-wallet-green px-5 text-sm font-semibold transition">Проверить</button>
        </div>
      </div>
    </section>

    <section class="glass-panel space-y-4 p-6">
      <div class="flex items-center justify-between">
        <h2 class="text-sm font-semibold uppercase text-slate-500">История сканов</h2>
        <button id="qrHistoryClear" class="text-xs font-medium text-apple-blue">Очистить</button>
      </div>
      <ul id="qrHistory" class="space-y-3 text-sm text-slate-600 dark:text-slate-300">
        <li class="text-xs text-slate-400">Пока пусто</li>
      </ul>
    </section>
  </main>

  <%- include('../partials/client/bottom-nav', { active: 'scan' }) %>
  <%- include('../partials/client/voucher-modal') %>

  <script>
    window.__WALLET_SCAN__ = {
      phone: <%- JSON.stringify(phone || null) %>
    };
    window.__WALLET_PUSH_PUBLIC_KEY__ = <%- JSON.stringify(pushPublicKey || null) %>;
  </script>
  <script src="/vendor/zxing-library/index.min.js" data-zxing-core="1" data-ready="1"></script>
  <script src="/vendor/zxing/browser/umd/zxing-browser.min.js" data-zxing-browser="1" data-ready="1"></script>
  <script src="/vendor/jsqr/jsQR.js" data-jsqr="1" data-ready="1"></script>
  <script type="module" src="/js/client-session.js"></script>
  <script type="module" src="/js/client-scan.js"></script>
</body>
</html>
