<!DOCTYPE html>
<html lang="ru">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <meta name="theme-color" content="#007AFF">
    <title>QR Сканер</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="manifest" href="/manifest.json">
    <script>
        tailwind.config = {
            theme: {
                extend: {
                    colors: {
                        'apple-blue': '#007AFF',
                    },
                    fontFamily: {
                        sans: ['-apple-system', 'BlinkMacSystemFont', 'Segoe UI', 'Roboto', 'Helvetica Neue', 'Arial', 'sans-serif'],
                    },
                }
            }
        }
    </script>
</head>
<body class="bg-black min-h-screen font-sans antialiased pb-20">
    <div class="max-w-md mx-auto relative h-screen">
        <!-- Header -->
        <div class="absolute top-0 left-0 right-0 z-10 p-4 bg-gradient-to-b from-black/50 to-transparent">
            <div class="flex items-center justify-between text-white">
                <button onclick="goBack()" class="p-2 hover:bg-white/10 rounded-full transition-colors">
                    <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/>
                    </svg>
                </button>
                <h1 class="text-lg font-semibold">QR Сканер</h1>
                <button onclick="toggleFlash()" class="p-2 hover:bg-white/10 rounded-full transition-colors">
                    <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"/>
                    </svg>
                </button>
            </div>
        </div>

        <!-- Camera View -->
        <div class="relative h-full overflow-hidden">
            <video id="video" class="w-full h-full object-cover" autoplay muted playsinline></video>
            
            <!-- Scanning Overlay -->
            <div class="absolute inset-0 flex items-center justify-center">
                <div class="relative">
                    <!-- Scanning Frame -->
                    <div class="w-64 h-64 border-2 border-white rounded-2xl relative">
                        <!-- Corner indicators -->
                        <div class="absolute top-0 left-0 w-8 h-8 border-l-4 border-t-4 border-apple-blue rounded-tl-lg"></div>
                        <div class="absolute top-0 right-0 w-8 h-8 border-r-4 border-t-4 border-apple-blue rounded-tr-lg"></div>
                        <div class="absolute bottom-0 left-0 w-8 h-8 border-l-4 border-b-4 border-apple-blue rounded-bl-lg"></div>
                        <div class="absolute bottom-0 right-0 w-8 h-8 border-r-4 border-b-4 border-apple-blue rounded-br-lg"></div>
                        
                        <!-- Scanning line animation -->
                        <div class="absolute top-0 left-0 right-0 h-1 bg-apple-blue shadow-lg animate-pulse"></div>
                    </div>
                    
                    <!-- Instruction text -->
                    <p class="text-white text-center mt-4 text-sm opacity-80">
                        Направьте камеру на QR код
                    </p>
                </div>
            </div>

            <!-- No Camera Message -->
            <div id="noCameraMessage" class="absolute inset-0 flex items-center justify-center bg-gray-900 hidden">
                <div class="text-center text-white p-8">
                    <div class="w-16 h-16 bg-gray-700 rounded-full flex items-center justify-center mx-auto mb-4">
                        <svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 9a2 2 0 012-2h.93a2 2 0 001.664-.89l.812-1.22A2 2 0 0110.07 4h3.86a2 2 0 011.664.89l.812 1.22A2 2 0 0018.07 7H19a2 2 0 012 2v9a2 2 0 01-2 2H5a2 2 0 01-2-2V9z"/>
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 13a3 3 0 11-6 0 3 3 0 016 0z"/>
                        </svg>
                    </div>
                    <h3 class="text-lg font-semibold mb-2">Камера недоступна</h3>
                    <p class="text-gray-400 text-sm">Разрешите доступ к камере для сканирования QR кодов</p>
                </div>
            </div>
        </div>

        <!-- Result Modal -->
        <div id="resultModal" class="fixed inset-0 bg-black/50 flex items-center justify-center z-50 hidden">
            <div class="bg-white rounded-2xl p-6 m-4 max-w-sm w-full">
                <div class="text-center">
                    <div class="w-16 h-16 bg-green-100 rounded-full flex items-center justify-center mx-auto mb-4">
                        <svg class="w-8 h-8 text-green-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/>
                        </svg>
                    </div>
                    <h3 class="text-lg font-semibold text-gray-900 mb-2">QR код найден!</h3>
                    <p id="qrResult" class="text-gray-600 text-sm mb-6 break-all"></p>
                    <div class="flex space-x-3">
                        <button onclick="closeResult()" class="flex-1 bg-gray-200 hover:bg-gray-300 text-gray-800 font-semibold py-2 px-4 rounded-lg transition-colors">
                            Закрыть
                        </button>
                        <button onclick="processQR()" class="flex-1 bg-apple-blue hover:bg-blue-600 text-white font-semibold py-2 px-4 rounded-lg transition-colors">
                            Обработать
                        </button>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Bottom Navigation -->
    <div class="fixed bottom-0 left-0 right-0 bg-white border-t border-gray-200 shadow-lg">
        <div class="max-w-md mx-auto px-4">
            <div class="flex justify-around py-2">
                <!-- Wallet Button -->
                <a href="/client/dashboard" class="flex flex-col items-center py-2 px-4 text-gray-400 hover:text-apple-blue transition-colors">
                    <svg class="w-6 h-6 mb-1" fill="currentColor" viewBox="0 0 24 24">
                        <path d="M21 18v1c0 1.1-.9 2-2 2H5c-1.11 0-2-.9-2-2V5c0-1.1.89-2 2-2h14c1.1 0 2 .9 2 2v1h-9c-1.11 0-2 .9-2 2v8c0 1.1.89 2 2 2h9zm-9-2h10V8H12v8zm4-2.5c-.83 0-1.5-.67-1.5-1.5s.67-1.5 1.5-1.5 1.5.67 1.5 1.5-.67 1.5-1.5 1.5z"/>
                    </svg>
                    <span class="text-xs">Кошелёк</span>
                </a>

                <!-- QR Scanner Button -->
                <div class="flex flex-col items-center py-2 px-4 text-apple-blue">
                    <div class="w-12 h-12 bg-apple-blue rounded-full flex items-center justify-center mb-1 shadow-lg">
                        <svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"/>
                        </svg>
                    </div>
                    <span class="text-xs">Сканер</span>
                </div>

                <!-- Profile Button -->
                <a href="/client/profile" class="flex flex-col items-center py-2 px-4 text-gray-400 hover:text-apple-blue transition-colors">
                    <svg class="w-6 h-6 mb-1" fill="currentColor" viewBox="0 0 24 24">
                        <path d="M12 12c2.21 0 4-1.79 4-4s-1.79-4-4-4-4 1.79-4 4 1.79 4 4 4zm0 2c-2.67 0-8 1.34-8 4v2h16v-2c0-2.66-5.33-4-8-4z"/>
                    </svg>
                    <span class="text-xs">Профиль</span>
                </a>
            </div>
        </div>
    </div>

    <script>
        let stream = null;
        let flashEnabled = false;
        let lastQRResult = '';

        // PWA Service Worker Registration
        if ('serviceWorker' in navigator) {
            navigator.serviceWorker.register('/sw.js')
                .then(registration => console.log('ServiceWorker registered'))
                .catch(err => console.log('ServiceWorker registration failed: ', err));
        }

        // Initialize camera on page load
        document.addEventListener('DOMContentLoaded', function() {
            initCamera();
        });

        async function initCamera() {
            try {
                const constraints = {
                    video: { 
                        facingMode: 'environment',
                        width: { ideal: 1280 },
                        height: { ideal: 720 }
                    }
                };

                stream = await navigator.mediaDevices.getUserMedia(constraints);
                const video = document.getElementById('video');
                video.srcObject = stream;

                // Start QR detection (placeholder - you'll need a QR library like jsQR)
                startQRDetection();

            } catch (error) {
                console.error('Camera access error:', error);
                showNoCameraMessage();
            }
        }

        function showNoCameraMessage() {
            document.getElementById('noCameraMessage').classList.remove('hidden');
        }

        function startQRDetection() {
            // Placeholder for QR detection logic
            // You would integrate a library like jsQR here
            console.log('QR detection started');
            
            // Simulate QR detection for demo
            setTimeout(() => {
                if (Math.random() > 0.7) { // Random demo trigger
                    simulateQRFound('https://example.com/voucher/12345');
                }
            }, 3000);
        }

        function simulateQRFound(qrData) {
            lastQRResult = qrData;
            document.getElementById('qrResult').textContent = qrData;
            document.getElementById('resultModal').classList.remove('hidden');
        }

        function closeResult() {
            document.getElementById('resultModal').classList.add('hidden');
            startQRDetection(); // Resume scanning
        }

        function processQR() {
            // Process the QR code result - redirect to voucher page or handle accordingly
            console.log('Processing QR:', lastQRResult);
            alert('Обрабатываем QR код: ' + lastQRResult);
            // Here you would typically redirect to a voucher activation page
            // window.location.href = '/client/voucher/activate?code=' + encodeURIComponent(lastQRResult);
        }

        function toggleFlash() {
            if (!stream) return;
            
            const track = stream.getVideoTracks()[0];
            if (track && track.getCapabilities && track.getCapabilities().torch) {
                flashEnabled = !flashEnabled;
                track.applyConstraints({
                    advanced: [{ torch: flashEnabled }]
                });
            }
        }

        function goBack() {
            if (stream) {
                stream.getTracks().forEach(track => track.stop());
            }
            window.history.back();
        }

        // Clean up camera stream when leaving the page
        window.addEventListener('beforeunload', function() {
            if (stream) {
                stream.getTracks().forEach(track => track.stop());
            }
        });
    </script>
</body>
</html>
