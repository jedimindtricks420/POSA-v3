<!DOCTYPE html>
<html lang="ru">

<head>
    <meta charset="UTF-8">
    <title>Редактировать SKU ManaStore</title>
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="/css/admin.css" rel="stylesheet">
</head>

<body class="bg-slate-50 min-h-screen">
    <%- include('../partials/admin-navbar', { user }) %>

        <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 py-8 pt-20">
            <div class="mb-6">
                <h2 class="text-2xl font-bold text-slate-900">Редактировать SKU ManaStore</h2>
                <p class="mt-1 text-sm text-slate-500">Изменить данные варианта <%= sku.variantId %>
                </p>
            </div>

            <form method="POST" action="/admin/manastore/skus/edit/<%= sku.id %>"
                class="bg-white shadow-sm ring-1 ring-slate-200 sm:rounded-lg p-6">
                <div class="space-y-6">
                    <div>
                        <label for="variantId" class="block text-sm font-medium text-slate-700">Variant ID *</label>
                        <div class="mt-1">
                            <input type="number" name="variantId" id="variantId" required value="<%= sku.variantId %>"
                                class="block w-full rounded-md border-slate-300 shadow-sm focus:border-indigo-500 focus:ring-indigo-500 sm:text-sm font-mono">
                        </div>
                    </div>

                    <div>
                        <label for="sku" class="block text-sm font-medium text-slate-700">SKU (алиас)</label>
                        <div class="mt-1">
                            <input type="text" name="sku" id="sku" value="<%= sku.sku || '' %>"
                                class="block w-full rounded-md border-slate-300 shadow-sm focus:border-indigo-500 focus:ring-indigo-500 sm:text-sm font-mono">
                        </div>
                    </div>

                    <div>
                        <label for="name" class="block text-sm font-medium text-slate-700">Название *</label>
                        <div class="mt-1">
                            <input type="text" name="name" id="name" required value="<%= sku.name %>"
                                class="block w-full rounded-md border-slate-300 shadow-sm focus:border-indigo-500 focus:ring-indigo-500 sm:text-sm">
                        </div>
                    </div>

                    <div>
                        <label for="description" class="block text-sm font-medium text-slate-700">Описание</label>
                        <div class="mt-1">
                            <textarea name="description" id="description" rows="3"
                                class="block w-full rounded-md border-slate-300 shadow-sm focus:border-indigo-500 focus:ring-indigo-500 sm:text-sm"><%= sku.description || '' %></textarea>
                        </div>
                    </div>

                    <div>
                        <label for="category" class="block text-sm font-medium text-slate-700">Категория</label>
                        <div class="mt-1">
                            <input type="text" name="category" id="category" value="<%= sku.category || '' %>"
                                class="block w-full rounded-md border-slate-300 shadow-sm focus:border-indigo-500 focus:ring-indigo-500 sm:text-sm">
                        </div>
                    </div>

                    <div class="grid grid-cols-1 gap-6 sm:grid-cols-3">
                        <div>
                            <label for="costPrice" class="block text-sm font-medium text-slate-700">Закупочная цена
                                (UZS)</label>
                            <div class="mt-1">
                                <input type="number" step="0.01" min="0" name="costPrice" id="costPrice"
                                    value="<%= sku.costPrice || '' %>"
                                    class="block w-full rounded-md border-slate-300 shadow-sm focus:border-indigo-500 focus:ring-indigo-500 sm:text-sm">
                            </div>
                        </div>

                        <div>
                            <label for="retailPrice" class="block text-sm font-medium text-slate-700">Розничная цена
                                (UZS)</label>
                            <div class="mt-1">
                                <input type="number" step="0.01" min="0" name="retailPrice" id="retailPrice"
                                    value="<%= sku.retailPrice || '' %>"
                                    class="block w-full rounded-md border-slate-300 shadow-sm focus:border-indigo-500 focus:ring-indigo-500 sm:text-sm">
                            </div>
                        </div>

                        <div>
                            <label for="faceValue" class="block text-sm font-medium text-slate-700">Face value</label>
                            <div class="mt-1">
                                <input type="number" step="0.01" min="0" name="faceValue" id="faceValue"
                                    value="<%= sku.faceValue || '' %>"
                                    class="block w-full rounded-md border-slate-300 shadow-sm focus:border-indigo-500 focus:ring-indigo-500 sm:text-sm">
                            </div>
                        </div>
                    </div>

                    <div class="flex items-center">
                        <input type="checkbox" name="isActive" id="isActive" <%=sku.isActive ? 'checked' : '' %>
                        class="h-4 w-4 rounded border-slate-300 text-indigo-600 focus:ring-indigo-500">
                        <label for="isActive" class="ml-3 text-sm text-slate-700">
                            Активен
                        </label>
                    </div>
                </div>

                <div class="mt-6 flex items-center justify-end gap-x-3">
                    <a href="/admin/manastore/skus"
                        class="rounded-md bg-white px-3 py-2 text-sm font-semibold text-slate-900 shadow-sm ring-1 ring-inset ring-slate-300 hover:bg-slate-50">
                        Отмена
                    </a>
                    <button type="submit"
                        class="rounded-md bg-indigo-600 px-3 py-2 text-sm font-semibold text-white shadow-sm hover:bg-indigo-700 focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:ring-offset-2">
                        Сохранить изменения
                    </button>
                </div>
            </form>
        </div>
</body>

</html>
