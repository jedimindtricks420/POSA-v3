<!DOCTYPE html>
<html lang="ru">

<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>История продаж</title>
  <link rel="icon" type="image/svg+xml" href="/images/Vector.svg">
  <script src="https://cdn.tailwindcss.com"></script>
  <link rel="stylesheet" href="/css/admin.css" />
</head>

<body class="bg-slate-100 min-h-screen text-slate-800">
  <%- include('../partials/merchant-navbar', { user }) %>

    <% const totalSales=sales.length; %>
      <% const onlineSales=sales.filter(sale=> sale.saleType === 'ONLINE').length; %>
        <% const offlineSales=totalSales - onlineSales; %>
          <% const totalAmount=sales.reduce((sum, sale)=> sum + sale.price, 0); %>
            <% const merchantDebtValue=Number(merchantDebt || 0); %>

              <main class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 pt-24 pb-16 space-y-8">
                <section
                  class="bg-white shadow-sm ring-1 ring-slate-200 rounded-xl p-6 sm:p-8 flex flex-col gap-6 sm:flex-row sm:items-center sm:justify-between">
                  <div>
                    <h1 class="text-2xl sm:text-3xl font-bold text-slate-900">История продаж</h1>
                    <p class="mt-2 text-sm sm:text-base text-slate-500">Отслеживайте каждую транзакцию, следите за
                      динамикой и управляйте своими продажами.</p>
                  </div>
                  <div class="flex flex-col sm:flex-row gap-3">
                    <a href="/merchant/sell"
                      class="inline-flex items-center justify-center gap-2 rounded-lg bg-indigo-600 px-4 py-2 text-sm font-semibold text-white shadow-sm transition hover:bg-indigo-500">
                      <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6v12m6-6H6" />
                      </svg>
                      Новая продажа
                    </a>
                    <a href="/merchant/checkout"
                      class="inline-flex items-center justify-center gap-2 rounded-lg border border-slate-200 bg-white px-4 py-2 text-sm font-semibold text-slate-700 shadow-sm transition hover:border-indigo-300 hover:text-indigo-600">
                      <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                          d="M3 3h2l.4 2M7 13h10l3-7H6.4M7 13L5.4 5M7 13l-2 9m13-9l2 9m-5-4a2 2 0 11-4 0 2 2 0 014 0z" />
                      </svg>
                      Перейти к чеку
                    </a>
                  </div>
                </section>

                <section class="grid grid-cols-1 gap-4 md:grid-cols-2 xl:grid-cols-4">
                  <div class="rounded-xl border border-slate-200 bg-white p-5 shadow-sm">
                    <p class="text-xs uppercase tracking-wide text-slate-400">Всего продаж</p>
                    <p class="mt-2 text-2xl font-semibold text-slate-900">
                      <%= totalSales %>
                    </p>
                  </div>
                  <div class="rounded-xl border border-slate-200 bg-white p-5 shadow-sm">
                    <p class="text-xs uppercase tracking-wide text-slate-400">Каналы продаж</p>
                    <div class="mt-4 space-y-2 text-sm">
                      <div class="flex items-center justify-between">
                        <span class="text-slate-500">Онлайн</span>
                        <span class="font-semibold text-green-600">
                          <%= onlineSales %>
                        </span>
                      </div>
                      <div class="flex items-center justify-between">
                        <span class="text-slate-500">Оффлайн</span>
                        <span class="font-semibold text-slate-900">
                          <%= offlineSales %>
                        </span>
                      </div>
                    </div>
                  </div>
                  <div class="rounded-xl border border-slate-200 bg-white p-5 shadow-sm">
                    <p class="text-xs uppercase tracking-wide text-slate-400">Сумма продаж</p>
                    <p class="mt-2 text-2xl font-semibold text-slate-900">
                      <%= totalAmount.toLocaleString('ru-RU') %> сум
                    </p>
                  </div>
                  <div class="rounded-xl border border-slate-200 bg-white p-5 shadow-sm">
                    <p class="text-xs uppercase tracking-wide text-slate-400">Ваш долг</p>
                    <p class="mt-2 text-2xl font-semibold text-rose-600">
                      <%= merchantDebtValue.toLocaleString('ru-RU') %> сум
                    </p>
                  </div>
                </section>

                <% if (!sales.length) { %>
                  <section
                    class="rounded-xl border border-dashed border-slate-300 bg-white px-8 py-14 text-center shadow-sm">
                    <div
                      class="mx-auto flex h-16 w-16 items-center justify-center rounded-full bg-indigo-100 text-indigo-600">
                      <svg class="h-7 w-7" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                          d="M20 13V6a2 2 0 00-2-2H6a2 2 0 00-2 2v7m16 0v5a2 2 0 01-2 2H6a2 2 0 01-2-2v-5m16 0h-2.586a1 1 0 00-.707.293l-2.414 2.414a1 1 0 01-.707.293H9.414a1 1 0 01-.707-.293L6.293 13.293A1 1 0 005.586 13H4" />
                      </svg>
                    </div>
                    <h2 class="mt-6 text-xl font-semibold text-slate-900">История пока пустая</h2>
                    <p class="mt-2 text-sm text-slate-500">Оформите первую продажу — и она сразу появится здесь.</p>
                    <div class="mt-6 flex flex-col sm:flex-row gap-3 justify-center">
                      <a href="/merchant/sell"
                        class="inline-flex items-center justify-center gap-2 rounded-lg bg-indigo-600 px-5 py-2.5 text-sm font-semibold text-white shadow-sm transition hover:bg-indigo-500">
                        <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6v12m6-6H6" />
                        </svg>
                        Создать продажу
                      </a>
                      <a href="/merchant/sell"
                        class="inline-flex items-center justify-center gap-2 rounded-lg border border-slate-200 bg-white px-5 py-2.5 text-sm font-semibold text-slate-700 shadow-sm transition hover:border-indigo-300 hover:text-indigo-600">
                        <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                            d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
                        </svg>
                        Каталог товаров
                      </a>
                    </div>
                  </section>
                  <% } else { %>
                    <section class="rounded-xl border border-slate-200 bg-white shadow-sm overflow-hidden">
                      <div class="flex items-center justify-between border-b border-slate-200 px-6 py-4">
                        <div>
                          <h2 class="text-lg font-semibold text-slate-900">Транзакции</h2>
                          <p class="text-sm text-slate-500">Список оформленных чеков в обратном хронологическом порядке.
                          </p>
                        </div>
                        <span class="rounded-full bg-slate-100 px-3 py-1 text-xs font-medium text-slate-500">Всего: <%=
                            totalSales %></span>
                      </div>
                      <div class="overflow-x-auto">
                        <table class="min-w-full divide-y divide-slate-200 text-sm">
                          <thead
                            class="bg-slate-50 text-left font-semibold text-slate-500 uppercase tracking-wide text-xs">
                            <tr>
                              <th class="px-6 py-3">#</th>
                              <th class="px-6 py-3">Товар</th>
                              <th class="px-6 py-3">Тип</th>
                              <th class="px-6 py-3">Телефон</th>
                              <th class="px-6 py-3">Ваучер</th>
                              <th class="px-6 py-3">Дата</th>
                              <th class="px-6 py-3 text-right">Сумма</th>
                            </tr>
                          </thead>
                          <tbody class="divide-y divide-slate-100 bg-white">
                            <% sales.forEach((sale, index)=> { %>
                              <tr class="hover:bg-slate-50">
                                <td class="px-6 py-4 text-slate-500 align-top">
                                  <%= index + 1 %>
                                </td>
                                <td class="px-6 py-4">
                                  <p class="font-semibold text-slate-900">
                                    <%= sale.productName %>
                                  </p>
                                  <p class="text-xs text-slate-400 mt-1">ID: <span class="font-mono">#<%= sale.productId
                                        %></span></p>
                                </td>
                                <td class="px-6 py-4">
                                  <% if (sale.saleType==='ONLINE' ) { %>
                                    <span
                                      class="inline-flex items-center gap-1 rounded-full bg-green-100 px-3 py-1 text-xs font-medium text-green-700">
                                      <span class="h-1.5 w-1.5 rounded-full bg-green-500"></span>
                                      Онлайн
                                    </span>
                                    <% } else { %>
                                      <span
                                        class="inline-flex items-center gap-1 rounded-full bg-slate-100 px-3 py-1 text-xs font-medium text-slate-600">
                                        <span class="h-1.5 w-1.5 rounded-full bg-slate-400"></span>
                                        Оффлайн
                                      </span>
                                      <% } %>
                                </td>
                                <td class="px-6 py-4 text-slate-600">
                                  <%= sale.customerPhone || '—' %>
                                </td>
                                <td class="px-6 py-4">
                                  <code
                                    class="rounded-md bg-slate-100 px-2 py-1 text-xs font-mono text-slate-700"><%= sale.maskedVoucher || sale.voucherValue %></code>
                                </td>
                                <td class="px-6 py-4 text-slate-600">
                                  <%= new Date(sale.date).toLocaleString('ru-RU') %>
                                </td>
                                <td class="px-6 py-4 text-right font-semibold text-slate-900">
                                  <%= sale.price.toLocaleString('ru-RU') %> сум
                                </td>
                              </tr>
                              <% }) %>
                          </tbody>
                        </table>
                      </div>
                    </section>
                    <% } %>
              </main>
</body>

</html>