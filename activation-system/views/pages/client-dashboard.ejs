<!DOCTYPE html>
<html lang="ru" class="h-full">
<%- include('../partials/client/head', { title: 'Мои ваучеры' }) %>
<body class="relative min-h-screen bg-wallet-bg px-4 text-slate-900 transition-colors dark:bg-wallet-dark dark:text-slate-100 safe-area-bottom">

  <main class="mx-auto flex w-full max-w-md flex-col gap-6 pb-24 pt-[calc(env(safe-area-inset-top,0px)+2rem)]">
    <section class="glass-panel space-y-6 p-6">
      <div class="flex items-center justify-between">
        <h2 class="text-lg font-semibold">Ваучеры</h2>
        <button id="walletRefresh" class="refresh-btn">Обновить</button>
      </div>
      <div id="walletEmpty" class="hidden rounded-3xl bg-white p-10 text-center text-sm text-slate-500 dark:bg-slate-900 dark:text-slate-300">
        Пока нет ваучеров. Когда появится новый, он отобразится здесь автоматически.
      </div>
      <div id="walletSkeleton">
        <%- include('../partials/client/wallet-skeleton') %>
      </div>
      <div id="walletList" class="hidden space-y-4"></div>
    </section>
  </main>

  <%- include('../partials/client/bottom-nav', { active: 'wallet' }) %>
  <%- include('../partials/client/voucher-modal') %>

  <script>
    window.__WALLET_BOOTSTRAP__ = {
      phone: <%- JSON.stringify(phone || null) %>,
      vouchers: <%- JSON.stringify(vouchers || []) %>
    };
    window.__WALLET_PUSH_PUBLIC_KEY__ = <%- JSON.stringify(pushPublicKey || null) %>;
  </script>
  <script type="module" src="/js/client-session.js"></script>
  <script type="module" src="/js/client-app.js"></script>
</body>
</html>
