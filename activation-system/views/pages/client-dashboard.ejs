<!DOCTYPE html>
<html lang="ru">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <meta name="theme-color" content="#007AFF">
    <title>Digital Wallet</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="manifest" href="/manifest.json">
    <script>
        tailwind.config = {
            theme: {
                extend: {
                    colors: {
                        'apple-blue': '#007AFF',
                    },
                    fontFamily: {
                        sans: ['-apple-system', 'BlinkMacSystemFont', 'Segoe UI', 'Roboto', 'Helvetica Neue', 'Arial', 'sans-serif'],
                    },
                }
            }
        }
    </script>
    <style>
        .glass-effect {
            background: rgba(255, 255, 255, 0.25);
            backdrop-filter: blur(10px);
            border: 1px solid rgba(255, 255, 255, 0.18);
        }
        .voucher-card {
            transition: transform 0.2s ease;
        }
        .voucher-card:hover {
            transform: translateY(-2px);
        }
    </style>
</head>
<body class="bg-gradient-to-br from-blue-50 to-indigo-100 min-h-screen font-sans antialiased">
    <div class="max-w-md mx-auto px-4 py-6">
        <!-- Header -->
        <div class="flex items-center justify-between mb-6">
            <div>
                <h1 class="text-2xl font-bold text-gray-900">Мой кошелёк</h1>
                <p class="text-gray-600 text-sm"><%= phone %></p>
            </div>
            <div class="flex space-x-2">
                <button class="p-2 bg-white rounded-full shadow-md">
                    <svg class="h-5 w-5 text-gray-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 3v1m0 16v1m9-9h-1M4 12H3m15.364 6.364l-.707-.707M6.343 6.343l-.707-.707m12.728 0l-.707.707M6.343 17.657l-.707.707"/>
                    </svg>
                </button>
                <a href="/client/profile" class="p-2 bg-white rounded-full shadow-md">
                    <svg class="h-5 w-5 text-gray-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"/>
                    </svg>
                </a>
            </div>
        </div>

        <!-- Balance Card -->
        <div class="bg-gradient-to-r from-apple-blue to-blue-600 rounded-2xl p-6 text-white shadow-lg mb-6">
            <div class="flex justify-between items-start mb-4">
                <div>
                    <p class="text-blue-100 text-sm">Активные ваучеры</p>
                    <p class="text-3xl font-bold">
                        <%= vouchers.filter(v => v.status === 'ACTIVE').length %>
                    </p>
                </div>
                <div class="text-right">
                    <p class="text-blue-100 text-sm">Общее количество</p>
                    <p class="text-xl font-semibold"><%= vouchers.length %></p>
                </div>
            </div>
            <div class="flex items-center justify-between">
                <div class="glass-effect rounded-lg px-3 py-1">
                    <span class="text-xs font-medium">DIGITAL WALLET</span>
                </div>
                <div>
                    <svg class="h-8 w-8 text-white" fill="currentColor" viewBox="0 0 24 24">
                        <path d="M20 4H4c-1.11 0-1.99.89-1.99 2L2 18c0 1.11.89 2 2 2h16c1.11 0 2-.89 2-2V6c0-1.11-.89-2-2-2zm0 14H4v-6h16v6zm0-10H4V6h16v2z"/>
                    </svg>
                </div>
            </div>
        </div>

        <!-- Quick Actions -->
        <div class="grid grid-cols-2 gap-4 mb-6">
            <a href="/client/qr-scanner" class="bg-white rounded-xl p-4 shadow-md hover:shadow-lg transition-shadow">
                <div class="text-center">
                    <div class="bg-green-100 rounded-full p-3 w-12 h-12 mx-auto mb-2">
                        <svg class="h-6 w-6 text-green-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v1m6 11h2m-6 0h-2v4m0-11v3m0 0h.01M12 12h4.01M16 20h4M4 12h4m12 0h.01M5 8h2a1 1 0 001-1V5a1 1 0 00-1-1H5a1 1 0 00-1 1v2a1 1 0 001 1zm12 0h2a1 1 0 001-1V5a1 1 0 00-1-1h-2a1 1 0 00-1 1v2a1 1 0 001 1zM5 20h2a1 1 0 001-1v-2a1 1 0 00-1-1H5a1 1 0 00-1 1v2a1 1 0 001 1z"/>
                        </svg>
                    </div>
                    <p class="text-sm font-medium text-gray-900">Сканировать</p>
                    <p class="text-xs text-gray-500">QR код</p>
                </div>
            </a>
            
            <a href="/client/profile" class="bg-white rounded-xl p-4 shadow-md hover:shadow-lg transition-shadow">
                <div class="text-center">
                    <div class="bg-blue-100 rounded-full p-3 w-12 h-12 mx-auto mb-2">
                        <svg class="h-6 w-6 text-blue-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"/>
                        </svg>
                    </div>
                    <p class="text-sm font-medium text-gray-900">Профиль</p>
                    <p class="text-xs text-gray-500">Настройки</p>
                </div>
            </a>
        </div>

        <!-- Vouchers List -->
        <div class="mb-6">
            <div class="flex items-center justify-between mb-4">
                <h2 class="text-lg font-semibold text-gray-900">Мои ваучеры</h2>
                <% if (vouchers.length > 0) { %>
                    <span class="text-sm text-gray-500"><%= vouchers.length %> шт.</span>
                <% } %>
            </div>

            <% if (vouchers.length === 0) { %>
                <div class="bg-white rounded-xl p-8 text-center shadow-md">
                    <div class="bg-gray-100 rounded-full p-4 w-16 h-16 mx-auto mb-4">
                        <svg class="h-8 w-8 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20 13V6a2 2 0 00-2-2H6a2 2 0 00-2 2v7m16 0v5a2 2 0 01-2 2H6a2 2 0 01-2-2v-5m16 0h-2.586a1 1 0 00-.707.293l-2.414 2.414a1 1 0 01-.707.293h-3.172a1 1 0 01-.707-.293l-2.414-2.414A1 1 0 006.586 13H4"/>
                        </svg>
                    </div>
                    <h3 class="text-lg font-medium text-gray-900 mb-2">Ваучеров пока нет</h3>
                    <p class="text-gray-500 text-sm mb-4">Купите ваучеры у наших партнеров для их появления в кошельке</p>
                    <a href="/client/qr-scanner" class="inline-flex items-center px-4 py-2 bg-apple-blue text-white text-sm font-medium rounded-lg hover:bg-blue-700 transition-colors">
                        <svg class="h-4 w-4 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v1m6 11h2m-6 0h-2v4m0-11v3m0 0h.01M12 12h4.01M16 20h4M4 12h4m12 0h.01M5 8h2a1 1 0 001-1V5a1 1 0 00-1-1H5a1 1 0 00-1 1v2a1 1 0 001 1zm12 0h2a1 1 0 001-1V5a1 1 0 00-1-1h-2a1 1 0 00-1 1v2a1 1 0 001 1zM5 20h2a1 1 0 001-1v-2a1 1 0 00-1-1H5a1 1 0 00-1 1v2a1 1 0 001 1z"/>
                        </svg>
                        Сканировать QR
                    </a>
                </div>
            <% } else { %>
                <div class="space-y-3">
                    <% vouchers.forEach((voucher, index) => { %>
                        <div class="voucher-card bg-white rounded-xl p-4 shadow-md border border-gray-100">
                            <div class="flex items-center justify-between mb-3">
                                <div class="flex items-center">
                                    <div class="bg-gradient-to-r from-purple-100 to-pink-100 rounded-lg p-2 mr-3">
                                        <svg class="h-5 w-5 text-purple-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 7h.01M7 3h5c.512 0 1.024.195 1.414.586l7 7a2 2 0 010 2.828l-7 7a2 2 0 01-2.828 0l-7-7A1.994 1.994 0 013 12V7a4 4 0 014-4z"/>
                                        </svg>
                                    </div>
                                    <div>
                                        <h3 class="font-medium text-gray-900"><%= voucher.productName %></h3>
                                        <p class="text-xs text-gray-500">
                                            Куплен <%= new Date(voucher.assignedAt).toLocaleDateString('ru-RU') %>
                                        </p>
                                    </div>
                                </div>
                                <div class="text-right">
                                    <% if (voucher.status === 'ACTIVE') { %>
                                        <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-green-100 text-green-800">
                                            <div class="w-1.5 h-1.5 bg-green-400 rounded-full mr-1"></div>
                                            Активен
                                        </span>
                                    <% } else if (voucher.status === 'USED') { %>
                                        <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-gray-100 text-gray-800">
                                            <div class="w-1.5 h-1.5 bg-gray-400 rounded-full mr-1"></div>
                                            Использован
                                        </span>
                                    <% } else { %>
                                        <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-yellow-100 text-yellow-800">
                                            <div class="w-1.5 h-1.5 bg-yellow-400 rounded-full mr-1"></div>
                                            <%= voucher.status %>
                                        </span>
                                    <% } %>
                                </div>
                            </div>
                            
                            <div class="border-t border-gray-100 pt-3">
                                <div class="flex items-center justify-between">
                                    <div>
                                        <p class="text-xs text-gray-500 mb-1">Код ваучера</p>
                                        <code class="text-sm font-mono bg-gray-50 px-2 py-1 rounded border">
                                            <%= voucher.value.substring(0, 8) %>...
                                        </code>
                                    </div>
                                    <% if (voucher.status === 'ACTIVE') { %>
                                        <button onclick="showVoucherDetails('<%= voucher.value %>', '<%= voucher.productName %>')" 
                                                class="px-3 py-1 bg-apple-blue text-white text-xs font-medium rounded-lg hover:bg-blue-700 transition-colors">
                                            Показать
                                        </button>
                                    <% } %>
                                </div>
                            </div>
                        </div>
                    <% }) %>
                </div>
            <% } %>
        </div>

        <!-- Bottom Navigation -->
        <div class="fixed bottom-0 left-0 right-0 bg-white border-t border-gray-200 px-4 py-2">
            <div class="max-w-md mx-auto">
                <div class="flex justify-around items-center">
                    <a href="/client/dashboard" class="flex flex-col items-center py-2 text-apple-blue">
                        <svg class="h-6 w-6" fill="currentColor" viewBox="0 0 24 24">
                            <path d="M10 20v-6h4v6h5v-8h3L12 3 2 12h3v8z"/>
                        </svg>
                        <span class="text-xs mt-1">Главная</span>
                    </a>
                    <a href="/client/qr-scanner" class="flex flex-col items-center py-2 text-gray-400 hover:text-apple-blue">
                        <svg class="h-6 w-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v1m6 11h2m-6 0h-2v4m0-11v3m0 0h.01M12 12h4.01M16 20h4M4 12h4m12 0h.01M5 8h2a1 1 0 001-1V5a1 1 0 00-1-1H5a1 1 0 00-1 1v2a1 1 0 001 1zm12 0h2a1 1 0 001-1V5a1 1 0 00-1-1h-2a1 1 0 00-1 1v2a1 1 0 001 1zM5 20h2a1 1 0 001-1v-2a1 1 0 00-1-1H5a1 1 0 00-1 1v2a1 1 0 001 1z"/>
                        </svg>
                        <span class="text-xs mt-1">Сканер</span>
                    </a>
                    <a href="/client/profile" class="flex flex-col items-center py-2 text-gray-400 hover:text-apple-blue">
                        <svg class="h-6 w-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"/>
                        </svg>
                        <span class="text-xs mt-1">Профиль</span>
                    </a>
                    <a href="/client/logout" class="flex flex-col items-center py-2 text-gray-400 hover:text-red-500">
                        <svg class="h-6 w-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 16l4-4m0 0l-4-4m4 4H7m6 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h4a3 3 0 013 3v1"/>
                        </svg>
                        <span class="text-xs mt-1">Выход</span>
                    </a>
                </div>
            </div>
        </div>
    </div>

    <!-- Modal for voucher details -->
    <div id="voucherModal" class="fixed inset-0 bg-black bg-opacity-50 hidden z-50">
        <div class="flex items-center justify-center min-h-screen px-4">
            <div class="bg-white rounded-2xl p-6 max-w-sm w-full">
                <div class="text-center">
                    <h3 class="text-lg font-semibold text-gray-900 mb-2" id="modalTitle">Детали ваучера</h3>
                    <div class="bg-gray-50 rounded-lg p-4 mb-4">
                        <p class="text-xs text-gray-500 mb-2">Код ваучера</p>
                        <code class="text-lg font-mono break-all" id="modalVoucherCode"></code>
                    </div>
                    <div class="space-y-3">
                        <button onclick="generateQR()" class="w-full bg-apple-blue text-white py-2 px-4 rounded-lg hover:bg-blue-700 transition-colors">
                            Показать QR код
                        </button>
                        <button onclick="copyToClipboard()" class="w-full bg-gray-100 text-gray-700 py-2 px-4 rounded-lg hover:bg-gray-200 transition-colors">
                            Копировать код
                        </button>
                        <button onclick="closeModal()" class="w-full text-gray-500 py-2">
                            Закрыть
                        </button>
                    </div>
                </div>
                <div id="qrContainer" class="mt-4 text-center hidden"></div>
            </div>
        </div>
    </div>

    <script>
        let currentVoucherCode = '';
        let currentVoucherTitle = '';

        function showVoucherDetails(voucherCode, title) {
            currentVoucherCode = voucherCode;
            currentVoucherTitle = title;
            document.getElementById('modalTitle').textContent = title;
            document.getElementById('modalVoucherCode').textContent = voucherCode;
            document.getElementById('voucherModal').classList.remove('hidden');
        }

        function closeModal() {
            document.getElementById('voucherModal').classList.add('hidden');
            document.getElementById('qrContainer').classList.add('hidden');
            document.getElementById('qrContainer').innerHTML = '';
        }

        function copyToClipboard() {
            navigator.clipboard.writeText(currentVoucherCode).then(() => {
                alert('Код ваучера скопирован в буфер обмена!');
            });
        }

        function generateQR() {
            const qrContainer = document.getElementById('qrContainer');
            qrContainer.innerHTML = `
                <p class="text-sm text-gray-500 mb-2">QR код для активации</p>
                <div class="bg-white p-4 rounded-lg border inline-block">
                    <div id="qrcode"></div>
                </div>
            `;
            qrContainer.classList.remove('hidden');
            
            // Here you would integrate with a QR code library
            // For now, just show placeholder
            document.getElementById('qrcode').innerHTML = `
                <div class="w-32 h-32 bg-gray-100 flex items-center justify-center text-xs text-gray-500 text-center">
                    QR код<br>${currentVoucherCode.substring(0, 8)}...
                </div>
            `;
        }

        // Close modal when clicking outside
        document.getElementById('voucherModal').addEventListener('click', function(e) {
            if (e.target === this) {
                closeModal();
            }
        });
    </script>
</body>
</html>
