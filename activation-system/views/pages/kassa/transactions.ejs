<!DOCTYPE html>
<html lang="ru">

<head>
    <meta charset="UTF-8">
    <title>Транзакции кассы — POSA</title>
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <script src="https://cdn.tailwindcss.com"></script>
</head>

<body class="bg-slate-50 min-h-screen">
    <%- include('../../partials/kassa-navbar', { user, activeNav: 'transactions' }) %>

        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
            <h1 class="text-2xl font-bold text-slate-900 mb-6">Транзакции</h1>

            <!-- Фильтры -->
            <form method="GET"
                class="bg-white rounded-lg shadow-sm ring-1 ring-slate-200 p-4 mb-6 flex items-end gap-4">
                <div>
                    <label class="block text-sm font-medium text-slate-700 mb-1">Вендор</label>
                    <select name="vendor" class="rounded-md border-slate-300 text-sm">
                        <option value="">Все</option>
                        <% vendors.forEach(v=> { %>
                            <option value="<%= v.id %>" <%=filters.vendor==v.id ? 'selected' : '' %>><%= v.name %>
                            </option>
                            <% }) %>
                    </select>
                </div>
                <div>
                    <label class="block text-sm font-medium text-slate-700 mb-1">Статус</label>
                    <select name="status" class="rounded-md border-slate-300 text-sm">
                        <option value="">Все</option>
                        <option value="PENDING" <%=filters.status==='PENDING' ? 'selected' : '' %>>Ожидает</option>
                        <option value="COMPLETED" <%=filters.status==='COMPLETED' ? 'selected' : '' %>>Завершена
                        </option>
                    </select>
                </div>
                <button type="submit"
                    class="inline-flex items-center rounded-md bg-indigo-600 px-3 py-2 text-sm font-semibold text-white hover:bg-indigo-500">Фильтр</button>
            </form>

            <!-- Таблица -->
            <div class="bg-white rounded-lg shadow-sm ring-1 ring-slate-200 overflow-hidden">
                <table class="min-w-full divide-y divide-slate-200">
                    <thead class="bg-slate-50">
                        <tr>
                            <th class="px-6 py-3 text-left text-xs font-medium text-slate-500 uppercase">ID</th>
                            <th class="px-6 py-3 text-left text-xs font-medium text-slate-500 uppercase">Товар</th>
                            <th class="px-6 py-3 text-left text-xs font-medium text-slate-500 uppercase">Вендор</th>
                            <th class="px-6 py-3 text-left text-xs font-medium text-slate-500 uppercase">Сумма</th>
                            <th class="px-6 py-3 text-left text-xs font-medium text-slate-500 uppercase">Доля платформы
                            </th>
                            <th class="px-6 py-3 text-left text-xs font-medium text-slate-500 uppercase">К выплате
                                вендору
                            </th>
                            <th class="px-6 py-3 text-left text-xs font-medium text-slate-500 uppercase">Статус</th>
                            <th class="px-6 py-3 text-left text-xs font-medium text-slate-500 uppercase">Дата</th>
                        </tr>
                    </thead>
                    <tbody class="divide-y divide-slate-200">
                        <% transactions.forEach(t=> { %>
                            <tr>
                                <td class="px-6 py-4 text-sm text-slate-900">
                                    <%= t.id %>
                                </td>
                                <td class="px-6 py-4 text-sm text-slate-600">
                                    <%= t.productName %>
                                </td>
                                <td class="px-6 py-4 text-sm text-slate-600">
                                    <%= t.vendor?.name || '-' %>
                                </td>
                                <td class="px-6 py-4 text-sm font-medium">
                                    <%= t.price.toLocaleString('ru-RU') %>
                                </td>
                                <td class="px-6 py-4 text-sm text-indigo-600">
                                    <%= t.kassaDebt.toLocaleString('ru-RU') %>
                                </td>
                                <td class="px-6 py-4 text-sm text-amber-600">
                                    <%= t.vendorDebt.toLocaleString('ru-RU') %>
                                </td>
                                <td class="px-6 py-4 text-sm">
                                    <span class="inline-flex items-center rounded-full px-2 py-0.5 text-xs font-medium
                <%= t.status === 'COMPLETED' ? 'bg-emerald-100 text-emerald-700' : 'bg-amber-100 text-amber-700' %>">
                                        <%= t.status==='COMPLETED' ? 'Выплачено' : 'Ожидает выплаты' %>
                                    </span>
                                </td>
                                <td class="px-6 py-4 text-sm text-slate-500">
                                    <%= t.createdAt.toLocaleDateString('ru-RU') %>
                                </td>
                            </tr>
                            <% }) %>
                                <% if (transactions.length===0) { %>
                                    <tr>
                                        <td colspan="8" class="px-6 py-8 text-center text-sm text-slate-400">Нет
                                            транзакций</td>
                                    </tr>
                                    <% } %>
                    </tbody>
                </table>
            </div>

            <!-- Пагинация -->
            <% if (totalPages> 1) { %>
                <div class="mt-4 flex justify-center gap-2">
                    <% for (let i=1; i <=totalPages; i++) { %>
                        <a href="?page=<%= i %>&vendor=<%= filters.vendor || '' %>&status=<%= filters.status || '' %>"
                            class="px-3 py-1 rounded text-sm <%= i === page ? 'bg-indigo-600 text-white' : 'bg-white text-slate-700 ring-1 ring-slate-200 hover:bg-slate-50' %>">
                            <%= i %>
                        </a>
                        <% } %>
                </div>
                <% } %>

                    <p class="mt-2 text-sm text-slate-500 text-center">Всего: <%= total %> транзакций</p>
        </div>
</body>

</html>