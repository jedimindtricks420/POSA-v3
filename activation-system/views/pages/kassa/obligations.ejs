<!DOCTYPE html>
<html lang="ru">

<head>
    <meta charset="UTF-8">
    <title>Обязательства — POSA</title>
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <script src="https://cdn.tailwindcss.com"></script>
</head>

<body class="bg-slate-50 min-h-screen">
    <%- include('../../partials/kassa-navbar', { user, activeNav: 'obligations' }) %>

        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
            <h1 class="text-2xl font-bold text-slate-900 mb-6">Взаиморасчёты с вендорами</h1>

            <!-- Статистика по вендорам -->
            <div class="bg-white rounded-lg shadow-sm ring-1 ring-slate-200 mb-8">
                <div class="px-6 py-4 border-b border-slate-200">
                    <h2 class="text-lg font-semibold text-slate-900">Статистика по вендорам</h2>
                </div>
                <table class="min-w-full divide-y divide-slate-200">
                    <thead class="bg-slate-50">
                        <tr>
                            <th class="px-6 py-3 text-left text-xs font-medium text-slate-500 uppercase">Вендор</th>
                            <th class="px-6 py-3 text-left text-xs font-medium text-slate-500 uppercase">Продажи</th>
                            <th class="px-6 py-3 text-left text-xs font-medium text-slate-500 uppercase">Сумма</th>
                            <th class="px-6 py-3 text-left text-xs font-medium text-slate-500 uppercase">Доход платформы
                            </th>
                            <th class="px-6 py-3 text-left text-xs font-medium text-slate-500 uppercase">К выплате
                                вендору
                            </th>
                            <th class="px-6 py-3 text-left text-xs font-medium text-slate-500 uppercase">Баланс вендора
                            </th>
                        </tr>
                    </thead>
                    <tbody class="divide-y divide-slate-200">
                        <% vendorStats.forEach(vs=> { %>
                            <tr>
                                <td class="px-6 py-4 text-sm font-medium text-slate-900">
                                    <%= vs.vendorName %>
                                </td>
                                <td class="px-6 py-4 text-sm text-slate-600">
                                    <%= vs._count.id %>
                                </td>
                                <td class="px-6 py-4 text-sm text-slate-900">
                                    <%= Number(vs._sum.price || 0).toLocaleString('ru-RU') %>
                                </td>
                                <td class="px-6 py-4 text-sm text-indigo-600">
                                    <%= Number(vs._sum.kassaDebt || 0).toLocaleString('ru-RU') %>
                                </td>
                                <td class="px-6 py-4 text-sm text-amber-600">
                                    <%= Number(vs._sum.vendorDebt || 0).toLocaleString('ru-RU') %>
                                </td>
                                <td class="px-6 py-4 text-sm text-slate-600">
                                    <%= typeof vs.vendorBalance==='number' ? vs.vendorBalance.toLocaleString('ru-RU')
                                        : '0' %>
                                </td>
                            </tr>
                            <% }) %>
                                <% if (vendorStats.length===0) { %>
                                    <tr>
                                        <td colspan="6" class="px-6 py-8 text-center text-sm text-slate-400">Нет данных
                                        </td>
                                    </tr>
                                    <% } %>
                    </tbody>
                </table>
            </div>

            <!-- Корректировки -->
            <div class="bg-white rounded-lg shadow-sm ring-1 ring-slate-200">
                <div class="px-6 py-4 border-b border-slate-200">
                    <h2 class="text-lg font-semibold text-slate-900">Последние корректировки</h2>
                </div>
                <table class="min-w-full divide-y divide-slate-200">
                    <thead class="bg-slate-50">
                        <tr>
                            <th class="px-6 py-3 text-left text-xs font-medium text-slate-500 uppercase">Дата</th>
                            <th class="px-6 py-3 text-left text-xs font-medium text-slate-500 uppercase">Сумма</th>
                            <th class="px-6 py-3 text-left text-xs font-medium text-slate-500 uppercase">Причина</th>
                        </tr>
                    </thead>
                    <tbody class="divide-y divide-slate-200">
                        <% adjustments.forEach(a=> { %>
                            <tr>
                                <td class="px-6 py-4 text-sm text-slate-500">
                                    <%= a.createdAt.toLocaleDateString('ru-RU') %>
                                </td>
                                <td
                                    class="px-6 py-4 text-sm font-medium <%= a.amount >= 0 ? 'text-emerald-600' : 'text-red-600' %>">
                                    <%= a.amount>= 0 ? '+' : '' %><%= a.amount.toLocaleString('ru-RU') %>
                                </td>
                                <td class="px-6 py-4 text-sm text-slate-600">
                                    <%= a.reason || '—' %>
                                </td>
                            </tr>
                            <% }) %>
                                <% if (adjustments.length===0) { %>
                                    <tr>
                                        <td colspan="3" class="px-6 py-8 text-center text-sm text-slate-400">Нет
                                            корректировок</td>
                                    </tr>
                                    <% } %>
                    </tbody>
                </table>
            </div>
        </div>
</body>

</html>