<!DOCTYPE html>
<html lang="ru">

<head>
    <meta charset="UTF-8">
    <title>Добавить магазин</title>
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="/css/admin.css" rel="stylesheet">
</head>

<body class="bg-slate-50 min-h-screen">
    <%- include('../partials/admin-navbar', { user }) %>

        <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 py-8 pt-20">
            <div class="mb-6">
                <h2 class="text-2xl font-bold text-slate-900">Добавить магазин активации</h2>
                <p class="mt-1 text-sm text-slate-500">Создайте новый магазин для активации ваучеров</p>
            </div>

            <% if (error) { %>
                <div class="rounded-md bg-red-50 p-4 mb-6">
                    <div class="flex">
                        <div class="flex-shrink-0">
                            <svg class="h-5 w-5 text-red-400" viewBox="0 0 20 20" fill="currentColor">
                                <path fill-rule="evenodd"
                                    d="M10 18a8 8 0 100-16 8 8 0 000 16zM8.707 7.293a1 1 0 00-1.414 1.414L8.586 10l-1.293 1.293a1 1 0 101.414 1.414L10 11.414l1.293 1.293a1 1 0 001.414-1.414L11.414 10l1.293-1.293a1 1 0 00-1.414-1.414L10 8.586 8.707 7.293z"
                                    clip-rule="evenodd" />
                            </svg>
                        </div>
                        <div class="ml-3">
                            <p class="text-sm font-medium text-red-800">
                                <%= error %>
                            </p>
                        </div>
                    </div>
                </div>
                <% } %>

                    <form method="POST" action="/admin/stores/add"
                        class="bg-white shadow-sm ring-1 ring-slate-200 sm:rounded-lg p-6">
                        <div class="space-y-6">
                            <div>
                                <label for="slug" class="block text-sm font-medium text-slate-700">Slug (URL)</label>
                                <div class="mt-1">
                                    <input type="text" name="slug" id="slug" required
                                        class="block w-full rounded-md border-slate-300 shadow-sm focus:border-indigo-500 focus:ring-indigo-500 sm:text-sm"
                                        placeholder="roblox">
                                </div>
                                <p class="mt-1 text-xs text-slate-500">Будет доступен по адресу: /slug (например:
                                    /roblox)</p>
                            </div>

                            <div>
                                <label for="name" class="block text-sm font-medium text-slate-700">Название</label>
                                <div class="mt-1">
                                    <input type="text" name="name" id="name" required
                                        class="block w-full rounded-md border-slate-300 shadow-sm focus:border-indigo-500 focus:ring-indigo-500 sm:text-sm"
                                        placeholder="Roblox">
                                </div>
                            </div>

                            <div>
                                <label class="block text-sm font-medium text-slate-700 mb-2">Продукты</label>
                                <div class="space-y-2 max-h-64 overflow-y-auto border border-slate-200 rounded-md p-3">
                                    <% products.forEach(product=> { %>
                                        <div class="flex items-center">
                                            <input type="checkbox" name="productIds" value="<%= product.id %>"
                                                id="product-<%= product.id %>"
                                                class="h-4 w-4 rounded border-slate-300 text-indigo-600 focus:ring-indigo-500">
                                            <label for="product-<%= product.id %>" class="ml-3 text-sm text-slate-700">
                                                <%= product.name %> (<%= product.vendor.name %>)
                                            </label>
                                        </div>
                                        <% }) %>
                                </div>
                                <p class="mt-1 text-xs text-slate-500">Выберите товары, которые можно активировать в
                                    этом магазине</p>
                            </div>

                            <div class="flex items-center">
                                <input type="checkbox" name="isActive" id="isActive" checked
                                    class="h-4 w-4 rounded border-slate-300 text-indigo-600 focus:ring-indigo-500">
                                <label for="isActive" class="ml-3 text-sm text-slate-700">
                                    Активен
                                </label>
                            </div>
                        </div>

                        <div class="mt-6 flex items-center justify-end gap-x-3">
                            <a href="/admin/stores"
                                class="rounded-md bg-white px-3 py-2 text-sm font-semibold text-slate-900 shadow-sm ring-1 ring-inset ring-slate-300 hover:bg-slate-50">
                                Отмена
                            </a>
                            <button type="submit"
                                class="rounded-md bg-indigo-600 px-3 py-2 text-sm font-semibold text-white shadow-sm hover:bg-indigo-700 focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:ring-offset-2">
                                Создать магазин
                            </button>
                        </div>
                    </form>
        </div>
</body>

</html>