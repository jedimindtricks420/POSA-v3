<!DOCTYPE html>
<html lang="ru" class="h-full">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover, maximum-scale=1" />
  <meta name="theme-color" content="#9EE52D" />
  <meta name="apple-mobile-web-app-capable" content="yes" />
  <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent" />
  <title><%= product.name %> — Namo Wallet</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/css/client.css" />
  <link rel="stylesheet" href="/css/client-overrides.css" />
</head>
<body class="min-h-screen bg-wallet-bg px-4 text-slate-900 transition-colors safe-area-y">

  <main class="mx-auto flex min-h-screen w-full max-w-md flex-col justify-center space-y-4 py-8">

    <!-- Логотип -->
    <header class="flex flex-col items-center space-y-3">
      <div class="h-14 w-14 overflow-hidden rounded-2xl bg-white p-2 shadow-sm ring-1 ring-slate-100/60">
        <img src="/wallet/icons/vec-icon.png" alt="Namo Wallet" class="h-full w-full object-contain" width="56" height="56" loading="lazy" onerror="this.style.display='none';this.parentElement.innerHTML='<span class=\'text-2xl\'>💳</span>'"/>
      </div>
      <p class="text-xs text-slate-500">wallet.namo.uz</p>
    </header>

    <!-- Карточка товара -->
    <section class="glass-panel space-y-6 p-6">

      <!-- Вендор и товар -->
      <div class="text-center space-y-2">
        <p class="text-xs uppercase tracking-wider text-slate-500"><%= product.vendor ? product.vendor.name : 'Товар' %></p>
        <h1 class="text-xl font-semibold text-slate-900"><%= product.name %></h1>
      </div>

      <hr class="border-slate-200">

      <!-- Цена -->
      <div class="text-center">
        <p class="text-xs text-slate-500 mb-1">Стоимость</p>
        <p class="text-3xl font-bold text-slate-900"><%= product.price.toLocaleString('ru-RU') %> <span class="text-lg font-semibold text-slate-500">сум</span></p>
      </div>

      <hr class="border-slate-200">

      <!-- Продавец -->
      <div class="flex items-center justify-between text-sm">
        <span class="text-slate-500">Продавец</span>
        <span class="font-medium text-slate-700"><%= merchant.username %></span>
      </div>

      <!-- Кнопка -->
      <% if (hasVouchers) { %>
        <a href="/pay/<%= link.token %>/checkout"
          class="block w-full rounded-2xl btn-wallet-green px-4 py-3.5 text-center text-sm font-semibold transition">
          Купить
        </a>
      <% } else { %>
        <button disabled
          class="block w-full rounded-2xl bg-slate-200 px-4 py-3.5 text-sm font-semibold text-slate-400 cursor-not-allowed">
          Временно недоступен
        </button>
        <p class="text-center text-xs text-slate-400">Ваучеры закончились</p>
      <% } %>
    </section>

    <p class="text-center text-xs text-slate-400">Безопасная оплата через Namo Wallet</p>
  </main>

</body>
</html>