<!DOCTYPE html>
<html lang="ru">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Настройки вендора</title>
  <script src="https://cdn.tailwindcss.com"></script>
  <link rel="stylesheet" href="/css/admin.css" />
</head>
<body class="bg-slate-100 min-h-screen text-slate-800">
  <%- include('../../partials/vendor-navbar', { user, active: 'settings' }) %>

  <main class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 pt-24 pb-16 space-y-10">
    <% if (typeof error !== 'undefined' && error) { %>
      <div class="rounded-xl border border-red-200 bg-red-50 px-4 py-3 text-sm text-red-600 shadow-sm">
        <div class="flex items-start gap-2">
          <svg class="h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-2.5L13.732 4c-.77-.833-1.732-.833-2.5 0L4.314 15.5c-.77.833.192 2.5 1.732 2.5z" />
          </svg>
          <span><%= error %></span>
        </div>
      </div>
    <% } %>
    <section class="rounded-2xl border border-slate-200 bg-white shadow-sm p-6 sm:p-8 space-y-6">
      <header class="space-y-2">
        <h1 class="text-2xl font-bold text-slate-900">Профиль вендора</h1>
        <p class="text-sm text-slate-500">Информация отображается в режиме чтения. Изменения выполняет администратор платформы.</p>
      </header>
      <div class="grid grid-cols-1 gap-4 sm:grid-cols-2">
        <div class="rounded-xl border border-slate-200 bg-slate-50 px-4 py-3">
          <p class="text-xs uppercase tracking-wide text-slate-400">Название</p>
          <p class="mt-1 text-lg font-semibold text-slate-900"><%= vendor.name %></p>
        </div>
        <div class="rounded-xl border border-slate-200 bg-slate-50 px-4 py-3">
          <p class="text-xs uppercase tracking-wide text-slate-400">Баланс</p>
          <p class="mt-1 text-lg font-semibold text-slate-900"><%= vendor.balance.toLocaleString('ru-RU') %> сум</p>
        </div>
        <div class="rounded-xl border border-slate-200 bg-slate-50 px-4 py-3">
          <p class="text-xs uppercase tracking-wide text-slate-400">Категория</p>
          <p class="mt-1 text-sm font-medium text-slate-900"><%= vendor.category || '—' %></p>
        </div>
        <div class="rounded-xl border border-slate-200 bg-slate-50 px-4 py-3">
          <p class="text-xs uppercase tracking-wide text-slate-400">Тип продуктов</p>
          <p class="mt-1 text-sm font-medium text-slate-900"><%= vendor.productType || '—' %></p>
        </div>
        <div class="rounded-xl border border-slate-200 bg-slate-50 px-4 py-3">
          <p class="text-xs uppercase tracking-wide text-slate-400">Комиссия по умолчанию</p>
          <p class="mt-1 text-sm font-medium text-slate-900"><%= vendor.defaultCommissionPercent %> %</p>
        </div>
      </div>
      <% if (vendor.description) { %>
        <div class="rounded-xl border border-slate-200 bg-white px-4 py-3">
          <p class="text-xs uppercase tracking-wide text-slate-400">Описание</p>
          <p class="mt-1 text-sm text-slate-600"><%= vendor.description %></p>
        </div>
      <% } %>
    </section>

    <section class="rounded-2xl border border-slate-200 bg-white shadow-sm">
      <div class="flex items-center justify-between border-b border-slate-200 px-6 py-4">
        <h2 class="text-lg font-semibold text-slate-900">Пользователи вендора</h2>
        <span class="rounded-full bg-slate-100 px-3 py-1 text-xs font-medium text-slate-500">Всего: <%= users.length %></span>
      </div>
      <% if (!users.length) { %>
        <p class="px-6 py-8 text-sm text-slate-500">Пользователи не назначены. Обратитесь к администратору для добавления аккаунтов.</p>
      <% } else { %>
        <div class="overflow-x-auto">
          <table class="min-w-full divide-y divide-slate-200 text-sm">
            <thead class="bg-slate-50 text-left uppercase tracking-wide text-xs text-slate-400">
              <tr>
                <th class="px-6 py-3">Логин</th>
                <th class="px-6 py-3">Примечание</th>
              </tr>
            </thead>
            <tbody class="divide-y divide-slate-100 bg-white">
              <% users.forEach((u) => { %>
                <tr class="hover:bg-slate-50">
                  <td class="px-6 py-3 font-medium text-slate-900"><%= u.username %></td>
                  <td class="px-6 py-3 text-slate-600"><%= u.note || '—' %></td>
                </tr>
              <% }) %>
            </tbody>
          </table>
        </div>
      <% } %>
    </section>

    <section class="rounded-2xl border border-slate-200 bg-white shadow-sm p-6 sm:p-8 space-y-4">
      <header class="flex items-center justify-between">
        <h2 class="text-lg font-semibold text-slate-900">Превью шаблона чека</h2>
        <span class="text-xs uppercase tracking-wide text-slate-400">Только чтение</span>
      </header>
      <% if (!previewHtml) { %>
        <div class="rounded-xl border border-dashed border-slate-300 bg-slate-50 px-6 py-8 text-sm text-slate-500">
          Шаблон чека ещё не настроен. Обратитесь к администратору.
        </div>
      <% } else { %>
        <% const escapedPreview = previewHtml.replace(/&/g, '&amp;').replace(/"/g, '&quot;'); %>
        <iframe title="Предпросмотр" class="w-full h-[420px] rounded-xl border border-slate-200 shadow-sm bg-slate-50" srcdoc="<%= escapedPreview %>"></iframe>
      <% } %>
    </section>
  </main>
</body>
</html>
