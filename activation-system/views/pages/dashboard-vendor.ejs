<%- include('../partials/vendor-navbar', { user }) %>

<div class="container py-4">
  <h2 class="mb-3">Активация ваучера</h2>

  <% if (error) { %>
    <div class="alert alert-danger"><%= error %></div>
  <% } %>
  <% if (success) { %>
    <div class="alert alert-success"><%= success %></div>
  <% } %>

  <form method="POST" action="/vendor/activate" class="card p-4">
    <div class="mb-3">
      <label for="code" class="form-label">Введите код ваучера:</label>
      <input type="text" name="code" id="code" class="form-control" required />
    </div>
    <button class="btn btn-primary">Активировать</button>
  </form>
</div>
