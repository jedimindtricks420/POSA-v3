<!DOCTYPE html>
<html lang="ru">

<head>
    <meta charset="UTF-8">
    <title>Dr.Web - Товары и привязка SKU</title>
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="/css/admin.css" rel="stylesheet">
</head>

<body class="bg-slate-50 min-h-screen">
    <%- include('../partials/admin-navbar', { user }) %>

        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8 pt-20">
            <div class="md:flex md:items-center md:justify-between mb-6">
                <div class="min-w-0 flex-1">
                    <h2 class="text-2xl font-bold leading-7 text-slate-900 sm:truncate sm:text-3xl sm:tracking-tight">
                        Dr.Web - Товары и привязка SKU
                    </h2>
                    <p class="mt-1 text-sm text-slate-500">
                        Привяжите SKU из каталога Dr.Web к вашим товарам
                    </p>
                </div>
                <div class="mt-4 flex md:ml-4 md:mt-0">
                    <a href="/admin/drweb"
                        class="inline-flex items-center rounded-md bg-white px-3 py-2 text-sm font-semibold text-slate-900 shadow-sm ring-1 ring-inset ring-slate-300 hover:bg-slate-50">
                        <svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                                d="M11 17l-5-5m0 0l5-5m-5 5h12" />
                        </svg>
                        Назад
                    </a>
                </div>
            </div>

            <div class="bg-white shadow-sm ring-1 ring-slate-200 sm:rounded-lg overflow-x-auto">
                <table class="min-w-full divide-y divide-slate-200">
                    <thead>
                        <tr>
                            <th scope="col"
                                class="py-3.5 pl-4 pr-3 text-left text-sm font-semibold text-slate-900 sm:pl-6">Товар
                            </th>
                            <th scope="col" class="px-3 py-3.5 text-left text-sm font-semibold text-slate-900">Цена</th>
                            <th scope="col" class="px-3 py-3.5 text-left text-sm font-semibold text-slate-900">Магазин
                            </th>
                            <th scope="col" class="px-3 py-3.5 text-left text-sm font-semibold text-slate-900">Текущий
                                SKU</th>
                            <th scope="col" class="px-3 py-3.5 text-left text-sm font-semibold text-slate-900">Привязать
                                SKU</th>
                            <th scope="col" class="relative py-3.5 pl-3 pr-4 sm:pr-6">
                                <span class="sr-only">Действия</span>
                            </th>
                        </tr>
                    </thead>
                    <tbody class="divide-y divide-slate-200 bg-white">
                        <% products.forEach(product=> { %>
                            <tr class="hover:bg-slate-50 transition-colors duration-150">
                                <td class="whitespace-nowrap py-4 pl-4 pr-3 text-sm font-medium text-slate-900 sm:pl-6">
                                    <%= product.name %>
                                </td>
                                <td class="whitespace-nowrap px-3 py-4 text-sm text-slate-600">
                                    <span class="font-mono">
                                        <%= Number(product.price).toLocaleString('ru-RU') %>
                                    </span> сум
                                </td>
                                <td class="whitespace-nowrap px-3 py-4 text-sm text-slate-600">
                                    <% if (product.store) { %>
                                        <span
                                            class="inline-flex items-center rounded-md bg-blue-50 px-2 py-1 text-xs font-medium text-blue-700 ring-1 ring-inset ring-blue-700/10">
                                            /<%= product.store.slug %>
                                        </span>
                                        <% } else { %>
                                            <span class="text-slate-400">—</span>
                                            <% } %>
                                </td>
                                <td class="whitespace-nowrap px-3 py-4 text-sm">
                                    <% if (product.drwebSku) { %>
                                        <span
                                            class="inline-flex items-center rounded-md bg-green-50 px-2 py-1 text-xs font-medium text-green-700 ring-1 ring-inset ring-green-600/20 font-mono">
                                            <%= product.drwebSku %>
                                        </span>
                                        <% } else { %>
                                            <span
                                                class="inline-flex items-center rounded-md bg-yellow-50 px-2 py-1 text-xs font-medium text-yellow-800 ring-1 ring-inset ring-yellow-600/20">
                                                Не привязан
                                            </span>
                                            <% } %>
                                </td>
                                <td class="whitespace-nowrap px-3 py-4 text-sm">
                                    <form method="POST" action="/admin/drweb/products/<%= product.id %>/bind"
                                        class="flex items-center gap-2">
                                        <select name="drwebSku"
                                            class="block w-full rounded-md border-slate-300 shadow-sm focus:border-indigo-500 focus:ring-indigo-500 text-xs">
                                            <option value="">Не привязан</option>
                                            <% skus.forEach(sku=> { %>
                                                <option value="<%= sku.sku %>" <%=product.drwebSku===sku.sku
                                                    ? 'selected' : '' %>>
                                                    <%= sku.sku %> - <%= sku.name %>
                                                </option>
                                                <% }) %>
                                        </select>
                                        <button type="submit"
                                            class="inline-flex items-center rounded-md bg-indigo-600 px-2 py-1 text-xs font-semibold text-white shadow-sm hover:bg-indigo-700">
                                            Сохранить
                                        </button>
                                    </form>
                                </td>
                                <td
                                    class="relative whitespace-nowrap py-4 pl-3 pr-4 text-right text-sm font-medium sm:pr-6">
                                    <a href="/admin/edit-product/<%= product.id %>"
                                        class="text-indigo-600 hover:text-indigo-900">
                                        Редактировать
                                    </a>
                                </td>
                            </tr>
                            <% }) %>
                    </tbody>
                </table>

                <% if (products.length===0) { %>
                    <div class="text-center py-12">
                        <svg class="mx-auto h-12 w-12 text-slate-400" fill="none" stroke="currentColor"
                            viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1"
                                d="M20 7l-8-4-8 4m16 0l-8 4m8-4v10l-8 4m0-10L4 7m8 4v10M4 7v10l8 4" />
                        </svg>
                        <h3 class="mt-2 text-sm font-semibold text-slate-900">Нет товаров Dr.Web</h3>
                        <p class="mt-1 text-sm text-slate-500">Создайте товары с вендором Dr.Web в разделе "Товары".</p>
                    </div>
                    <% } %>
            </div>
        </div>
</body>

</html>