<!DOCTYPE html>
<html lang="ru">
<head>
  <meta charset="UTF-8">
  <title>Продажи | Admin Panel</title>
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <script src="https://cdn.tailwindcss.com"></script>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
  <link href="/css/admin.css" rel="stylesheet">
</head>
<body class="bg-slate-50 min-h-screen font-[Inter]">
  <%- include('../partials/admin-navbar', { user }) %>

  <% const statsData = stats || { totalSales: 0, onlineSales: 0, offlineSales: 0, totalAmount: 0, averageCheck: 0, platformRevenue: 0, averagePlatformRevenue: 0, vendorPayoutTotal: 0, vendorOutstanding: 0, merchantCommission: 0, averageMerchantCommission: 0 }; %>
  <% const formatCurrency = (value) => Number(value || 0).toLocaleString('ru-RU', { minimumFractionDigits: 2 }); %>
  <% const normalizePath = (val) => (val || '').replace(/\\/g, '/'); %>

  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8 pt-20">
    <div class="md:flex md:items-center md:justify-between mb-8">
      <div>
        <h1 class="text-3xl font-bold tracking-tight text-slate-900">Дашборд продаж</h1>
        <p class="mt-2 text-sm text-slate-500">Актуальные цифры по обороту, заработку платформы и распределению средств</p>
      </div>
    </div>

    <div class="grid grid-cols-1 gap-4 lg:grid-cols-4 mb-8">
      <div class="rounded-2xl bg-white p-5 shadow ring-1 ring-slate-100">
        <p class="text-sm font-medium text-slate-500">Количество продаж</p>
        <p class="mt-2 text-3xl font-semibold text-slate-900"><%= statsData.totalSales %></p>
        <p class="mt-2 text-xs uppercase tracking-widest text-slate-400">на сумму <%= formatCurrency(statsData.totalAmount) %> сум</p>
        <div class="mt-4 flex items-center justify-between text-xs font-semibold text-slate-600">
          <span class="flex items-center gap-1"><span class="h-1.5 w-1.5 rounded-full bg-green-500"></span> Онлайн: <%= statsData.onlineSales %></span>
          <span class="flex items-center gap-1"><span class="h-1.5 w-1.5 rounded-full bg-slate-400"></span> Оффлайн: <%= statsData.offlineSales %></span>
        </div>
      </div>

      <div class="rounded-2xl bg-white p-5 shadow ring-1 ring-slate-100">
        <p class="text-sm font-medium text-slate-500">Доход платформы</p>
        <p class="mt-2 text-3xl font-semibold text-indigo-600"><%= formatCurrency(statsData.platformRevenue) %></p>
        <p class="text-xs uppercase tracking-widest text-slate-400">сум</p>
        <p class="mt-4 text-sm text-slate-500">Средний чек: <span class="font-semibold text-slate-900"><%= formatCurrency(statsData.averageCheck) %></span> сум</p>
        <p class="text-sm text-slate-500">Средний доход: <span class="font-semibold text-slate-900"><%= formatCurrency(statsData.averagePlatformRevenue) %></span> сум</p>
      </div>

      <div class="rounded-2xl bg-white p-5 shadow ring-1 ring-slate-100">
        <p class="text-sm font-medium text-slate-500">Обязательства перед вендорами</p>
        <p class="mt-2 text-3xl font-semibold text-emerald-600"><%= formatCurrency(statsData.vendorOutstanding) %></p>
        <p class="text-xs uppercase tracking-widest text-slate-400">сум к выплате</p>
        <p class="mt-4 text-sm text-slate-500">Начислено всего: <span class="font-semibold text-slate-900"><%= formatCurrency(statsData.vendorPayoutTotal) %></span> сум</p>
      </div>

      <div class="rounded-2xl bg-white p-5 shadow ring-1 ring-slate-100">
        <p class="text-sm font-medium text-slate-500">Комиссия мерчантов</p>
        <p class="mt-2 text-3xl font-semibold text-amber-600"><%= formatCurrency(statsData.merchantCommission) %></p>
        <p class="text-xs uppercase tracking-widest text-slate-400">сум выплачено</p>
        <p class="mt-4 text-sm text-slate-500">Средний заработок: <span class="font-semibold text-slate-900"><%= formatCurrency(statsData.averageMerchantCommission) %></span> сум</p>
      </div>
    </div>

    <div class="bg-white shadow ring-1 ring-slate-200 sm:rounded-2xl">
      <% if (sales.length === 0) { %>
        <div class="px-8 py-16 text-center">
          <svg class="mx-auto h-14 w-14 text-slate-300" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 6v12m6-6H6" />
          </svg>
          <h3 class="mt-4 text-base font-semibold text-slate-900">Продажи отсутствуют</h3>
          <p class="mt-2 text-sm text-slate-500">Создайте продажу, чтобы посмотреть информацию в таблице ниже.</p>
        </div>
      <% } else { %>
        <div class="px-6 py-4 border-b border-slate-200 flex items-center justify-between">
          <div>
            <h2 class="text-lg font-semibold text-slate-900">Все продажи</h2>
            <p class="text-sm text-slate-500">Список чеков в обратном хронологическом порядке</p>
          </div>
          <span class="rounded-full bg-slate-100 px-3 py-1 text-xs font-semibold text-slate-600">Всего: <%= statsData.totalSales %></span>
        </div>
        <div class="overflow-x-auto">
          <table class="min-w-full divide-y divide-slate-200 text-sm">
            <thead class="bg-slate-50 text-left text-xs font-semibold uppercase tracking-wide text-slate-500">
              <tr>
                <th class="py-3.5 pl-6 pr-3">ID</th>
                <th class="px-3 py-3.5">Дата</th>
                <th class="px-3 py-3.5">Продукт</th>
                <th class="px-3 py-3.5">Тип</th>
                <th class="px-3 py-3.5">Сумма</th>
                <th class="px-3 py-3.5">Ваучер</th>
                <th class="px-3 py-3.5">Мерчант</th>
                <th class="px-3 py-3.5">Статус</th>
                <th class="py-3.5 pl-3 pr-6 text-right">Чек</th>
              </tr>
            </thead>
            <tbody class="divide-y divide-slate-200 bg-white">
              <% sales.forEach(sale => { %>
                <tr class="hover:bg-slate-50 transition">
                  <td class="whitespace-nowrap py-4 pl-6 pr-3 font-semibold text-slate-900">#<%= sale.id %></td>
                  <td class="whitespace-nowrap px-3 py-4 text-slate-500"><%= new Date(sale.date).toLocaleString() %></td>
                  <td class="whitespace-nowrap px-3 py-4 text-slate-600"><%= sale.productName %></td>
                  <td class="whitespace-nowrap px-3 py-4">
                    <% if (sale.saleType === 'ONLINE') { %>
                      <span class="inline-flex items-center gap-1 rounded-full bg-green-100 px-3 py-1 text-xs font-medium text-green-700 ring-1 ring-inset ring-green-600/20">
                        <span class="h-1.5 w-1.5 rounded-full bg-green-500"></span>
                        Онлайн
                      </span>
                    <% } else { %>
                      <span class="inline-flex items-center gap-1 rounded-full bg-slate-100 px-3 py-1 text-xs font-medium text-slate-600 ring-1 ring-inset ring-slate-500/10">
                        <span class="h-1.5 w-1.5 rounded-full bg-slate-400"></span>
                        Оффлайн
                      </span>
                    <% } %>
                  </td>
                  <td class="whitespace-nowrap px-3 py-4 font-mono text-slate-900"><%= sale.price.toLocaleString('ru-RU') %> сум</td>
                  <td class="whitespace-nowrap px-3 py-4 font-mono text-slate-500"><%= sale.voucherValue %></td>
                  <td class="whitespace-nowrap px-3 py-4 text-slate-600"><%= sale.merchantUsername %></td>
                  <td class="whitespace-nowrap px-3 py-4">
                    <span class="inline-flex items-center rounded-md bg-emerald-50 px-2 py-1 text-xs font-semibold text-emerald-700 ring-1 ring-inset ring-emerald-600/20">
                      <%= sale.status %>
                    </span>
                  </td>
                  <td class="whitespace-nowrap py-4 pl-3 pr-6 text-right">
                    <% if (sale.receiptPath) { %>
                      <a href="/<%= normalizePath(sale.receiptPath) %>" target="_blank"
                        class="inline-flex items-center rounded-md bg-blue-50 px-3 py-1.5 text-xs font-semibold text-blue-700 ring-1 ring-inset ring-blue-600/10 hover:bg-blue-100">
                        <svg class="w-4 h-4 mr-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
                        </svg>
                        Чек
                      </a>
                    <% } else { %>
                      <span class="text-slate-400 text-xs">нет</span>
                    <% } %>
                  </td>
                </tr>
              <% }) %>
            </tbody>
          </table>
        </div>
      <% } %>
    </div>
  </div>
</body>
</html>
