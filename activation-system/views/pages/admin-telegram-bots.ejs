<!DOCTYPE html>
<html lang="ru">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Telegram Боты - Admin Panel</title>
    <script src="https://cdn.tailwindcss.com"></script>
</head>

<body class="bg-gray-50">
    <%- include('../partials/admin-navbar') %>

        <div class="container mx-auto px-4 py-8 mt-20">
            <div class="flex justify-between items-center mb-6">
                <h1 class="text-3xl font-bold text-gray-800">Telegram Боты</h1>
                <a href="/admin/telegram-bots/create"
                    class="bg-indigo-600 hover:bg-indigo-700 text-white px-6 py-2 rounded-lg transition">
                    + Создать бота
                </a>
            </div>

            <% if (bots.length===0) { %>
                <div class="bg-white rounded-lg shadow p-8 text-center">
                    <p class="text-gray-500">Нет настроенных ботов</p>
                </div>
                <% } else { %>
                    <div class="bg-white rounded-lg shadow overflow-hidden">
                        <table class="min-w-full divide-y divide-gray-200">
                            <thead class="bg-gray-50">
                                <tr>
                                    <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Название
                                    </th>
                                    <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Магазины
                                    </th>
                                    <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">
                                        Пользователи</th>
                                    <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Статус
                                    </th>
                                    <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase">Действия
                                    </th>
                                </tr>
                            </thead>
                            <tbody class="bg-white divide-y divide-gray-200">
                                <% bots.forEach(bot=> { %>
                                    <tr>
                                        <td class="px-6 py-4 whitespace-nowrap">
                                            <div class="text-sm font-medium text-gray-900">
                                                <%= bot.name %>
                                            </div>
                                        </td>
                                        <td class="px-6 py-4">
                                            <div class="text-sm text-gray-500">
                                                <% if (bot.stores.length> 0) { %>
                                                    <%= bot.stores.map(s=> s.store.name).join(', ') %>
                                                        <% } else { %>
                                                            <span class="text-gray-400">Нет привязанных</span>
                                                            <% } %>
                                            </div>
                                        </td>
                                        <td class="px-6 py-4 whitespace-nowrap">
                                            <div class="text-sm text-gray-500">
                                                <% try { %>
                                                    <%= JSON.parse(bot.authorizedUsers).length %> польз.
                                                        <% } catch(e) { %>
                                                            <%= bot.authorizedUsers.split(',').filter(x=>
                                                                x.trim()).length %> польз.
                                                                <% } %>
                                            </div>
                                        </td>
                                        <td class="px-6 py-4 whitespace-nowrap">
                                            <% if (bot.isActive) { %>
                                                <span
                                                    class="px-2 inline-flex text-xs leading-5 font-semibold rounded-full bg-green-100 text-green-800">
                                                    Активен
                                                </span>
                                                <% } else { %>
                                                    <span
                                                        class="px-2 inline-flex text-xs leading-5 font-semibold rounded-full bg-gray-100 text-gray-800">
                                                        Неактивен
                                                    </span>
                                                    <% } %>
                                        </td>
                                        <td class="px-6 py-4 whitespace-nowrap text-sm font-medium">
                                            <button onclick="testBot(<%= bot.id %>)"
                                                class="text-blue-600 hover:text-blue-900 mr-3">Тест</button>
                                            <a href="/admin/telegram-bots/<%= bot.id %>/edit"
                                                class="text-indigo-600 hover:text-indigo-900 mr-3">Изменить</a>
                                            <form action="/admin/telegram-bots/<%= bot.id %>/delete" method="POST"
                                                class="inline" onsubmit="return confirm('Удалить бота?')">
                                                <button type="submit"
                                                    class="text-red-600 hover:text-red-900">Удалить</button>
                                            </form>
                                        </td>
                                    </tr>
                                    <% }) %>
                            </tbody>
                        </table>
                    </div>
                    <% } %>
        </div>

        <script>
            async function testBot(botId) {
                if (!confirm('Отправить тестовое сообщение?')) return;

                try {
                    const response = await fetch(`/admin/telegram-bots/${botId}/test`, {
                        method: 'POST',
                        headers: { 'Content-Type': 'application/json' }
                    });
                    const result = await response.json();

                    if (result.success) {
                        alert('Тестовое сообщение отправлено успешно!');
                    } else {
                        alert('Ошибка: ' + (result.error || 'Неизвестная ошибка'));
                    }
                } catch (error) {
                    alert('Ошибка при отправке: ' + error.message);
                }
            }
        </script>
</body>

</html>