<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Admin Panel</title>
    <link rel="icon" type="image/svg+xml" href="/images/Vector.svg">
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="/css/admin.css" rel="stylesheet">
    <script>
        window.__APP_ROLE__ = <% - JSON.stringify(appRole || 'Admin') %>;
    </script>
</head>

<body class="bg-gray-100">
    <!-- Navbar -->
    <nav class="bg-white shadow-lg">
        <div class="max-w-7xl mx-auto px-4">
            <div class="flex justify-between h-16">
                <div class="flex">
                    <div class="flex-shrink-0 flex items-center">
                        <a href="/admin/dashboard" class="text-xl font-bold text-gray-800">
                            Admin Panel
                        </a>
                    </div>
                    <div class="hidden md:ml-6 md:flex md:space-x-8">
                        <a href="/admin/dashboard"
                            class="border-b-2 border-transparent hover:border-blue-500 text-gray-500 hover:text-gray-700 inline-flex items-center px-1 pt-1 text-sm font-medium">
                            Dashboard
                        </a>
                        <a href="/admin/users"
                            class="border-b-2 border-transparent hover:border-blue-500 text-gray-500 hover:text-gray-700 inline-flex items-center px-1 pt-1 text-sm font-medium">
                            Users
                        </a>
                        <a href="/admin/vendors"
                            class="border-b-2 border-transparent hover:border-blue-500 text-gray-500 hover:text-gray-700 inline-flex items-center px-1 pt-1 text-sm font-medium">
                            Vendors
                        </a>
                        <a href="/admin/products"
                            class="border-b-2 border-transparent hover:border-blue-500 text-gray-500 hover:text-gray-700 inline-flex items-center px-1 pt-1 text-sm font-medium">
                            Products
                        </a>
                        <a href="/admin/vouchers"
                            class="border-b-2 border-transparent hover:border-blue-500 text-gray-500 hover:text-gray-700 inline-flex items-center px-1 pt-1 text-sm font-medium">
                            Vouchers
                        </a>
                        <a href="/admin/sales"
                            class="border-b-2 border-transparent hover:border-blue-500 text-gray-500 hover:text-gray-700 inline-flex items-center px-1 pt-1 text-sm font-medium">
                            Sales
                        </a>
                        <a href="/admin/merchants"
                            class="border-b-2 border-transparent hover:border-blue-500 text-gray-500 hover:text-gray-700 inline-flex items-center px-1 pt-1 text-sm font-medium">
                            Merchants
                        </a>
                    </div>
                </div>
                <div class="flex items-center">
                    <div class="flex-shrink-0">
                        <form action="/logout" method="POST" class="inline">
                            <button type="submit"
                                class="bg-red-500 hover:bg-red-600 text-white px-4 py-2 rounded-md text-sm font-medium">
                                Выйти
                            </button>
                        </form>
                    </div>
                </div>
            </div>
        </div>
    </nav>

    <!-- Mobile menu -->
    <div class="md:hidden">
        <div class="px-2 pt-2 pb-3 space-y-1">
            <a href="/admin/dashboard"
                class="block px-3 py-2 rounded-md text-base font-medium text-gray-700 hover:text-gray-900 hover:bg-gray-50">Dashboard</a>
            <a href="/admin/users"
                class="block px-3 py-2 rounded-md text-base font-medium text-gray-700 hover:text-gray-900 hover:bg-gray-50">Users</a>
            <a href="/admin/vendors"
                class="block px-3 py-2 rounded-md text-base font-medium text-gray-700 hover:text-gray-900 hover:bg-gray-50">Vendors</a>
            <a href="/admin/products"
                class="block px-3 py-2 rounded-md text-base font-medium text-gray-700 hover:text-gray-900 hover:bg-gray-50">Products</a>
            <a href="/admin/vouchers"
                class="block px-3 py-2 rounded-md text-base font-medium text-gray-700 hover:text-gray-900 hover:bg-gray-50">Vouchers</a>
            <a href="/admin/sales"
                class="block px-3 py-2 rounded-md text-base font-medium text-gray-700 hover:text-gray-900 hover:bg-gray-50">Sales</a>
            <a href="/admin/merchants"
                class="block px-3 py-2 rounded-md text-base font-medium text-gray-700 hover:text-gray-900 hover:bg-gray-50">Merchants</a>
        </div>
    </div>

    <!-- Main content -->
    <main class="max-w-7xl mx-auto py-6 sm:px-6 lg:px-8">
        <%- body %>
    </main>
</body>
<script type="module">
    if (window.__APP_ROLE__ !== 'Client' && 'serviceWorker' in navigator) {
        navigator.serviceWorker.getRegistrations?.().then((registrations) => {
            registrations
                .filter((registration) => registration?.scope?.startsWith(`${window.location.origin}/`))
                .forEach((registration) => registration.unregister().catch(() => { }));
        }).catch(() => { });
    }
</script>

</html>