<!DOCTYPE html>
<html lang="ru">
<head>
  <meta charset="UTF-8">
  <title>Панель управления</title>
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
  <% if (isClient) { %>
    <link rel="manifest" href="/manifest.json">
    <meta name="theme-color" content="#9EE52D">
    <link rel="apple-touch-icon" href="/wallet/icons/icon-192.png">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="apple-mobile-web-app-status-bar-style" content="default">
  <% } %>
  <script>
    window.__APP_ROLE__ = <%- JSON.stringify(appRole || 'Public') %>;
  </script>
</head>

<body class="bg-light">
  <!-- Контент страницы -->
  <div class="container py-4">
    <%- body %>
  </div>
  <% if (!isClient) { %>
    <script type="module" src="/js/admin-session.js"></script>
  <% } %>
  <script type="module">
    const appRole = window.__APP_ROLE__;
    if (appRole === 'Client') {
      import('/js/register-sw.js')
        .then(({ registerServiceWorker }) => registerServiceWorker())
        .catch((error) => {
          console.error('Service worker registration failed', error);
        });
    } else if ('serviceWorker' in navigator) {
      navigator.serviceWorker.getRegistrations?.().then((registrations) => {
        registrations
          .filter((registration) => registration?.scope?.startsWith(`${window.location.origin}/`))
          .forEach((registration) => registration.unregister().catch(() => {}));
      }).catch(() => {});
    }
  </script>
</body>

</html>
