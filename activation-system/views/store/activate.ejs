<div class="card p-4 mb-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h3 class="mb-0">Активация ваучера <%= store.name %>
        </h3>
        <form action="/<%= store.slug %>/logout" method="POST" class="d-inline">
            <button type="submit" class="btn btn-outline-danger btn-sm">Выйти</button>
        </form>
    </div>
    <div class="mb-3">
        <label class="form-label">Код ваучера</label>
        <input type="text" id="voucherCode" class="form-control" placeholder="Введите код">
    </div>
    <button class="btn btn-success w-100" onclick="activate()">Активировать</button>
    <div id="error-msg" class="alert alert-danger mt-3" style="display:none;"></div>
</div>

<div class="card p-4">
    <h5>История активаций</h5>
    <div class="table-responsive">
        <table class="table">
            <thead>
                <tr>
                    <th>Дата</th>
                    <th>Товар</th>
                    <th>Ключ</th>
                </tr>
            </thead>
            <tbody>
                <% if (history.length===0) { %>
                    <tr>
                        <td colspan="3" class="text-center text-muted">История пуста</td>
                    </tr>
                    <% } %>
                        <% history.forEach(item=> { %>
                            <tr>
                                <td>
                                    <%= new Date(item.activatedAt).toLocaleString() %>
                                </td>
                                <td>
                                    <%= item.voucher.product.name %>
                                </td>
                                <td>
                                    <% if (item.voucher.rokkyOrder && item.voucher.rokkyOrder.key) { %>
                                        <code><%= item.voucher.rokkyOrder.key %></code>
                                        <% } else { %>
                                            <span class="badge bg-warning text-dark">Ожидание</span>
                                            <% } %>
                                </td>
                            </tr>
                            <% }) %>
            </tbody>
        </table>
    </div>
</div>

<!-- Success Modal -->
<div class="modal fade" id="successModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">Успешно!</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body text-center">
                <p>Ваш цифровой ключ:</p>
                <h3 id="modalKey" class="text-primary"></h3>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Закрыть</button>
            </div>
        </div>
    </div>
</div>

<script>
    const storeSlug = '<%= store.slug %>';

    async function activate() {
        const code = document.getElementById('voucherCode').value;
        if (!code) return showError('Введите код');

        try {
            const res = await fetch(`/${storeSlug}/activate`, {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ voucherCode: code, storeSlug })
            });
            const data = await res.json();

            if (data.success) {
                if (data.key) {
                    document.getElementById('modalKey').innerText = data.key;
                    const modal = new bootstrap.Modal(document.getElementById('successModal'));
                    modal.show();
                    document.getElementById('successModal').addEventListener('hidden.bs.modal', () => {
                        window.location.reload();
                    });
                } else {
                    alert(data.message);
                    window.location.reload();
                }
            } else {
                showError(data.error || 'Ошибка активации');
            }
        } catch (e) {
            showError('Ошибка сети');
        }
    }

    function showError(msg) {
        const el = document.getElementById('error-msg');
        el.innerText = msg;
        el.style.display = 'block';
    }
</script>