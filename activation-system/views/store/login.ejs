<div class="card p-4">
    <h3 class="text-center mb-4">Вход в <%= store ? store.name : 'Магазин' %>
    </h3>

    <div id="step-phone">
        <div class="mb-3">
            <label class="form-label">Номер телефона</label>
            <input type="tel" id="phone" class="form-control" placeholder="+998901234567">
        </div>
        <button class="btn btn-primary w-100" onclick="sendOtp()">Получить код</button>
    </div>

    <div id="step-otp" style="display:none;">
        <div class="mb-3">
            <label class="form-label">Код из SMS</label>
            <input type="text" id="otp" class="form-control" placeholder="123456">
        </div>
        <button class="btn btn-primary w-100" onclick="verifyOtp()">Войти</button>
        <button class="btn btn-link w-100 mt-2" onclick="backToPhone()">Изменить номер</button>
    </div>

    <div id="error-msg" class="alert alert-danger mt-3" style="display:none;"></div>
</div>

<script>
    const storeSlug = '<%= store ? store.slug : "" %>';
    let currentPhone = '';

    async function sendOtp() {
        const phone = document.getElementById('phone').value;
        if (!phone) return showError('Введите номер телефона');

        try {
            const res = await fetch(`/${storeSlug}/otp`, {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ phone, storeSlug })
            });
            const data = await res.json();

            if (data.success) {
                currentPhone = phone;
                document.getElementById('step-phone').style.display = 'none';
                document.getElementById('step-otp').style.display = 'block';
                hideError();
            } else {
                showError(data.error || 'Ошибка отправки SMS');
            }
        } catch (e) {
            showError('Ошибка сети');
        }
    }

    async function verifyOtp() {
        const code = document.getElementById('otp').value;
        if (!code) return showError('Введите код');

        try {
            const res = await fetch(`/${storeSlug}/verify`, {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ phone: currentPhone, code, storeSlug })
            });
            const data = await res.json();

            if (data.success) {
                window.location.href = data.redirectUrl;
            } else {
                showError(data.error || 'Неверный код');
            }
        } catch (e) {
            showError('Ошибка сети');
        }
    }

    function backToPhone() {
        document.getElementById('step-phone').style.display = 'block';
        document.getElementById('step-otp').style.display = 'none';
        hideError();
    }

    function showError(msg) {
        const el = document.getElementById('error-msg');
        el.innerText = msg;
        el.style.display = 'block';
    }

    function hideError() {
        document.getElementById('error-msg').style.display = 'none';
    }
</script>