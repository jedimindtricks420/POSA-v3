            "text": "{\n  \"name\": \"Namo Wallet\",\n  \"short_name\": \"Wallet\",\n  \"start_url\": \"/wallet\",\n  \"display\": \"standalone\",\n  \"orientation\": \"portrait\",\n  \"background_color\": \"#F5F5F7\",\n  \"theme_color\": \"#ffffff\",\n  \"description\": \"Клиентский кошелек Namo с поддержкой оффлайн, QR и push уведомлений.\",\n  \"icons\": [\n    {\n      \"src\": \"/images/icon-192.png\",\n      \"sizes\": \"192x192\",\n      \"type\": \"image/png\",\n      \"purpose\": \"any maskable\"\n    },\n    {\n      \"src\": \"/images/icon-512.png\",\n      \"sizes\": \"512x512\",\n      \"type\": \"image/png\",\n      \"purpose\": \"any maskable\"\n    }\n  ],\n  \"shortcuts\": [\n    {\n      \"name\": \"Мои ваучеры\",\n      \"short_name\": \"Ваучеры\",\n      \"url\": \"/client/dashboard\"\n    },\n    {\n      \"name\": \"Сканер QR\",\n      \"short_name\": \"Сканер\",\n      \"url\": \"/client/qr-scanner\"\n    },\n    {\n      \"name\": \"Поддержка\",\n      \"short_name\": \"Помощь\",\n      \"url\": \"tel:+998781234567\"\n    }\n  ]\n}\n"
