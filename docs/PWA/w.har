            "text": "<!DOCTYPE html>\n<html lang=\"ru\">\n<head>\n  <meta charset=\"UTF-8\">\n  <title>Панель управления</title>\n  <meta name=\"viewport\" content=\"width=device-width, initial-scale=1\">\n  <link href=\"https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css\" rel=\"stylesheet\">\n  \n    <link rel=\"manifest\" href=\"/manifest.json\">\n    <meta name=\"theme-color\" content=\"#0ea5e9\">\n    <link rel=\"apple-touch-icon\" href=\"/wallet/icons/icon-192.png\">\n    <meta name=\"apple-mobile-web-app-capable\" content=\"yes\">\n    <meta name=\"apple-mobile-web-app-status-bar-style\" content=\"default\">\n  \n  <script>\n    window.__APP_ROLE__ = \"Client\";\n  </script>\n</head>\n\n<body class=\"bg-light\">\n  <!-- Контент страницы -->\n  <div class=\"container py-4\">\n    <!DOCTYPE html>\n<html lang=\"ru\" class=\"h-full\">\n<head>\n  <meta charset=\"utf-8\" />\n  <meta name=\"viewport\" content=\"width=device-width, initial-scale=1, viewport-fit=cover, maximum-scale=1\" />\n  <meta name=\"mobile-web-app-capable\" content=\"yes\" />\n  <meta name=\"theme-color\" content=\"#0A84FF\" />\n  <meta name=\"apple-mobile-web-app-capable\" content=\"yes\" />\n  <meta name=\"apple-mobile-web-app-status-bar-style\" content=\"black-translucent\" />\n  <meta name=\"apple-mobile-web-app-status-bar-style\" content=\"black\" media=\"(prefers-color-scheme: light)\">\n  <meta name=\"apple-mobile-web-app-status-bar-style\" content=\"black-translucent\" media=\"(prefers-color-scheme: dark)\">\n  <meta name=\"apple-mobile-web-app-title\" content=\"Namo Wallet\" />\n  <link rel=\"manifest\" href=\"/manifest.json\" />\n  <link rel=\"apple-touch-icon\" href=\"/images/icon-192.png\" />\n  <link rel=\"icon\" type=\"image/png\" sizes=\"32x32\" href=\"/images/icon-192.png\" />\n  <script>\n    window.__APP_ROLE__ = 'Client';\n  </script>\n  <!-- Inter font -->\n  <link rel=\"preconnect\" href=\"https://fonts.googleapis.com\">\n  <link rel=\"preconnect\" href=\"https://fonts.gstatic.com\" crossorigin>\n  <link href=\"https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap\" rel=\"stylesheet\">\n  <link rel=\"stylesheet\" href=\"/css/client.css\" />\n  <title>Мои ваучеры</title>\n</head>\n\n<body class=\"relative min-h-screen bg-wallet-bg text-slate-900 dark:bg-wallet-dark dark:text-slate-100 safe-area-bottom pt-[calc(env(safe-area-inset-top,0px)+4rem)]\">\n\n  <main class=\"mx-auto flex w-full max-w-md flex-col gap-6 px-4 pb-16\">\n    <section>\n      <div class=\"flex items-center justify-between pt-2\">\n        <h2 class=\"text-xl font-semibold\">Мои ваучеры</h2>\n        <button id=\"walletRefresh\" class=\"refresh-btn\">Обновить</button>\n      </div>\n      <div id=\"walletEmpty\" class=\"mt-6 hidden rounded-3xl bg-white p-10 text-center text-sm text-slate-500 dark:bg-slate-900 dark:text-slate-300\">\n        Пока нет ваучеров. Когда появится новый, он отобразится здесь автоматически.\n      </div>\n      <div id=\"walletSkeleton\" class=\"mt-6\">\n        <div class=\"animate-pulse space-y-4\">\n  <div class=\"h-48 rounded-3xl bg-white/40\"></div>\n  <div class=\"h-48 rounded-3xl bg-white/40\"></div>\n</div>\n\n      </div>\n      <div id=\"walletList\" class=\"mt-6 hidden space-y-4\"></div>\n    </section>\n  </main>\n\n  <nav class=\"fixed inset-x-0 bottom-0 z-40 pb-[env(safe-area-inset-bottom,0px)]\">\n  <div class=\"px-6 pb-6\">\n    <div class=\"glass-panel flex items-center justify-around px-4 py-2 text-sm text-slate-500 dark:text-slate-300\">\n      <a href=\"/client/dashboard\" class=\"flex flex-col items-center gap-1 text-apple-blue font-semibold\">\n        <svg class=\"h-5 w-5\" xmlns=\"http://www.w3.org/2000/svg\" fill=\"none\" viewBox=\"0 0 24 24\" stroke=\"currentColor\">\n          <path stroke-linecap=\"round\" stroke-linejoin=\"round\" stroke-width=\"1.5\" d=\"M3.75 8.25h16.5v10.5a1.5 1.5 0 0 1-1.5 1.5H5.25a1.5 1.5 0 0 1-1.5-1.5V8.25Zm0-3a1.5 1.5 0 0 1 1.5-1.5h13.5a1.5 1.5 0 0 1 1.5 1.5V8.25H3.75V5.25Z\" />\n        </svg>\n        <span>Wallet</span>\n      </a>\n      <a href=\"/client/qr-scanner\" class=\"flex flex-col items-center gap-1 \">\n        <svg class=\"h-5 w-5\" xmlns=\"http://www.w3.org/2000/svg\" fill=\"none\" viewBox=\"0 0 24 24\" stroke=\"currentColor\">\n          <path stroke-linecap=\"round\" stroke-linejoin=\"round\" stroke-width=\"1.5\" d=\"M3 7.5A1.5 1.5 0 0 1 4.5 6h3A1.5 1.5 0 0 1 9 7.5v3A1.5 1.5 0 0 1 7.5 12h-3A1.5 1.5 0 0 1 3 10.5v-3Zm12 0A1.5 1.5 0 0 1 16.5 6h3A1.5 1.5 0 0 1 21 7.5v3a1.5 1.5 0 0 1-1.5 1.5h-3A1.5 1.5 0 0 1 15 10.5v-3Zm-12 9A1.5 1.5 0 0 1 4.5 15h3A1.5 1.5 0 0 1 9 16.5v3A1.5 1.5 0 0 1 7.5 21h-3A1.5 1.5 0 0 1 3 19.5v-3Zm12 0a1.5 1.5 0 0 1 1.5-1.5h3a1.5 1.5 0 0 1 1.5 1.5v3A1.5 1.5 0 0 1 19.5 21h-3A1.5 1.5 0 0 1 15 19.5v-3Z\" />\n        </svg>\n        <span>QR</span>\n      </a>\n      <a href=\"/client/profile\" class=\"flex flex-col items-center gap-1 \">\n        <svg class=\"h-5 w-5\" xmlns=\"http://www.w3.org/2000/svg\" fill=\"none\" viewBox=\"0 0 24 24\" stroke=\"currentColor\">\n          <path stroke-linecap=\"round\" stroke-linejoin=\"round\" stroke-width=\"1.5\" d=\"M15.25 7.5a3.25 3.25 0 1 1-6.5 0 3.25 3.25 0 0 1 6.5 0ZM5.98 18.42a6.51 6.51 0 0 1 12.04 0A11.96 11.96 0 0 1 12 21a11.96 11.96 0 0 1-6.02-2.58Z\" />\n        </svg>\n        <span>Profile</span>\n      </a>\n    </div>\n  </div>\n</nav>\n\n  <div id=\"voucherModal\" class=\"fixed inset-0 z-50 hidden items-end justify-center bg-slate-900/40 backdrop-blur-sm sm:items-center\">\n  <div class=\"relative w-full max-w-md rounded-t-3xl bg-white p-6 shadow-2xl dark:bg-slate-900 sm:rounded-3xl max-h-[90svh] overflow-y-auto overscroll-contain\">\n    <button id=\"voucherModalClose\" class=\"absolute right-4 top-4 text-slate-400 hover:text-slate-600\" aria-label=\"Close modal\">\n      <svg class=\"h-5 w-5\" xmlns=\"http://www.w3.org/2000/svg\" fill=\"none\" viewBox=\"0 0 24 24\" stroke=\"currentColor\">\n        <path stroke-linecap=\"round\" stroke-linejoin=\"round\" stroke-width=\"1.5\" d=\"M6 18 18 6m0 12L6 6\" />\n      </svg>\n    </button>\n    <div class=\"space-y-6\">\n      <div class=\"space-y-2 text-center\">\n        <p id=\"voucherModalProduct\" class=\"text-xs uppercase tracking-wider text-slate-500\"></p>\n        <h2 id=\"voucherModalValue\" class=\"text-2xl font-semibold text-slate-900 dark:text-slate-100\"></h2>\n        <div id=\"voucherModalStatus\" class=\"badge mx-auto text-slate-900 dark:text-slate-900\"></div>\n      </div>\n      <div class=\"space-y-4\">\n        <div class=\"rounded-3xl bg-slate-50 p-6 dark:bg-slate-800\">\n          <div id=\"voucherModalQr\" class=\"flex items-center justify-center\"></div>\n          <p class=\"mt-4 text-center text-xs text-slate-500\">Покажите этот QR код продавцу</p>\n        </div>\n        <div class=\"rounded-2xl bg-slate-100 p-4 dark:bg-slate-800\">\n          <p class=\"text-xs text-slate-500 text-center\">Штрихкод</p>\n          <div id=\"voucherModalBarcode\" class=\"mt-2 flex justify-center\"></div>\n        </div>\n        <div class=\"rounded-2xl bg-slate-100 p-4 text-sm leading-relaxed text-slate-600 dark:bg-slate-800 dark:text-slate-300\" id=\"voucherModalTerms\"></div>\n      </div>\n      <div class=\"grid grid-cols-1 gap-3 sm:grid-cols-2\">\n        <button id=\"voucherModalAddApple\" class=\"inline-flex items-center justify-center rounded-2xl bg-slate-900 px-4 py-3 text-sm font-semibold text-white transition hover:bg-slate-700\">\n          Добавить в Apple Wallet\n        </button>\n        <button id=\"voucherModalAddGoogle\" class=\"inline-flex items-center justify-center rounded-2xl bg-slate-200 px-4 py-3 text-sm font-semibold text-slate-900 transition hover:bg-slate-300 dark:bg-slate-700 dark:text-white\">\n          Добавить в Google Wallet\n        </button>\n        <button id=\"voucherModalCopy\" class=\"inline-flex items-center justify-center rounded-2xl bg-apple-blue px-4 py-3 text-sm font-semibold text-white transition hover:bg-blue-600\">\n          Скопировать код\n        </button>\n        <button id=\"voucherModalShare\" class=\"inline-flex items-center justify-center rounded-2xl border border-slate-200 px-4 py-3 text-sm font-semibold text-slate-700 transition hover:bg-slate-100 dark:border-slate-700 dark:text-white dark:hover:bg-slate-800\">\n          Поделиться\n        </button>\n      </div>\n      <button id=\"voucherModalCloseBottom\" class=\"w-full rounded-2xl border border-slate-200 px-4 py-3 text-sm font-semibold text-slate-700 transition hover:bg-slate-100 dark:border-slate-700 dark:text-white dark:hover:bg-slate-800\">\n        Закрыть\n      </button>\n      <p id=\"voucherModalSyncInfo\" class=\"text-center text-xs text-slate-400\"></p>\n    </div>\n  </div>\n</div>\n\n\n  <script>\n    window.__WALLET_BOOTSTRAP__ = {\n      phone: \"+998998137861\",\n      vouchers: []\n    };\n    window.__WALLET_PUSH_PUBLIC_KEY__ = null;\n  </script>\n  <script type=\"module\" src=\"/js/client-session.js\"></script>\n  <script type=\"module\" src=\"/js/client-app.js\"></script>\n</body>\n</html>\n\n  </div>\n  \n  <script type=\"module\">\n    const appRole = window.__APP_ROLE__;\n    if (appRole === 'Client') {\n      import('/js/register-sw.js')\n        .then(({ registerServiceWorker }) => registerServiceWorker())\n        .catch((error) => {\n          console.error('Service worker registration failed', error);\n        });\n    } else if ('serviceWorker' in navigator) {\n      navigator.serviceWorker.getRegistrations?.().then((registrations) => {\n        registrations\n          .filter((registration) => registration?.scope?.startsWith(`${window.location.origin}/`))\n          .forEach((registration) => registration.unregister().catch(() => {}));\n      }).catch(() => {});\n    }\n  </script>\n</body>\n\n</html>\n"
